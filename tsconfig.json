{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist",
    "debug",
    "node_modules",
    "infrastructure/aws/build"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*":        ["./src/*"],
      "@shared/*":  ["./src/shared/*"],
      "@features/*": ["./src/features/*"],
      "@data/*":    ["./src/data/*"],
      "@core/*":    ["./src/core/*"],
      "@content/*": ["./src/content/*"]
    }
  }
}
