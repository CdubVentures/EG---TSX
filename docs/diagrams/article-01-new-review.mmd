flowchart TB
  subgraph INPUT["DEVELOPER INPUT"]
    I1["Developer runs:\nnode scripts/new-content.mjs\n  --type review\n  --category mouse\n  --brand Razer\n  --model 'Viper V3 Pro'"]
  end

  subgraph SCRIPT["CREATION SCRIPT"]
    direction TB
    S1["Derive article slug:\nrazer-viper-v3-pro-review"]
    S2["Look up product slug\nin mouse.json:\nrazer-viper-v3-pro"]
    S3["Create MDX file:\nsrc/content/reviews/mouse/\n  razer-viper-v3-pro-review.md\n\nFrontmatter:\n  category: mouse\n  brand: Razer\n  model: Viper V3 Pro\n  productId: razer-viper-v3-pro"]
    S4{"Does this article type\nhave its own images?"}
    S5["NO -- Reviews use the\nPRODUCT's image folder\n(already exists at\npublic/images/mouse/\nrazer/viper-v3-pro/)"]
    S6["YES -- Guides/News get\ntheir own image folder:\npublic/images/guides/mouse/\n  best-fps-mice-2026/"]
    S1 --> S2 --> S3 --> S4
    S4 -->|"Review"| S5
    S4 -->|"Guide / News"| S6
  end

  subgraph RESULT_R["REVIEW FILES ON DISK"]
    direction LR
    F1["src/content/reviews/mouse/\n  razer-viper-v3-pro-review.md\n\n(Astro entry.id =\n  razer-viper-v3-pro-review)"]
    F2["public/images/mouse/\n  razer/viper-v3-pro/\n    top---white+black_m.webp\n    feature-image_xxl.webp\n    ...\n\n(Product's image folder,\n  shared with snapshot page)"]
    F1 -.-|"productId links\nto product slug"| F2
  end

  subgraph RESULT_G["GUIDE / NEWS FILES ON DISK"]
    direction LR
    G1["src/content/guides/mouse/\n  best-fps-mice-2026.md\n\n(Astro entry.id =\n  best-fps-mice-2026)"]
    G2["public/images/guides/mouse/\n  best-fps-mice-2026/\n    hero_xl.webp\n    hero_blur.webp\n    ..."]
    G1 -.-|"slug matches\nfolder name"| G2
  end

