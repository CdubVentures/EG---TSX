flowchart LR
  subgraph SOURCES["DATA + IMAGE SOURCES"]
    direction TB
    S1["Product JSON\nmouse/keyboard/monitor.json\n\n100+ fields per product\nimagePath field for images\nslug field for lookups"]
    S2["Review Frontmatter\nsrc/content/reviews/\n\nEditorial: title, verdict,\npros, cons, body text\nproductId → links to product"]
    S3["Guide/News Frontmatter\nsrc/content/guides or news/\n\nAll metadata + body text\nSlug = image folder name"]
    S4["Brand Collection\nsrc/content/brands/\n\nBrand name, description\nSlug = image folder name"]
    S5["Game Collection\nsrc/content/games/\n\nGame name, genres\nSlug = image folder name"]
  end

  subgraph PAGES["PAGE TYPES — DATA + IMAGE SOURCE"]
    direction TB
    P1["Product Card\nDATA: Product JSON\nIMAGES: product.imagePath + stems"]
    P2["Snapshot Page\nDATA: Product JSON\nIMAGES: product.imagePath + stems"]
    P3["Review Page\nDATA: Frontmatter + Product JSON\nIMAGES: product.imagePath\n+ article folder for hero"]
    P4["Guide Page\nDATA: Frontmatter\nIMAGES: /images/guides/cat/slug/"]
    P5["News Page\nDATA: Frontmatter\nIMAGES: /images/news/cat/slug/"]
    P6["Brand Page\nDATA: Brand collection\nIMAGES: /images/brands/slug/"]
    P7["Game Page\nDATA: Game collection\nIMAGES: /images/games/slug/"]
  end

  S1 --> P1
  S1 --> P2
  S1 --> P3
  S2 --> P3
  S3 --> P4
  S3 --> P5
  S4 --> P6
  S5 --> P7

