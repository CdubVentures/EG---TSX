---
import MainLayout from '@shared/layouts/MainLayout.astro';
import AnnouncementBar from '@shared/ui/AnnouncementBar.astro';
import HomeHero from '@features/home/components/HomeHero.astro';
import TopProducts from '@features/home/components/TopProducts.astro';
import { CONFIG } from '@core/config';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('dataProducts');
const productCount = allProducts.length;
---

<MainLayout
  title={`${CONFIG.site.name} — The Smarter Way to Compare PC Gear`}
  description={CONFIG.site.defaultDescription}
  theme="gaming"
>
  <AnnouncementBar />

  <section class="home-rail-anchor -bg -pad-top" style="--home-rail-bg: var(--section-darkestdarker-background-color)">
    <div class="home-rail-main">
      <div class="home-top-wrapper">
        <HomeHero productCount={productCount} />
        <TopProducts />
      </div>
    </div>

    {/* Right ad rail (empty structural slot) */}
    <aside class="home-rail -right">
      <div class="sticky-stack" data-sticky="true">
        {/* Ad slot wired in Phase 5+ */}
      </div>
    </aside>
  </section>
</MainLayout>

<style is:global>
  /* ══════════════════════════════════════════════════════════════════════════
     HOME PAGE — Layout Grid & Section Ordering
     Port of view_index.css lines 22–162
     ══════════════════════════════════════════════════════════════════════════ */

  :root {
    --home-width: 1075px;
  }

  /* ── Full-bleed section wrapper with right rail ── */
  .home-rail-anchor {
    position: relative;
    display: grid;
    grid-template-columns:
      1fr minmax(0, var(--home-width)) 30px 300px 1fr;
    background: var(--home-rail-bg, transparent);
    padding-top: var(--home-rail-pad-top, 0);
    padding-bottom: var(--home-rail-pad-bottom, 0);
    isolation: isolate;
    padding-left: clamp(0px, -1650px + 103.125vw, 330px);
    padding-right: 2rem;
  }

  .home-rail-anchor:last-of-type {
    margin-bottom: 4rem;
  }

  .home-rail-main {
    grid-column: 2;
    min-width: 0;
  }

  .home-rail.-right {
    grid-column: 4;
    width: 300px;
    max-width: 300px;
    padding-top: var(--rail-pad-top, 0);
    padding-bottom: var(--rail-pad-bottom, 0);
  }

  /* Sticky opt-in */
  .home-rail.-right .sticky-stack {
    position: static;
  }

  .home-rail.-right .sticky-stack[data-sticky="true"] {
    position: sticky;
    top: var(--rail-sticky-top, calc(var(--top-bar-H, 64px) + 32px));
    will-change: top;
    isolation: isolate;
    z-index: 1000;
  }

  /* ── Hide rail on narrow viewports ── */
  @media (max-width: 1425px) {
    .home-rail-anchor {
      grid-template-columns: 1fr minmax(0, var(--home-width)) 1fr;
      padding-left: 0;
      padding-right: 0;
    }

    .home-rail.-right {
      display: none;
    }
  }

  /* Prevent horizontal scrollbars when rail shows */
  @media (min-width: 1351px) {
    body {
      overflow-x: clip;
    }
  }

  /* ── Home top wrapper (dark hero area) ── */
  .home-top-wrapper {
    display: flex;
    flex-direction: column;
    background-color: var(--section-darkestdarker-background-color);
    padding-bottom: 4rem;
  }

  /* ── Desktop section ordering ── */
  /* Default order set in child components:
     .home-page-intro: order 1  (TopProducts)
     .home-title: order 2       (HomeHero title)
     .home-title-stats-container: order 3 (HomeHero buttons)
  */

  /* ── Mobile section reordering ── */
  @media (max-width: 900px) {
    .home-top-wrapper {
      padding-bottom: 0;
    }
  }
</style>
