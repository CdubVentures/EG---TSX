---
import MainLayout from '@shared/layouts/MainLayout.astro';
import AnnouncementBar from '@shared/ui/AnnouncementBar.astro';
import HomeHero from '@features/home/components/HomeHero.astro';
import TopProducts from '@features/home/components/TopProducts.astro';
import Dashboard from '@features/home/components/Dashboard.astro';
import AdSlot from '@features/ads/components/AdSlot.astro';
import SectionDivider from '@shared/ui/SectionDivider.astro';
import GamesScroller from '@features/home/components/GamesScroller.astro';
import FeaturedScroller from '@features/home/components/FeaturedScroller.astro';
import LatestNews from '@features/home/components/LatestNews.astro';
import { CONFIG } from '@core/config';
import { getProducts } from '@core/products';
import { getReviews, getGuides, getNews, getGames } from '@core/content';
import { buildDashboard, sortByPinnedThenDate, pinnedSet, badgesMap } from '@core/dashboard';
import type { DashboardEntry } from '@core/article-helpers';
import { toFeaturedItem, groupByCategory, getActiveCategories } from '@features/home/featured-scroller-utils';

const allProducts = await getProducts();
const productCount = allProducts.length;

// ── Dashboard data: merge reviews + guides + news ──
const [reviews, guides, news] = await Promise.all([
  getReviews(),
  getGuides(),
  getNews(),
]);

// Tag each entry with _collection so components know which collection it came from
const taggedReviews = reviews.map(e => ({ ...e, _collection: 'reviews' })) as DashboardEntry[];
const taggedGuides  = guides.map(e => ({ ...e, _collection: 'guides' })) as DashboardEntry[];
const taggedNews    = news.map(e => ({ ...e, _collection: 'news' })) as DashboardEntry[];

const allArticles = [...taggedReviews, ...taggedGuides, ...taggedNews];

// Dashboard: editorial slot control, pins, badges from config/data/content.json
const dashboardItems = buildDashboard(allArticles);

// News sidebar: first 3 news items with hero image (from original news list, not merged)
const newsItems = taggedNews.filter(e => e.data.hero).slice(0, 3);

// Dedup set: IDs already used in dashboard
const _usedIds = new Set(dashboardItems.map(e => e.entry.id));

// ── Games data ──
// WHY: Tag with _collection so sortByPinnedThenDate can build "games:{id}" keys
// to match against pinnedSet. Without this, pinned games don't float to front.
const rawGames = await getGames();
const taggedGames = rawGames.map(e => ({ ...e, _collection: 'games' })) as DashboardEntry[];
const games = sortByPinnedThenDate(taggedGames, pinnedSet);

// ── Featured Reviews + Highlighted Guides data ──
const availableReviews = taggedReviews.filter(e => !_usedIds.has(e.id));
const availableGuides  = taggedGuides.filter(e => !_usedIds.has(e.id));

const pinBadgeConfig = { pinnedSet, badgesMap };
const reviewItems = sortByPinnedThenDate(availableReviews.filter(e => e.data.hero), pinnedSet).map(e => toFeaturedItem(e, pinBadgeConfig));
const guideItems  = sortByPinnedThenDate(availableGuides.filter(e => e.data.hero), pinnedSet).map(e => toFeaturedItem(e, pinBadgeConfig));

const reviewsByCategory = groupByCategory(reviewItems);
const guidesByCategory  = groupByCategory(guideItems);
const reviewActiveCats  = getActiveCategories(reviewsByCategory, CONFIG.contentCategories);
const guideActiveCats   = getActiveCategories(guidesByCategory, CONFIG.contentCategories);

// ── Latest News data (scroller4x4 section) ──
const availableNews = taggedNews.filter(e => !_usedIds.has(e.id) && e.data.hero);
const latestNewsItems = sortByPinnedThenDate(availableNews, pinnedSet).map(e => toFeaturedItem(e, pinBadgeConfig));
---

<MainLayout
  title={`${CONFIG.site.name} — The Smarter Way to Compare PC Gear`}
  description={CONFIG.site.defaultDescription}
  canonicalUrl={`${CONFIG.site.url}/`}
  theme="gaming"
>
  <AnnouncementBar />

  <section class="home-rail-anchor -bg -pad-top" style="--home-rail-bg: var(--section-darkestdarker-background-color)">
    <div class="home-rail-main">
      <div class="home-top-wrapper">
        <HomeHero productCount={productCount} />
        <TopProducts />
      </div>
    </div>

    <aside class="home-rail -right" style="--rail-pad-top: 5rem;">
      <div class="sticky-stack" data-sticky="true">
        <AdSlot position="sidebar_sticky" />
      </div>
    </aside>
  </section>

  {/* ── Dashboard section ── */}
  <section class="home-rail-anchor">
    <div class="home-rail-main">
      <Dashboard items={dashboardItems} newsItems={newsItems} />
      <div class="home-ad">
        <AdSlot position="in_content" />
      </div>
    </div>

    <aside class="home-rail -right" style="--rail-pad-top: 3.75rem;">
      <div class="sticky-stack" data-sticky="true">
        <AdSlot position="sidebar_sticky" />
      </div>
    </aside>
  </section>

  {/* ── Games + Featured Reviews section (shared rail) ── */}
  <section class="home-rail-anchor">
    <div class="home-rail-main">
      {games.length > 0 && (
        <div class="home-page-body">
          <SectionDivider
            title="Game Gear Picks"
            subtitle="Reviewed and Pro-Tested"
            seeMoreHref="/games"
          />
          <GamesScroller games={games} pinnedSet={pinnedSet} badgesMap={badgesMap} />
        </div>
      )}

      <div class="home-page-body">
        <FeaturedScroller
          prefix="reviews"
          sectionTitle="Featured Reviews"
          sectionSubtitle="In-depth reviews of the latest gaming products"
          seeMoreHref="/reviews"
          allItems={reviewItems}
          itemsByCategory={reviewsByCategory}
          activeCategories={reviewActiveCats}
        />
      </div>

      <div class="home-ad">
        <AdSlot position="in_content" />
      </div>
    </div>

    <aside class="home-rail -right" style="--rail-pad-top: 4rem;">
      <div class="sticky-stack" data-sticky="true">
        <AdSlot position="sidebar_sticky" />
      </div>
    </aside>
  </section>

  {/* ── Highlighted Guides + Latest News section (shared rail) ── */}
  <section class="home-rail-anchor">
    <div class="home-rail-main">
      <div class="home-page-body">
        <FeaturedScroller
          prefix="guides"
          sectionTitle="Highlighted Guides"
          sectionSubtitle="Expert guides to elevate your game"
          seeMoreHref="/guides"
          allItems={guideItems}
          itemsByCategory={guidesByCategory}
          activeCategories={guideActiveCats}
        />
      </div>

      {latestNewsItems.length > 0 && (
        <div class="home-page-body home-news">
          <LatestNews items={latestNewsItems} />
        </div>
      )}
    </div>

    <aside class="home-rail -right" style="--rail-pad-top: 4rem;">
      <div class="sticky-stack" data-sticky="true">
        <AdSlot position="sidebar_sticky" />
      </div>
    </aside>
  </section>
</MainLayout>

<style is:global>
  /* ══════════════════════════════════════════════════════════════════════════
     HOME PAGE — Layout Grid & Section Ordering
     Port of view_index.css lines 22–162
     ══════════════════════════════════════════════════════════════════════════ */

  :root {
    --home-width: 1075px;
  }

  /* ── Full-bleed section wrapper with right rail ── */
  .home-rail-anchor {
    position: relative;
    display: grid;
    grid-template-columns:
      1fr minmax(0, var(--home-width)) 30px 300px 1fr;
    background: var(--home-rail-bg, transparent);
    padding-top: var(--home-rail-pad-top, 0);
    padding-bottom: var(--home-rail-pad-bottom, 0);
    isolation: isolate;
    padding-left: clamp(0px, -1650px + 103.125vw, 330px);
    padding-right: 2rem;
  }

  .home-rail-anchor:last-of-type {
    margin-bottom: 4rem;
  }

  .home-rail-main {
    grid-column: 2;
    min-width: 0;
  }

  .home-rail.-right {
    grid-column: 4;
    width: 300px;
    max-width: 300px;
    padding-top: var(--rail-pad-top, 0);
    padding-bottom: var(--rail-pad-bottom, 0);
  }

  /* Sticky opt-in */
  .home-rail.-right .sticky-stack {
    position: static;
  }

  .home-rail.-right .sticky-stack[data-sticky="true"] {
    position: sticky;
    top: var(--rail-sticky-top, calc(var(--top-bar-H, 64px) + 32px));
    will-change: top;
    isolation: isolate;
    z-index: 1000;
  }

  /* ── Hide rail on narrow viewports ── */
  @media (max-width: 1425px) {
    .home-rail-anchor {
      grid-template-columns: 1fr minmax(0, var(--home-width)) 1fr;
      padding-left: 0;
      padding-right: 0;
    }

    .home-rail.-right {
      display: none;
    }
  }

  /* Prevent horizontal scrollbars when rail shows */
  @media (min-width: 1351px) {
    body {
      overflow-x: clip;
    }
  }

  /* ── Home page body wrapper (port of view_index.css lines 115–127) ── */
  .home-page-body {
    width: calc(100% - 3rem);
    max-width: var(--home-width);
    margin: var(--section-gap) auto;
  }

  .home-page-body.home-news {
    margin: var(--section-gap) auto;
  }

  .home-page-body--first {
    margin-top: var(--section-gap);
  }

  /* ── Home top wrapper (dark hero area) ── */
  .home-top-wrapper {
    display: flex;
    flex-direction: column;
    background-color: var(--section-darkestdarker-background-color);
    padding-bottom: 4rem;
  }

  /* ── Desktop section ordering ── */
  /* Default order set in child components:
     .home-page-intro: order 1  (TopProducts)
     .home-title: order 2       (HomeHero title)
     .home-title-stats-container: order 3 (HomeHero buttons)
  */

  /* ── Mobile section reordering ── */
  @media (max-width: 900px) {
    .home-top-wrapper {
      padding-bottom: 0;
    }
  }

  /* ── Shared item-tag / item-date (port of site_shared.css lines 386–410) ── */
  .item-tag {
    font-family: var(--identity-font);
    font-weight: var(--font-weight7);
    font-size: var(--ft-14-12);
    text-transform: uppercase;
    display: inline-block;
  }

  .item-date {
    line-height: 1.5;
    font-size: var(--ft-12-11);
    font-family: var(--identity-font);
    font-weight: var(--font-weight6);
  }

  @media (max-width: 600px) {
    .item-tag {
      font-size: var(--fm-12-11);
    }
  }

  /* ── Inline ad spacing + centering (port of HBS widget_ads.css lines 19–23, 96–98) ── */
  .home-ad {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: var(--section-gap) 0;
    width: 100%;
  }
</style>
