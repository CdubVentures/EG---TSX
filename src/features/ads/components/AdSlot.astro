---
import { resolveAd, isAdsEnabled, parseLargestSize, parseSmallestSize } from '../resolve';
import {
  AD_LABEL,
  ADSENSE_CLIENT,
  SHOW_PRODUCTION_PLACEHOLDERS,
  LOAD_SAMPLE_ADS,
  SAMPLE_AD_MODE,
  SAMPLE_AD_NETWORK,
} from '../config';
import {
  getSampleAdCreative,
  getSampleAdCreativeSequence,
  type SampleAdCreative,
} from '../sample-images';
import {
  createSampleSlotPlan,
  getSampleRefreshPlan,
} from '../sample-slot-plan';
import {
  buildSampleOverlayPresentation,
  type SampleOverlayPresentation,
} from '../sample-ad-presentation';

interface Props {
  position: string;
  sticky?: boolean;
}

const { position, sticky = false } = Astro.props;

const placement = resolveAd(position);
const shouldRender = placement != null && placement.display;

const adsEnabled = shouldRender ? isAdsEnabled() : false;
const placementType = placement?.placementType ?? 'rail';
const isInline = placementType === 'inline';

const largestSize = shouldRender ? parseLargestSize(placement.sizes) : undefined;
const smallestSize = shouldRender ? parseSmallestSize(placement.sizes) : undefined;
const sizeStr = largestSize ? `${largestSize.width}x${largestSize.height}` : '';

const w = largestSize?.width ?? 300;
const h = largestSize?.height ?? 250;
const wSm = smallestSize?.width ?? w;
const hSm = smallestSize?.height ?? h;

// WHY: aspect-ratio for responsive inline ads — height scales proportionally with width.
// At 500px viewport: 970/250 → ~129px height. At 320px → ~82px. Industry standard.
const adRatio = `${w} / ${h}`;

const adClient = ADSENSE_CLIENT;
const ariaLabel = `Advertisement: ${position}`;

// WHY: sample ads override everything — render sample ad creatives when enabled.
const showSample = shouldRender && LOAD_SAMPLE_ADS;
const sampleCreativeSequence = showSample
  ? getSampleAdCreativeSequence(w, h, SAMPLE_AD_MODE, SAMPLE_AD_NETWORK, 7)
  : [];
const sampleSlotKey = `${position}|${w}x${h}|${placementType}|${sticky ? 'sticky' : 'static'}`;
const sampleSlotPlan = createSampleSlotPlan({
  slotKey: sampleSlotKey,
  creatives: sampleCreativeSequence,
});

interface SampleDisplayCreative extends SampleAdCreative {
  overlay?: SampleOverlayPresentation;
}

function isDefined<T>(value: T | undefined): value is T {
  return value !== undefined;
}

const decorateSampleCreative = (
  creative: ReturnType<typeof getSampleAdCreative>,
): SampleDisplayCreative | undefined => {
  if (!creative) return undefined;

  const overlay = buildSampleOverlayPresentation(creative);
  return overlay ? { ...creative, overlay } : { ...creative };
};
const sampleDisplaySequence = sampleSlotPlan.creatives
  .map((creative) => decorateSampleCreative(creative))
  .filter(isDefined);
const sampleFallbackCreative = showSample
  ? decorateSampleCreative(getSampleAdCreative(w, h, SAMPLE_AD_MODE, SAMPLE_AD_NETWORK))
  : undefined;
const sampleCreative = sampleDisplaySequence[0] ?? sampleFallbackCreative;
const sampleRefreshPlan = getSampleRefreshPlan({ placementType, sticky });
const sampleCreativeHasRotation = sampleDisplaySequence.length > 1 && sampleRefreshPlan.maxRefreshes > 0;
const sampleCreativeStartIndex = sampleCreativeHasRotation ? sampleSlotPlan.startIndex : 0;
const sampleCreativeRotationPayload = sampleDisplaySequence.length > 0
  ? JSON.stringify(sampleDisplaySequence)
  : '';
const sampleCreativeIntervalMinMs = sampleRefreshPlan.minMs;
const sampleCreativeIntervalMaxMs = sampleRefreshPlan.maxMs;
const sampleCreativeRefreshLimit = sampleRefreshPlan.maxRefreshes;
// WHY: production placeholders show HBS-style border + "Ad" circle when ads are off
const showProdPlaceholder = shouldRender && !adsEnabled && !LOAD_SAMPLE_ADS && SHOW_PRODUCTION_PLACEHOLDERS;
// Dev placeholder: dashed outline + position label (existing behavior)
const showDevPlaceholder = shouldRender && !adsEnabled && !LOAD_SAMPLE_ADS && !SHOW_PRODUCTION_PLACEHOLDERS;
---

{/* ── Sample Ad: SVG ad creative from config/media/sample-ads/ ── */}
{showSample && (
  <div
    class="ad-slot ad-slot--sample"
    data-position={position}
    data-provider={placement.provider}
    data-first-size={sizeStr}
    data-placement-type={placementType}
    data-sticky={sticky ? 'true' : undefined}
    data-sample-rotation={sampleCreativeHasRotation ? sampleCreativeRotationPayload : undefined}
    data-sample-start-index={sampleCreativeHasRotation ? sampleCreativeStartIndex : 0}
    data-sample-interval-min={sampleCreativeHasRotation ? sampleCreativeIntervalMinMs : undefined}
    data-sample-interval-max={sampleCreativeHasRotation ? sampleCreativeIntervalMaxMs : undefined}
    data-sample-refresh-limit={sampleCreativeHasRotation ? sampleCreativeRefreshLimit : undefined}
    data-sample-creative-source={sampleCreative?.source}
    style={`--ad-w: ${w}px; --ad-h: ${h}px; --ad-w-sm: ${wSm}px; --ad-h-sm: ${hSm}px; --ad-ratio: ${adRatio};`}
    role="complementary"
    aria-label={ariaLabel}
  >
    <div class="ad-slot__sample-creative-slot" aria-live="polite">
      {sampleCreative ? (
      sampleCreative.kind === 'video' ? (
        <div class="ad-slot__sample-creative ad-slot__sample-creative--video">
            <video
              class="ad-slot__sample-video"
              autoplay
              muted
              playsinline
              preload="metadata"
              aria-label={`${position} ${sampleCreative.networkLabel} sample ad`}
            >
            <source src={sampleCreative.source} type="video/mp4" />
          </video>
          {sampleCreative.overlay && (
            <div class={`ad-slot__sample-overlay ad-slot__sample-overlay--${sampleCreative.overlay.variant}`}>
              <div class="ad-slot__sample-overlay-top">
                <span class="ad-slot__sample-network">{sampleCreative.overlay.sponsorLabel}</span>
                <span class="ad-slot__sample-badge">{sampleCreative.overlay.badge}</span>
              </div>
              <div class="ad-slot__sample-overlay-body">
                <span class="ad-slot__sample-kicker">{sampleCreative.overlay.kicker}</span>
                <span class="ad-slot__sample-label">{sampleCreative.overlay.brand}</span>
                <span class="ad-slot__sample-size">{sampleCreative.overlay.headline}</span>
                <span class="ad-slot__sample-offer">{sampleCreative.overlay.offer}</span>
                <span class="ad-slot__sample-cta">{sampleCreative.overlay.cta}</span>
                {sampleCreative.overlay.disclaimer && (
                  <span class="ad-slot__sample-meta ad-slot__sample-meta--disclaimer">
                    {sampleCreative.overlay.disclaimer}
                  </span>
                )}
                {sampleCreative.overlay.duration && (
                  <span class="ad-slot__sample-meta ad-slot__sample-meta--duration">
                    {`Duration ${sampleCreative.overlay.duration}`}
                  </span>
                )}
              </div>
            </div>
          )}
        </div>
        ) : (
          <div class="ad-slot__sample-creative">
            <div class="ad-slot__sample-svg-wrap" set:html={sampleCreative.source} />
          </div>
        )
      ) : (
      <div class="ad-slot__sample-inner">
        <span class="ad-slot__sample-label">Sample Ad</span>
        <span class="ad-slot__sample-size">{sizeStr}</span>
        <span class="ad-slot__sample-position">{position}</span>
      </div>
    )}
    </div>
  </div>
)}

{showSample && sampleCreativeHasRotation && (
  <script type="module">
    (() => {
      const ROTATION_FALLBACK_MS = 60000;
      const HIDDEN_RETRY_MS = 5000;

      const SAMPLE_SLOT_RUNTIME_KEY = '__egSampleSlotRuntimeState';
      const parseDurationSeconds = (value) => {
        if (typeof value !== 'string') return null;

        const parts = value.split(':');
        if (parts.length !== 2) return null;

        const minutes = Number.parseInt(parts[0], 10);
        const seconds = Number.parseInt(parts[1], 10);

        if (!Number.isFinite(minutes) || !Number.isFinite(seconds)) return null;

        return minutes * 60 + seconds;
      };

      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
      const parseIntervalMs = (raw, fallbackMs = ROTATION_FALLBACK_MS) => {
        const parsed = Number.parseInt(String(raw || ''), 10);
        if (!Number.isFinite(parsed)) return fallbackMs;
        return parsed;
      };
      const parseRefreshLimit = (raw, fallback = 1) => {
        const parsed = Number.parseInt(String(raw || ''), 10);
        if (!Number.isFinite(parsed) || parsed < 0) return fallback;
        return parsed;
      };

      const safeDurationMs = (creative, fallbackMs, minMs, maxMs) => {
        const baseMs = clamp(fallbackMs, minMs, maxMs);
        if (creative?.kind !== 'video') {
          return baseMs;
        }

        const parsedSeconds = parseDurationSeconds(creative?.duration);
        if (!Number.isFinite(parsedSeconds) || parsedSeconds <= 0) {
          return baseMs;
        }

        return Math.max(baseMs, (parsedSeconds + 2) * 1000);
      };

      const jitterMs = (baseMs, minMs, maxMs) => {
        const jitter = Math.round((Math.random() - 0.5) * 2500);
        return clamp(baseMs + jitter, minMs, maxMs);
      };

      const getRuntimeState = () => {
        const current = window[SAMPLE_SLOT_RUNTIME_KEY];
        if (current && typeof current === 'object') {
          return current;
        }

        const state = {
          visibleSources: new Set(),
          slotSourceById: new Map(),
        };
        window[SAMPLE_SLOT_RUNTIME_KEY] = state;
        return state;
      };

      const buildOverlay = (creative) => {
        const presentation = creative?.overlay;
        if (!presentation) return null;

        const overlay = document.createElement('div');
        overlay.className = `ad-slot__sample-overlay ad-slot__sample-overlay--${presentation.variant || 'editorial'}`;

        const top = document.createElement('div');
        top.className = 'ad-slot__sample-overlay-top';

        const topLabels = [
          { className: 'ad-slot__sample-network', value: presentation.sponsorLabel },
          { className: 'ad-slot__sample-badge', value: presentation.badge },
        ];

        for (const item of topLabels) {
          const node = document.createElement('span');
          node.className = item.className;
          node.textContent = item.value || '';
          top.append(node);
        }

        const body = document.createElement('div');
        body.className = 'ad-slot__sample-overlay-body';

        const bodyLabels = [
          { className: 'ad-slot__sample-kicker', value: presentation.kicker },
          { className: 'ad-slot__sample-label', value: presentation.brand },
          { className: 'ad-slot__sample-size', value: presentation.headline },
          { className: 'ad-slot__sample-offer', value: presentation.offer },
          { className: 'ad-slot__sample-cta', value: presentation.cta },
        ];

        for (const item of bodyLabels) {
          const node = document.createElement('span');
          node.className = item.className;
          node.textContent = item.value || '';
          body.append(node);
        }

        if (presentation.disclaimer) {
          const disclaimer = document.createElement('span');
          disclaimer.className = 'ad-slot__sample-meta ad-slot__sample-meta--disclaimer';
          disclaimer.textContent = presentation.disclaimer;
          body.append(disclaimer);
        }

        if (presentation.duration) {
          const duration = document.createElement('span');
          duration.className = 'ad-slot__sample-meta ad-slot__sample-meta--duration';
          duration.textContent = `Duration ${presentation.duration}`;
          body.append(duration);
        }

        overlay.append(top);
        overlay.append(body);
        return overlay;
      };
      const pickCreativeForFrame = (payload, pointer, slot, runtimeState) => {
        const total = payload.length;
        const currentSource = slot.dataset.sampleCreativeSource || '';
        const reserved = new Set(runtimeState.visibleSources);
        reserved.delete(currentSource);

        for (let offset = 0; offset < total; offset += 1) {
          const candidateIndex = (pointer + offset) % total;
          const candidate = payload[candidateIndex];
          if (!candidate) continue;
          if (candidate.source === currentSource) continue;
          if (total > 1 && reserved.has(candidate.source)) continue;
          return { creative: candidate, index: candidateIndex };
        }

        const fallbackIndex = pointer % total;
        return { creative: payload[fallbackIndex], index: fallbackIndex };
      };

      const renderCreative = (slot, creative, index, runtimeState) => {
        const slotContainer = slot.querySelector('.ad-slot__sample-creative-slot');
        const positionName = slot.dataset.position ?? 'Advertisement';
        if (!slotContainer || !creative) return;

        const slotId = slot.dataset.sampleSlotId || `slot-${Math.random().toString(36).slice(2, 8)}`;
        slot.dataset.sampleSlotId = slotId;

        const previousSource = runtimeState.slotSourceById.get(slotId);
        if (previousSource && previousSource !== creative.source) {
          runtimeState.visibleSources.delete(previousSource);
        }

        slotContainer.innerHTML = '';

        const creativeWrapper = document.createElement('div');
        creativeWrapper.className = creative.kind === 'video'
          ? 'ad-slot__sample-creative ad-slot__sample-creative--video'
          : 'ad-slot__sample-creative';
        creativeWrapper.dataset.sampleCreativeFrame = String(index);

        if (creative.kind === 'video') {
          const video = document.createElement('video');
          video.className = 'ad-slot__sample-video';
          video.autoplay = true;
          video.muted = true;
          video.loop = false;
          video.playsInline = true;
          video.preload = 'metadata';
          video.setAttribute('aria-label', `${positionName} ${creative.networkLabel || ''} sample ad`);
          const source = document.createElement('source');
          source.src = creative.source;
          source.type = 'video/mp4';
          video.append(source);
          creativeWrapper.append(video);
        } else {
          const svgWrap = document.createElement('div');
          svgWrap.className = 'ad-slot__sample-svg-wrap';
          svgWrap.innerHTML = creative.source || '';
          creativeWrapper.append(svgWrap);
        }

        const overlay = buildOverlay(creative);
        if (overlay) {
          creativeWrapper.append(overlay);
        }
        slotContainer.append(creativeWrapper);

        runtimeState.slotSourceById.set(slotId, creative.source);
        runtimeState.visibleSources.add(creative.source);
        slot.dataset.sampleCreativeSource = creative.source;

        const activeVideo = creativeWrapper.querySelector('.ad-slot__sample-video');
        if (activeVideo) {
          activeVideo.load();
          activeVideo.play().catch(() => {});
        }
      };

      const setupSlot = (slot) => {
        const payloadText = slot.dataset.sampleRotation;
        if (!payloadText) return;

        let payload = [];
        try {
          payload = JSON.parse(payloadText);
        } catch (error) {
          payload = [];
        }

        if (!Array.isArray(payload) || payload.length < 2) return;

        const intervalMin = clamp(
          parseIntervalMs(slot.dataset.sampleIntervalMin, ROTATION_FALLBACK_MS),
          30000,
          150000
        );
        const intervalMax = clamp(
          parseIntervalMs(slot.dataset.sampleIntervalMax, ROTATION_FALLBACK_MS + 15000),
          30000,
          150000
        );
        const normalizedMin = Math.min(intervalMin, intervalMax);
        const normalizedMax = Math.max(intervalMin, intervalMax);
        const refreshLimit = parseRefreshLimit(slot.dataset.sampleRefreshLimit, 1);
        const runtimeState = getRuntimeState();

        let pointer = Number(slot.dataset.sampleStartIndex) || 0;
        if (!Number.isFinite(pointer)) {
          pointer = 0;
        }

        const total = payload.length;
        pointer = ((pointer % total) + total) % total;
        slot.dataset.sampleRotationIndex = String(pointer);

        const slotId = slot.dataset.sampleSlotId || `slot-${Math.random().toString(36).slice(2, 8)}`;
        slot.dataset.sampleSlotId = slotId;

        let isViewable = !('IntersectionObserver' in window);
        let refreshCount = 0;
        const currentSource = slot.dataset.sampleCreativeSource || '';
        const currentIndex = currentSource
          ? payload.findIndex((creative) => creative?.source === currentSource)
          : -1;

        if (currentSource) {
          runtimeState.slotSourceById.set(slotId, currentSource);
          runtimeState.visibleSources.add(currentSource);
        }

        if (currentIndex >= 0) {
          pointer = (currentIndex + 1) % total;
          slot.dataset.sampleRotationIndex = String(pointer);
        }

        if ('IntersectionObserver' in window) {
          const observer = new window.IntersectionObserver((entries) => {
            const nextEntry = entries[0];
            if (!nextEntry) return;
            isViewable = nextEntry.isIntersecting && nextEntry.intersectionRatio >= 0.5;
          }, { threshold: [0, 0.5, 1] });
          observer.observe(slot);
        }

        const scheduleNext = (creative) => {
          if (refreshCount >= refreshLimit) return;

          const dwellMs = safeDurationMs(
            creative,
            ROTATION_FALLBACK_MS,
            normalizedMin,
            normalizedMax
          );
          window.setTimeout(tick, jitterMs(dwellMs, normalizedMin, normalizedMax));
        };

        const tick = () => {
          if (document.visibilityState === 'hidden' || !isViewable) {
            window.setTimeout(tick, HIDDEN_RETRY_MS);
            return;
          }

          if (refreshCount >= refreshLimit) {
            return;
          }

          const selection = pickCreativeForFrame(payload, pointer, slot, runtimeState);
          const selectedIndex = selection.index;
          const creative = selection.creative;
          const next = (selectedIndex + 1) % total;
          renderCreative(slot, creative, selectedIndex, runtimeState);
          refreshCount += 1;
          pointer = next;
          scheduleNext(creative);
        };

        const initialCreative = currentIndex >= 0 ? payload[currentIndex] : payload[pointer];
        if (initialCreative) {
          scheduleNext(initialCreative);
        } else {
          tick();
        }
      };
      const currentSlot = document.currentScript?.previousElementSibling;
      if (currentSlot && currentSlot instanceof HTMLElement) {
        setupSlot(currentSlot);
      }
    })();
  </script>
)}

{/* ── Production Placeholder: HBS-style top/bottom border + "Ad" circle ── */}
{showProdPlaceholder && (
  <div
    class="ad-slot ad-slot--production"
    data-position={position}
    data-provider={placement.provider}
    data-first-size={sizeStr}
    data-placement-type={placementType}
    data-sticky={sticky ? 'true' : undefined}
    style={`--ad-w: ${w}px; --ad-h: ${h}px; --ad-w-sm: ${wSm}px; --ad-h-sm: ${hSm}px; --ad-ratio: ${adRatio};`}
    role="complementary"
    aria-label={ariaLabel}
  >
    <span class="ad-label">{AD_LABEL}</span>
  </div>
)}

{/* ── Dev Placeholder: dashed outline + position name ── */}
{showDevPlaceholder && (
  <div
    class="ad-slot"
    data-position={position}
    data-provider={placement.provider}
    data-first-size={sizeStr}
    data-placeholder="true"
    data-placement-type={placementType}
    data-sticky={sticky ? 'true' : undefined}
    style={`--ad-w: ${w}px; --ad-h: ${h}px; --ad-w-sm: ${wSm}px; --ad-h-sm: ${hSm}px; --ad-ratio: ${adRatio};`}
    role="complementary"
    aria-label={ariaLabel}
  />
)}

{shouldRender && adsEnabled && !LOAD_SAMPLE_ADS && placement.provider === 'adsense' && !isInline && (
  <div
    class="ad-slot"
    data-position={position}
    data-provider={placement.provider}
    data-first-size={sizeStr}
    data-placement-type={placementType}
    data-fill="pending"
    data-sticky={sticky ? 'true' : undefined}
    style={`--ad-w: ${w}px; --ad-h: ${h}px;`}
    role="complementary"
    aria-label={ariaLabel}
  >
    <span class="ad-label">{AD_LABEL}</span>
    <ins
      class="adsbygoogle"
      style={`display:inline-block; width:${w}px; height:${h}px;`}
      data-ad-client={adClient}
      data-ad-slot={placement.adSlot}
    />
  </div>
)}

{shouldRender && adsEnabled && !LOAD_SAMPLE_ADS && placement.provider === 'adsense' && isInline && (
  <div
    class="ad-slot"
    data-position={position}
    data-provider={placement.provider}
    data-first-size={sizeStr}
    data-placement-type={placementType}
    data-fill="pending"
    data-sticky={sticky ? 'true' : undefined}
    style={`--ad-w: ${w}px; --ad-h: ${h}px; --ad-w-sm: ${wSm}px; --ad-h-sm: ${hSm}px; --ad-ratio: ${adRatio};`}
    role="complementary"
    aria-label={ariaLabel}
  >
    <span class="ad-label">{AD_LABEL}</span>
    <ins
      class="adsbygoogle"
      style="display:block;"
      data-ad-client={adClient}
      data-ad-slot={placement.adSlot}
      data-ad-format="fluid"
      data-ad-layout="in-article"
    />
  </div>
)}

{/* Direct sponsor — rendered by bootstrap.ts at runtime */}
{shouldRender && adsEnabled && !LOAD_SAMPLE_ADS && placement.provider !== 'adsense' && (
  <div
    class="ad-slot"
    data-position={position}
    data-provider={placement.provider}
    data-first-size={sizeStr}
    data-placement-type={placementType}
    data-fill="pending"
    data-sticky={sticky ? 'true' : undefined}
    style={`--ad-w: ${w}px; --ad-h: ${h}px;`}
    role="complementary"
    aria-label={ariaLabel}
  >
    <span class="ad-label">{AD_LABEL}</span>
  </div>
)}

<style is:global>
  /* ═══════════════════════════════════════════════════════════════════════════
     AD SLOT — Base + Placeholder + Live styling
     Ported from EG-HBS widget_ads.css (lines 131–238)
     Dark theme values are LOCKED — they match HBS exactly.
     ═══════════════════════════════════════════════════════════════════════════ */

  /* ── Base slot reset ── */
  .ad-slot {
    position: relative;
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    box-sizing: border-box;
    background: transparent;
    font-size: 0;
  }

  /* ── CLS reservation (all live slots) ── */
  .ad-slot:not([data-placeholder="true"]):not(.ad-slot--sample) {
    width: var(--ad-w, 300px);
    max-width: 100%;
    min-height: var(--ad-h, 250px);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     DEV PLACEHOLDER — dashed outline + position label (default when ads off)
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-slot[data-placeholder="true"] {
    display: none;
    visibility: hidden;
    opacity: 0;
    transition: opacity 120ms ease-out;
    position: relative;
    width: var(--ad-w, 300px);
    max-width: var(--ad-w, 300px);
    min-height: var(--ad-h, 250px);
    outline: 2px dashed var(--card-color, var(--site-color, #394cc8));
    padding: 24px 12px 30px;
    background:
      repeating-linear-gradient(
        135deg,
        color-mix(in oklab, #fff 2%, transparent) 0 12px,
        color-mix(in oklab, #fff 5%, transparent) 12px 24px
      );
  }

  /* Reveal when size is known */
  .ad-slot[data-placeholder="true"][data-first-size] {
    display: block;
    visibility: visible;
    opacity: 1;
  }

  /* ── Label: position + provider (centered) ── */
  .ad-slot[data-placeholder="true"]::before {
    content: attr(data-position) " \2022  " attr(data-provider);
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 14px;
    font: 800 clamp(12px, 11px + .25vw, 14px)/1 var(--identity-font, system-ui);
    letter-spacing: .09em;
    color: #dbe2ea;
    text-transform: uppercase;
    pointer-events: none;
  }

  /* ── Size chip (bottom-center) ── */
  .ad-slot[data-placeholder="true"]::after {
    content: attr(data-first-size);
    position: absolute;
    left: 50%;
    bottom: 8px;
    transform: translateX(-50%);
    font: 700 11px/1 var(--identity-font, system-ui);
    letter-spacing: .06em;
    color: #b8c1cc;
    pointer-events: none;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     PRODUCTION PLACEHOLDER — HBS-style top/bottom border + "Ad" circle
     Matches EG-HBS widget_ads.css lines 303–349 exactly.
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-slot--production {
    width: var(--ad-w, 300px);
    max-width: 100%;
    min-height: var(--ad-h, 250px);
    background: transparent;
    border-top: 1px solid var(--section-dusker-background-color, #2a2d2d);
    border-bottom: 1px solid var(--section-dusker-background-color, #2a2d2d);
    border-left: 0;
    border-right: 0;
    border-radius: 0;
    outline: 0;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     AD LABEL — "Ad" badge (HBS pattern: 36px circle behind creative)
     Color values match HBS widget_ads.css lines 330–349 exactly.
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-label {
    position: absolute;
    /* WHY: inset:0 + margin:auto is more robust than top/left/transform —
       guaranteed dead-center regardless of how parent height is resolved
       (min-height, aspect-ratio, or flow content). */
    inset: 0;
    margin: auto;
    z-index: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    /* WHY: HBS --section-dusker-background-color = #2a2d2d */
    border: 2px solid var(--section-dusker-background-color, #2a2d2d);
    font: 800 13px/1 var(--identity-font, system-ui);
    letter-spacing: .02em;
    /* WHY: HBS uses rgba white (.65) for text on dark backgrounds.
       Bridge var --grey-color-3 is muted in all themes:
       gaming=#b0b0b0, default=#718096, workstation=#a1a1aa, review=#a8a29e */
    color: var(--grey-color-3, rgba(255, 255, 255, .65));
    pointer-events: none;
    opacity: .65;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     SAMPLE ADS — SVG ad creatives from config/media/sample-ads/
     Falls back to colored dummy rectangle if no SVG matches the display size.
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-slot--sample {
    width: var(--ad-w, 300px);
