    );
  }

  .ad-slot__sample-overlay--fashion .ad-slot__sample-overlay-body {
    max-width: min(74%, 28rem);
  }

  .ad-slot__sample-overlay--fashion .ad-slot__sample-badge {
    background: rgba(255, 255, 255, .1);
  }

  .ad-slot__sample-overlay--auto::before {
    background: linear-gradient(
      to top,
      rgba(3, 6, 10, .9) 0%,
      rgba(3, 6, 10, .28) 34%,
