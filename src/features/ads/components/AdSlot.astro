  .ad-slot__sample-creative--video {
    position: relative;
    background: #000;
    line-height: 1;
    overflow: hidden;
  }

  .ad-slot__sample-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    background: #000;
    pointer-events: none;
