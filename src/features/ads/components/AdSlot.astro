    overflow: hidden;
  }

  /* SVG creative — fill the slot exactly */
  /* WHY background: when max-width:100% shrinks the slot narrower than the
     SVG viewBox, preserveAspectRatio creates empty space above/below.
     Dark bg matches the SVG backgrounds so the gap is invisible. */
  .ad-slot__sample-creative {
    width: 100%;
    height: var(--ad-h, 250px);
    line-height: 0;
    font-size: 0;
    background: #0d1117;
    position: relative;
    overflow: hidden;
