  .ad-slot[data-first-size="320x50"] .ad-slot__sample-overlay,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-overlay,
  .ad-slot[data-first-size="728x90"] .ad-slot__sample-overlay {
    padding: 8px;
    gap: 6px;
  }

  .ad-slot[data-first-size="320x50"] .ad-slot__sample-overlay-body,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-overlay-body,
  .ad-slot[data-first-size="728x90"] .ad-slot__sample-overlay-body {
    gap: 4px;
    max-width: min(64%, 20rem);
  }

  .ad-slot[data-first-size="320x50"] .ad-slot__sample-kicker,
  .ad-slot[data-first-size="320x50"] .ad-slot__sample-offer,
  .ad-slot[data-first-size="320x50"] .ad-slot__sample-meta--disclaimer,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-meta--disclaimer,
  .ad-slot[data-first-size="728x90"] .ad-slot__sample-meta--disclaimer {
    display: none;
  }

  .ad-slot[data-first-size="320x50"] .ad-slot__sample-label,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-label,
  .ad-slot[data-first-size="728x90"] .ad-slot__sample-label {
    font-size: 12px;
  }

  .ad-slot[data-first-size="320x50"] .ad-slot__sample-size,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-size,
  .ad-slot[data-first-size="728x90"] .ad-slot__sample-size {
    font-size: 10px;
    line-height: 1.15;
  }

  .ad-slot[data-first-size="320x50"] .ad-slot__sample-network,
  .ad-slot[data-first-size="320x50"] .ad-slot__sample-badge,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-network,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-badge,
