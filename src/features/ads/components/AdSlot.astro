    padding: 4px 8px;
    font-size: 9px;
  }

  .ad-slot[data-first-size="320x50"] .ad-slot__sample-cta,
  .ad-slot[data-first-size="320x100"] .ad-slot__sample-cta,
  .ad-slot[data-first-size="728x90"] .ad-slot__sample-cta {
    min-height: 24px;
    padding: 5px 10px;
    font-size: 9px;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     ANTI-FLICKER — hide live slot content until fill status is known
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-slot[data-fill="pending"] ins,
  .ad-slot[data-fill="pending"] iframe {
    visibility: hidden;
    opacity: 0;
  }

  .ad-slot[data-fill="filled"] ins,
  .ad-slot[data-fill="filled"] iframe {
    visibility: visible;
    opacity: 1;
    transition: opacity 120ms ease-out;
  }

  /* Hide "Ad" badge once creative fills */
  .ad-slot[data-fill="filled"] .ad-label {
    display: none;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     UNFILLED COLLAPSE
     Rail: hide entirely. Inline: zero-height collapse.
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-slot[data-fill="unfilled"][data-placement-type="rail"] {
    display: none !important;
  }

  .ad-slot[data-fill="unfilled"][data-placement-type="inline"] {
    min-height: 0;
    height: 0;
    overflow: hidden;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     INLINE RESPONSIVE — fluid width + aspect-ratio scaling (industry standard)
     Inline ads scale proportionally with container width:
       Desktop 1000px → 250px tall   (970/250 ratio)
       Tablet   768px → 198px tall
       Mobile   500px → 129px tall
       Small    320px →  82px tall
     No fixed heights eating half the screen on mobile.
     ═══════════════════════════════════════════════════════════════════════════ */

  /* All inline containers: fluid width + proportional height */
  .ad-slot[data-placement-type="inline"],
  .ad-slot[data-placement-type="inline"]:not([data-placeholder="true"]):not(.ad-slot--sample) {
    width: 100%;
    min-height: 50px;
    aspect-ratio: var(--ad-ratio, auto);
  }

  /* Inline sample ads: fluid + aspect-ratio */
  .ad-slot--sample[data-placement-type="inline"] {
    width: 100%;
    min-height: 50px;
    aspect-ratio: var(--ad-ratio, auto);
  }

  /* Inline sample creative: scale with container, not fixed height */
  .ad-slot--sample[data-placement-type="inline"] .ad-slot__sample-creative {
    height: auto;
    aspect-ratio: var(--ad-ratio, auto);
  }

  .ad-slot--sample[data-placement-type="inline"] .ad-slot__sample-creative--video {
    height: auto;
    aspect-ratio: var(--ad-ratio, auto);
  }

  /* Inline sample fallback rectangle: scale with container */
  .ad-slot--sample[data-placement-type="inline"] .ad-slot__sample-inner {
    min-height: 50px;
    aspect-ratio: var(--ad-ratio, auto);
  }

  /* Inline production placeholder: fluid + aspect-ratio */
  .ad-slot--production[data-placement-type="inline"] {
    width: 100%;
    min-height: 50px;
    aspect-ratio: var(--ad-ratio, auto);
  }

  /* Inline dev placeholder: fluid + aspect-ratio */
  .ad-slot[data-placeholder="true"][data-placement-type="inline"] {
    width: 100%;
    max-width: 100%;
    min-height: 50px;
    aspect-ratio: var(--ad-ratio, auto);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     INLINE OVERFLOW CLAMP — prevent AdSense from exceeding container width
     ═══════════════════════════════════════════════════════════════════════════ */
  .ad-slot[data-placement-type="inline"] ins,
  .ad-slot[data-placement-type="inline"] div[id^="aswift_"],
  .ad-slot[data-placement-type="inline"] iframe {
    max-width: 100% !important;
  }

  /* WHY: Keep aspect-ratio reservation on filled inline ads to prevent CLS.
     AdSense can serve any size from the slot's size list (e.g. 728x90 in a
     970x250 slot). Clearing aspect-ratio + min-height would let the
     container collapse to 50px, causing content below to jump upward.
     Instead we keep the aspect-ratio floor — shorter ads get whitespace
     below, taller ads grow via overflow-y: visible. This is the
     industry-standard trade-off for zero layout shift (Raptive, Mediavine
     both do this). */
  .ad-slot[data-fill="filled"][data-placement-type="inline"] {
    overflow-y: visible;
  }
</style>
