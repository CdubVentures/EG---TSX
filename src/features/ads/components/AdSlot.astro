    );
  }

  .ad-slot__sample-overlay--auto .ad-slot__sample-overlay-body {
    align-self: flex-end;
    align-items: flex-end;
    max-width: min(72%, 28rem);
    text-align: right;
  }

  .ad-slot__sample-overlay--auto .ad-slot__sample-cta {
    align-self: flex-end;
  }

  .ad-slot__sample-overlay--software .ad-slot__sample-overlay-body {
