---
/**
 * HomeHero.astro — h1, subtitle with product count, 6 stat buttons.
 * Port of HBS .home-title + .home-title-stats-container (lines 28–291).
 */
interface Props {
  productCount: number;
}

const { productCount } = Astro.props;
---

{/* ── Hero Title ── */}
<div class="home-title">
  <h1>
    <span class="home-title-main-text">The Smarter Way to Compare PC Gear</span>
  </h1>
  <div class="home-title-sub-texts">
    <h2>
      <a href="/hubs" class="home-title-h2-link">
        Compare
        <span class="home-hero-countWrap">
          <span class="home-hero-count" data-home-count={productCount}>{productCount}</span>
        </span>
        products—verified specs, reviews, and guides that actually help
      </a>
    </h2>
  </div>
</div>

{/* ── Stat Buttons ── */}
<div class="home-title-stats-container">

  {/* Shared gradient defs — rendered once, referenced by all buttons */}
  {/* WHY: Gradient defs for non-Hubs button hover. Hubs gradient is inside its own SVG (matching HBS). */}
