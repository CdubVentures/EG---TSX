<style>
  /* ── Hero Title ── */
  .home-title {
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    width: calc(100% - 3rem);
    max-width: var(--home-width);
    margin: 5rem auto 0 auto;
    order: 2;
  }

  .home-title h1 {
    font-size: var(--ft-55-40);
    font-weight: 900;
    font-family: var(--identity-font);
    color: var(--white-color-1);
    letter-spacing: -0.5px;
    line-height: 1.2;
    padding: 0;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    position: relative;
    white-space: normal;
    overflow-wrap: break-word;
  }

  .home-title-sub-texts {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 1.5rem;
    letter-spacing: -0.5px;
    row-gap: 2em;
  }

  .home-title-sub-texts h2 {
    font-size: var(--ft-32-24);
    text-shadow: none;
    text-transform: capitalize;
    margin-right: 1rem;
    flex: 0 1 auto;
  }

  .home-title h2 {
    font-weight: 700;
    font-family: var(--identity-font);
    color: var(--grey-color-3);
    letter-spacing: -0.5px;
    line-height: 1.2;
    padding: 0;
    margin: 0;
  }

  /* ── Count badge with gradient text ── */
  .home-hero-countWrap {
    position: relative;
    display: inline-block;
    padding: 0 0.12em;
    margin: 0 0.06em;
    border-radius: 4px;
  }

  .home-hero-count {
    display: inline-block;
    position: relative;
    font-variant-numeric: tabular-nums;
    color: var(--white-color-1);
    will-change: transform, opacity, filter;
  }

  @supports ((-webkit-background-clip: text) or (background-clip: text)) {
    .home-hero-count {
      background: var(--site-gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
  }

  .home-hero-count.is-animating {
    animation: homeHeroCountIn 720ms cubic-bezier(0.18, 0.9, 0.22, 1) both;
  }

  .home-hero-countWrap.is-shine::after {
    content: "";
    position: absolute;
    inset: -20% -40%;
    pointer-events: none;
    border-radius: inherit;
    background: linear-gradient(110deg,
      transparent 0%,
      rgba(255, 255, 255, 0) 42%,
      rgba(255, 255, 255, 0.18) 50%,
      rgba(255, 255, 255, 0) 58%,
      transparent 100%);
    transform: translateX(-140%) rotate(10deg);
    opacity: 0;
    animation: homeHeroCountShine 1100ms cubic-bezier(0.2, 0.85, 0.2, 1) both;
  }

  @keyframes homeHeroCountIn {
    0%   { opacity: 0; transform: translateY(6px); filter: blur(10px); }
    70%  { opacity: 1; transform: translateY(-1px); filter: blur(0px); }
    100% { opacity: 1; transform: translateY(0px); filter: none; }
  }

  @keyframes homeHeroCountShine {
    0%   { opacity: 0; transform: translateX(-140%) rotate(10deg); }
    20%  { opacity: 0.9; }
    70%  { opacity: 0.18; }
    100% { opacity: 0; transform: translateX(140%) rotate(10deg); }
  }

  /* ── h2 link hover underline ── */
  .home-title-h2-link {
    position: relative;
    display: inline;
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(var(--site-start-color), var(--site-end-color));
    background-repeat: no-repeat;
    background-size: 0% 2px;
    background-position: 0 100%;
  }

  .home-title-h2-link:hover,
  .home-title-h2-link:focus-visible {
    background-size: 100% 2px;
    filter: brightness(1.06);
  }

  .home-title-h2-link:focus-visible {
