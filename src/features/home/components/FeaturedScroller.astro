---
/**
 * FeaturedScroller.astro — Large featured tile + horizontal card scroller with category tabs.
 * Reusable for "Featured Reviews" and "Highlighted Guides" sections.
 * Port of HBS scrollerFeatured.handlebars + scroller_featured.css + scrollerFeatured.js.
 * Dark theme values are LOCKED — match HBS exactly.
 */
import FeaturedPanel from './FeaturedPanel.astro';
import { getCategoryColors } from '@core/categories';
import type { FeaturedItem } from '../featured-scroller-utils';

interface Props {
  prefix: string;
  sectionTitle: string;
  sectionSubtitle: string;
  seeMoreHref: string;
  allItems: FeaturedItem[];
  itemsByCategory: Record<string, FeaturedItem[]>;
  activeCategories: string[];
}

const {
  prefix,
  sectionTitle,
  sectionSubtitle,
  seeMoreHref,
  allItems,
  itemsByCategory,
  activeCategories,
} = Astro.props;

// WHY: Empty items → render nothing (contract invariant)
if (allItems.length === 0) return;
---

<div class="feature-board-section-container" data-prefix={prefix}>
  <div class="section-divider">
    <div class="section-divider-heading">
      <h2 class="section-divider-title">{sectionTitle}</h2>
      <span class="section-divider-subtitle">{sectionSubtitle}</span>
    </div>
    <div class="section-divider-actions" aria-label={sectionTitle}>
      <button type="button" class="section-divider-link active"
         id={`${prefix}-tab-all`}
         aria-pressed="true" aria-controls={`${prefix}-all`}
         data-filter="all" data-category="all">
        All
      </button>
      {activeCategories.map(cat => {
        const colors = getCategoryColors(cat);
        return (
          <button type="button" class="section-divider-link"
             id={`${prefix}-tab-${cat}`}
             aria-pressed="false" aria-controls={`${prefix}-${cat}`}
             data-filter={cat} data-category={cat}
             data-product-color="true"
             style={`--card-color: ${colors.base}; --card-hover: ${colors.hover};`}>
            {itemsByCategory[cat]?.[0]?.categoryLabel ?? cat}
          </button>
        );
      })}
      <a href={seeMoreHref} class="section-divider-link"
         aria-label={`See more ${sectionTitle}`}
         data-filter="see-more" data-category="see-more">
        See More
      </a>
    </div>
  </div>

  <section class="feature-board-menu-section">
    {/* ── "All" tab panel (visible by default) ── */}
    <FeaturedPanel panelId={`${prefix}-all`} prefix={prefix} items={allItems} visible={true} />

    {/* ── Per-category tab panels (hidden by default) ── */}
    {activeCategories.map(cat => (
      <FeaturedPanel panelId={`${prefix}-${cat}`} prefix={prefix} items={itemsByCategory[cat] ?? []} visible={false} />
    ))}
  </section>
</div>

<script>
  // ─── Featured Scroller — Tab Switching + Slider Behavior ──────────────────
  // Port of HBS scrollerFeatured.js + site_utility.js initializeSlider.
  // Each container scoped by data-prefix — no conflicts between instances.
  // Slider logic delegated to shared initSlider; tab switching is unique here.

  import { initSlider } from '@shared/ui/slider-init';

  // WHY WeakMap: stores cleanup functions per scroller element to prevent
  // listener accumulation on tab re-init (Refactor 3 fix).
  const sliderCleanups = new WeakMap<HTMLElement, () => void>();

  function initScrollerWithCleanup(scrollerEl: HTMLElement) {
    const slider = scrollerEl.querySelector('.feature-board-slider') as HTMLElement | null;
    const leftArrow = scrollerEl.querySelector('.feature-board-left-arrow') as HTMLElement | null;
    const rightArrow = scrollerEl.querySelector('.feature-board-right-arrow') as HTMLElement | null;

    if (!slider) return;

    // Clean up old listeners if this scroller was already initialized
    const oldCleanup = sliderCleanups.get(scrollerEl);
    if (oldCleanup) oldCleanup();

    const cleanup = initSlider({ slider, leftArrow, rightArrow });
    sliderCleanups.set(scrollerEl, cleanup);
  }

  function initFeaturedScrollers() {
    const containers = document.querySelectorAll('.feature-board-section-container');

    containers.forEach(container => {
      const prefix = container.getAttribute('data-prefix');
      if (!prefix) return;

      // ── Tab switching ──────────────────────────────────────────────────────
      const filterButtons = container.querySelectorAll(
        '.section-divider-actions .section-divider-link[data-filter]:not([data-filter="see-more"])'
      ) as NodeListOf<HTMLButtonElement>;

      filterButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();

          filterButtons.forEach(b => {
            b.classList.remove('active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');

          // WHY .${prefix}-section: [id^="${prefix}-"] also matches tab buttons
          // (e.g. reviews-tab-all) which hides the buttons themselves — HBS tabs
          // have no IDs so this collision didn't exist there.
          const sections = container.querySelectorAll(`.${prefix}-section`) as NodeListOf<HTMLElement>;
          sections.forEach(section => section.style.display = 'none');

          const filter = btn.getAttribute('data-filter');
          const targetId = `${prefix}-${filter}`;
          const targetSection = document.getElementById(targetId);
          if (targetSection) {
            targetSection.style.display = 'block';
            // Reinitialize sliders in the newly-visible section
            targetSection.querySelectorAll('.feature-board-scroller').forEach(scroller => {
              initScrollerWithCleanup(scroller as HTMLElement);
            });
          }
        });
      });

      // ── Initialize sliders for visible sections ────────────────────────────
      const sections = container.querySelectorAll(`.${prefix}-section`) as NodeListOf<HTMLElement>;
      sections.forEach(section => {
        if (getComputedStyle(section).display !== 'none') {
          section.querySelectorAll('.feature-board-scroller').forEach(scroller => {
            initScrollerWithCleanup(scroller as HTMLElement);
          });
        }
      });
    });
  }

  // WHY: Astro hoists <script> as deferred ES modules — DOMContentLoaded
  // may have already fired. Check readyState first.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFeaturedScrollers);
  } else {
    initFeaturedScrollers();
  }
</script>

<style is:global>
  /* ═══════════════════════════════════════════════════════════════════════════
     FEATURED SCROLLER — Port of scroller_featured.css + site_arrows.css
     Dark theme values are LOCKED — match HBS exactly.
     ═══════════════════════════════════════════════════════════════════════════ */

  /* ── Large Tile ── */
  /* WHY --color-text-on-accent: desktop layout overlays content on dark rgba bg.
     Bridge vars flip to dark text in light themes = unreadable. ≤825px reverts
     to bridge vars when the layout becomes a themed card. */
  .feature-board-large-tile {
    position: relative;
    max-height: clamp(325px, 218.3333px + 26.6667vw, 525px);
    height: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text-on-accent);
    background: var(--section-dark-background-color);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease;
  }

  .feature-board-large-tile:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .feature-board-large-tile-image {
    width: 100%;
    min-height: clamp(325px, 218.3333px + 26.6667vw, 525px);
    object-fit: cover;
    object-position: center;
    flex-shrink: 0;
  }

  .feature-board-large-tile-content {
    position: absolute;
    bottom: 0;
    left: 0;
    font-family: var(--identity-font);
    background-color: rgba(08, 08, 08, 0.65);
    padding: 1.5rem;
    color: var(--color-text-on-accent);
    text-align: left;
    width: 65%;
    max-width: 100%;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-radius: 0 8px 8px 0;
  }

  .feature-board-content-top {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-board-large-tile-title {
    font-size: var(--ft-36-22);
    line-height: 1.25;
    letter-spacing: -0.5px;
    margin: 0;
    font-weight: bold;
    color: var(--color-text-on-accent);
  }

  .feature-board-large-tile-description {
    margin: 0;
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-2);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    display: none;
  }

  .feature-board-large-tile-date {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
    display: none;
  }

  .feature-board-large-tile:hover .feature-board-large-tile-title {
    text-decoration: underline;
    text-decoration-color: var(--color-text-on-accent);
    text-decoration-thickness: clamp(1.25px, 0.45px + 0.2vw, 2.75px);
    text-underline-offset: clamp(1.25px, 1.1167px + 0.0333vw, 1.5px);
  }

  @media (max-width: 825px) {
    /* WHY: ≤825px switches from cinematic overlay to themed card layout.
       Text reverts to bridge vars that switch with theme. */
    .feature-board-large-tile {
      max-height: unset;
      color: var(--white-color-1);
    }

    .feature-board-large-tile-image {
      aspect-ratio: 16 / 9;
      min-height: unset;
    }

    .feature-board-large-tile-content {
      position: relative;
      width: 100%;
      flex: 1;
      padding: 1.25rem 1.65rem;
      box-sizing: border-box;
      background: transparent;
      color: var(--white-color-1);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 0.75rem;
      box-shadow: none;
    }

    .feature-board-large-tile-title {
      color: var(--white-black-color-1);
    }

    .feature-board-large-tile:hover .feature-board-large-tile-title {
      text-decoration-color: var(--white-black-color-1);
    }

    .feature-board-large-tile-date {
      display: block;
    }
  }

  @media (max-width: 600px) {
    .feature-board-large-tile-title {
      font-size: var(--fm-22-21);
    }
  }

  /* ── Scroller Container ── */
  .feature-board-scroller-container {
    position: relative;
    padding: 0;
    display: flex;
    justify-content: center;
    max-width: 100%;
    box-sizing: border-box;
    z-index: 3;
    margin-top: 1.5rem;
  }

  .feature-board-scroller {
    position: relative;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: auto;
    box-sizing: border-box;
  }

  .feature-board-slider {
    display: flex;
    align-items: stretch;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    width: 100%;
    gap: 1.25rem;
    user-select: none;
    padding-bottom: 1rem;
    margin-bottom: -1rem;
  }

  /* ── Scroller Cards ── */
  .feature-board-item.feature-board-row1-item {
    display: flex;
    flex-direction: column;
    background: var(--section-dark-background-color);
    overflow: hidden;
    position: relative;
    border-radius: 6px;
    flex-shrink: 0;
    text-decoration: none;
    color: var(--white-color-1);
    width: clamp(200px, 25vw, 275px);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease;
  }

  .feature-board-item.feature-board-row1-item:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .feature-board-grid-image.feature-board-row1-image {
    width: 100%;
    aspect-ratio: 9 / 6.5;
    height: auto;
    object-fit: cover;
    object-position: center;
  }

  .feature-board-item-content.feature-board-row1-content {
    flex: 1;
    padding: 1.35rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .feature-board-row1-title {
    font-size: var(--ft-18-16);
    font-weight: var(--font-weight7);
    margin: 0;
    line-height: 1.35;
    letter-spacing: -0.5px;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--white-color-1);
    font-family: var(--identity-font);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .feature-board-row1-description {
    display: none;
  }

  .feature-board-row1-date {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
  }

  .feature-board-item.feature-board-row1-item:hover .feature-board-row1-title {
    text-decoration: underline;
    text-decoration-color: var(--white-black-color-1);
    text-decoration-thickness: 1.25px;
    text-underline-offset: 1.25px;
  }

  @media (max-width: 825px) {
    .feature-board-row1-title {
      line-height: 1.3;
    }
  }

  @media (max-width: 600px) {
    .feature-board-row1-title {
      font-size: var(--fm-16-15);
    }
  }

  /* ── Arrow positioning (base styles in global.css .scroller-arrow) ── */
  .feature-board-left-arrow {
    left: 0.45rem;
  }

  .feature-board-right-arrow {
    right: 0.4rem;
  }

  /* ── EditorsBadge positioning inside featured cards ── */
  .feature-board-badge-wrap {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
  }

  /* WHY: HBS scroller_featured.css sized large tile and scroller cards differently.
     Large tile is a full-width cinematic image → badge needs to be larger.
     Scroller cards are narrow thumbnails → badge needs to be smaller. */
  .feature-board-large-tile .feature-board-badge-wrap {
    font-size: var(--font-size-22px);
  }

  .feature-board-item .feature-board-badge-wrap {
    font-size: var(--font-size-15px);
  }

  @media (max-width: 1150px) {
    .feature-board-large-tile .feature-board-badge-wrap {
      font-size: var(--ft-21-18);
    }

    .feature-board-item .feature-board-badge-wrap {
      font-size: var(--ft-15-14);
    }
  }

  @media (max-width: 600px) {
    .feature-board-large-tile .feature-board-badge-wrap {
      font-size: var(--fm-18-16);
    }

    .feature-board-item .feature-board-badge-wrap {
      font-size: var(--fm-14-12);
    }
  }
</style>
