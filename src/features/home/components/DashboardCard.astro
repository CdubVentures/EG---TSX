---
/**
 * DashboardCard.astro — Reusable card for rows 2–5.
 * Variant prop controls sizing, line clamps, and descriptions per row.
 * Faithful port of HBS .dashboard-rowN-item/image/content/title/description/date CSS.
 */
import { articleUrl, resolveHero, articleSrcSet, formatArticleDate } from '@core/article-helpers';
import type { DashboardEntry } from '@core/article-helpers';
import type { DashboardMeta } from '@core/dashboard';
import { categoryColor } from '@core/config';
import PinTag from '@shared/ui/PinTag.astro';
import EditorsBadge from '@shared/ui/EditorsBadge.astro';

type Variant = 'row2' | 'row3' | 'row4' | 'row5';

interface Props {
  item: DashboardEntry;
  variant: Variant;
  eager?: boolean;
  meta?: DashboardMeta;
}

const { item, variant, eager = false, meta } = Astro.props;
const url = articleUrl(item._collection, item.id);
const heroPath = item.data.hero
  ? resolveHero(item._collection, item.id, item.data.hero)
  : null;
const catColor = item.data.category ? categoryColor(item.data.category) : undefined;
const hasDescription = variant !== 'row2' && item.data.description;

// Determine sizes attribute per variant
const sizesMap: Record<Variant, string> = {
  row2: '(min-width: 825px) 325px, 275px',
  row3: '(min-width: 1150px) 325px, clamp(200px, 400px, 500px)',
  row4: '(min-width: 1150px) 325px, clamp(200px, 400px, 500px)',
  row5: '(min-width: 1150px) 250px, clamp(200px, 400px, 500px)',
};
---

<a href={url} class:list={['dashboard-grid-item', `dashboard-${variant}-item`]}>
  {meta?.isPinned && <PinTag categoryColor={catColor} />}
  {meta?.badgeText && <EditorsBadge badgeText={meta.badgeText} category={item.data.category} />}
  {heroPath && (
    <img
      loading={eager ? 'eager' : 'lazy'}
      src={`${heroPath}_s.webp`}
      srcset={articleSrcSet(heroPath)}
      sizes={sizesMap[variant]}
      alt={item.data.title}
      class:list={['dashboard-grid-image', `dashboard-${variant}-image`]}
    />
  )}
  <div class:list={['dashboard-grid-item-content', `dashboard-${variant}-content`]}>
    <div class="dashboard-content-top">
      {item.data.category && (
        <span class="dashboard-item-type item-tag" style={catColor ? `color: ${catColor}` : undefined}>
          {item.data.category}
        </span>
      )}
      <h3 class={`dashboard-${variant}-title`}>{item.data.title}</h3>
      {hasDescription && (
        <p class={`dashboard-${variant}-description`}>{item.data.description}</p>
      )}
    </div>
    <p class:list={[`dashboard-${variant}-date`, 'item-date']}>
      {formatArticleDate(item.data.datePublished, item.data.dateUpdated)}
    </p>
  </div>
</a>

<style>
  /* ── Row 2 item (3-col, desktop vertical) ── */
  .dashboard-row2-item {
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--section-dark-background-color);
    overflow: hidden;
    border-radius: 6px;
    text-decoration: none;
    color: var(--white-color-1);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease;
  }

  .dashboard-row2-item:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .dashboard-row2-image {
    height: clamp(159px, 120.4118px + 9.6471vw, 200px);
    width: 100%;
    object-fit: cover;
  }

  .dashboard-row2-content {
    flex: 1;
    padding: 1.25rem 1.65rem;
    box-sizing: border-box;
    background: transparent;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .dashboard-row2-title {
    font-size: var(--font-size-19px);
    font-weight: var(--font-weight7);
    margin: 0.5rem 0 0.75rem 0;
    line-height: 1.35;
    letter-spacing: -0.5px;
    color: var(--white-black-color-1);
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: var(--identity-font);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .dashboard-row2-date {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
  }

  /* ── Rows 3, 4, 5 items ── */
  .dashboard-row3-item,
  .dashboard-row4-item,
  .dashboard-row5-item {
    display: flex;
    flex-direction: column;
    background: var(--section-dark-background-color);
    overflow: hidden;
    position: relative;
    border-radius: 6px;
    text-decoration: none;
    color: var(--white-color-1);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease;
  }

  .dashboard-row3-item:hover,
  .dashboard-row4-item:hover,
  .dashboard-row5-item:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .dashboard-row3-image,
  .dashboard-row4-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .dashboard-row5-image {
    width: 100%;
    height: 125px;
    object-fit: cover;
  }

  .dashboard-row3-content,
  .dashboard-row4-content,
  .dashboard-row5-content {
    flex: 1;
    padding: 1.35rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .dashboard-content-top {
    display: flex;
    flex-direction: column;
  }

  .dashboard-row3-title,
  .dashboard-row4-title,
  .dashboard-row5-title {
    font-size: var(--font-size-18px);
    font-weight: var(--font-weight7);
    margin: 0.5rem 0;
    line-height: 1.4;
    letter-spacing: -0.5px;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--white-color-1);
    font-family: var(--identity-font);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .dashboard-row3-description,
  .dashboard-row4-description {
    margin: 0;
    line-height: 1.5;
    font-size: var(--font-size-16px);
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    /* Hidden by default on desktop, shown at ≤1150px */
    display: none;
  }

  .dashboard-row5-description {
    margin: 0;
    line-height: 1.5;
    font-size: var(--font-size-16px);
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
    /* Hidden by default on desktop */
    display: none;
  }

  /* ── Dates ── */
  .dashboard-row3-date,
  .dashboard-row4-date,
  .dashboard-row5-date {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
  }

  /* ── Hover effects ── */
  .dashboard-grid-item:hover .dashboard-row2-title {
    text-decoration: underline;
    text-decoration-color: var(--white-black-color-1);
    text-decoration-thickness: 1.25px;
    text-underline-offset: 1.25px;
  }

  .dashboard-grid-item:hover .dashboard-row3-title,
  .dashboard-grid-item:hover .dashboard-row4-title,
  .dashboard-grid-item:hover .dashboard-row5-title {
    text-decoration: underline;
    text-decoration-color: var(--white-black-color-1);
    text-decoration-thickness: 1.25px;
    text-underline-offset: 1.25px;
  }

  /* ── ≤1150px: rows 3–5 become horizontal (40% image / 60% content) ── */
  @media (max-width: 1150px) {
    .dashboard-row2-title {
      font-size: var(--ft-19-17);
    }

    .dashboard-row3-item,
    .dashboard-row4-item,
    .dashboard-row5-item {
      width: 100%;
      flex-direction: row;
      align-items: stretch;
      border-radius: 5px;
      background: var(--section-dark-background-color);
    }

    .dashboard-row3-image,
    .dashboard-row4-image,
    .dashboard-row5-image {
      order: 1;
      width: 40%;
      height: var(--font-size-215px);
      object-fit: cover;
    }

    .dashboard-row3-content,
    .dashboard-row4-content,
    .dashboard-row5-content {
      order: 2;
      width: 60%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 0.5rem;
      padding: 20px;
    }

    .dashboard-row3-title,
    .dashboard-row4-title,
    .dashboard-row5-title {
      font-size: var(--ft-21-16);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .dashboard-row3-description,
    .dashboard-row4-description,
    .dashboard-row5-description {
      font-size: var(--font-size-15px);
      color: var(--grey-color-4);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .dashboard-row2-date,
    .dashboard-row3-date,
    .dashboard-row4-date,
    .dashboard-row5-date {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 1;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Tag clamp at 1150px */
    .dashboard-row3-item .item-tag,
    .dashboard-row4-item .item-tag,
    .dashboard-row5-item .item-tag {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 1;
      overflow: hidden;
      text-overflow: ellipsis;
    }
  }

  /* ── ≤825px ── */
  @media (max-width: 825px) {
    .dashboard-row2-title {
      line-height: 1.3;
    }

    .dashboard-row3-image,
    .dashboard-row4-image,
    .dashboard-row5-image {
      height: var(--font-size-165px);
    }

    .dashboard-row3-content,
    .dashboard-row4-content,
    .dashboard-row5-content {
      padding: clamp(12px, 9.1765px + 0.7059vw, 15px) 15px;
    }

    .dashboard-row3-title,
    .dashboard-row4-title,
    .dashboard-row5-title {
      margin: 0.45rem 0 0.7rem 0;
      line-height: 1.4;
      -webkit-line-clamp: 2;
    }

    .dashboard-row3-description,
    .dashboard-row4-description,
    .dashboard-row5-description {
      line-height: 1.4;
      -webkit-line-clamp: 1;
      margin-bottom: 0.25rem;
    }
  }

  /* ── Row 2 at ≤825px: horizontal scroll ── */
  @media (max-width: 825px) {
    .dashboard-row2-item {
      flex: none;
    }
  }

  /* ── ≤600px ── */
  @media (max-width: 600px) {
    .dashboard-row2-title {
      font-size: var(--fm-17-15);
    }

    .dashboard-row3-image,
    .dashboard-row4-image,
    .dashboard-row5-image {
      height: clamp(var(--font-size-125px), 7.5rem + 12.5vw, var(--font-size-150px));
    }

    .dashboard-row3-title,
    .dashboard-row4-title,
    .dashboard-row5-title {
      font-size: var(--fm-16-14);
      line-height: 1.4;
      -webkit-line-clamp: 3;
    }

    .dashboard-row3-content,
    .dashboard-row4-content,
    .dashboard-row5-content {
      gap: 0;
    }

    .dashboard-row3-description,
    .dashboard-row4-description,
    .dashboard-row5-description {
      display: none;
    }

    .dashboard-row2-date,
    .dashboard-row3-date,
    .dashboard-row4-date,
    .dashboard-row5-date {
      overflow: visible;
    }
  }

  /* ── ≤400px ── */
  @media (max-width: 400px) {
    .dashboard-row3-image,
    .dashboard-row4-image,
    .dashboard-row5-image {
      height: var(--font-size-120px);
    }
  }
</style>
