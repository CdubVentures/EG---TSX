---
/**
 * LatestNews.astro — "Latest News" section on the home page.
 * Port of HBS scroller4x4.handlebars (166 lines) + scroller_4x4.css (451 lines).
 *
 * Structure:
 *   SectionDivider → Top Grid (2×2) → SubSectionDivider → Bottom Feed (up to 16)
 *   Inline ad after 8th bottom feed item.
 *
 * All dark theme CSS values are LOCKED to HBS parity.
 */
import SectionDivider from '@shared/ui/SectionDivider.astro';
import SubSectionDivider from '@shared/ui/SubSectionDivider.astro';
import AdSlot from '@features/ads/components/AdSlot.astro';
import EditorsBadge from '@shared/ui/EditorsBadge.astro';
import { catVar } from '@core/categories';
import { newsTopGridItems, newsBottomFeedItems, newsAdInsertIndex } from '../latest-news-utils';
import type { FeaturedItem } from '../featured-scroller-utils';

interface Props {
  items: FeaturedItem[];
}

const { items } = Astro.props;

if (items.length === 0) return;

const topItems = newsTopGridItems(items);
const feedItems = newsBottomFeedItems(items);
const adIndex = newsAdInsertIndex(feedItems.length);

// Split top grid into row1 (first 2) and row2 (next 2)
const row1 = topItems.slice(0, 2);
const row2 = topItems.slice(2, 4);
---

<SectionDivider
  title="Latest News"
  subtitle="The latest updates in esports, tech, and gaming"
  seeMoreHref="/news"
/>

{/* ── Top Grid (2×2) ── */}
<section class="news-menu-tile-board-section">
  <div class="news-menu-content">
    <div class="news-menu-items active">
      <div class="news-grid-container">
        <div class="news-top-row">

          {/* Row 1 */}
          <div class="news-grid-row news-row1">
            {row1.map(item => (
              <a href={item.url} class="news-grid-item news-row1-item">
                {item.egbadge && (
                  <EditorsBadge badgeText={item.egbadge} category={item.category} />
                )}
                <img
                  loading="lazy"
                  src={`${item.heroPath}_s.webp`}
                  srcset={item.srcset}
                  sizes="(min-width: 1150px) 500px, (max-width: 1000px) 50vw, 500px"
                  alt={item.title}
                  class="news-grid-image news-row1-image"
                />
                <div class="news-grid-item-content news-row1-content">
                  <div class="news-content-top">
                    <span
                      class="news-item-type item-tag"
                      style={`color: ${catVar(item.category)}`}
                    >{item.categoryLabel}</span>
                    <h3 class="news-row1-title">{item.title}</h3>
                  </div>
                  <p class="news-row1-date item-date">{item.dateFormatted}</p>
                </div>
              </a>
            ))}
          </div>

          {/* Row 2 (only if we have items for it) */}
          {row2.length > 0 && (
            <div class="news-grid-row news-row2">
              {row2.map(item => (
                <a href={item.url} class="news-grid-item news-row2-item">
                  {item.egbadge && (
                    <EditorsBadge badgeText={item.egbadge} category={item.category} />
                  )}
                  <img
                    loading="lazy"
                    src={`${item.heroPath}_s.webp`}
                    srcset={item.srcset}
                    sizes="(min-width: 1150px) 500px, (max-width: 1000px) 50vw, 500px"
                    alt={item.title}
                    class="news-grid-image news-row2-image"
                  />
                  <div class="news-grid-item-content news-row2-content">
                    <div class="news-content-top">
                      <span
                        class="news-item-type item-tag"
                        style={`color: ${catVar(item.category)}`}
                      >{item.categoryLabel}</span>
                      <h3 class="news-row2-title">{item.title}</h3>
                    </div>
                    <p class="news-row2-date item-date">{item.dateFormatted}</p>
                  </div>
                </a>
              ))}
            </div>
          )}

        </div>
      </div>
    </div>
  </div>
</section>

{/* ── Sub-section divider + Bottom Feed (only if ≥ 4 items) ── */}
{feedItems.length > 0 && (
  <>
    <SubSectionDivider text="News Cont." />

    <div class="news-row">
      {feedItems.map((item, i) => (
        <>
          <a href={item.url} class="news-item">
            {item.egbadge && (
              <EditorsBadge badgeText={item.egbadge} category={item.category} />
            )}
            <img
              loading="lazy"
              src={`${item.heroPath}_s.webp`}
              srcset={item.srcset}
              sizes="(min-width: 1000px) 400px, 40vw"
              alt={item.title}
              class="news-item-image"
            />
            <div class="news-item-content">
              <div class="news-content-top">
                <span
                  class="news-item-type item-tag"
                  style={`color: ${catVar(item.category)}`}
                >{item.categoryLabel}</span>
                <h3 class="news-item-title">{item.title}</h3>
                <p class="news-item-description">{item.description}</p>
              </div>
              <p class="news-item-date item-date">{item.dateFormatted}</p>
            </div>
          </a>

          {/* Inline ad after 8th feed item */}
          {i === adIndex && (
            <div class="news-inline-ad" aria-label="Advertisement">
              <AdSlot campaign="inline-ad" />
            </div>
          )}
        </>
      ))}
    </div>
  </>
)}

<style is:global>
  /* ══════════════════════════════════════════════════════════════════════════
     LATEST NEWS — Port of scroller_4x4.css (EG-HBS)
     Dark theme values are LOCKED — they match HBS exactly.
     ══════════════════════════════════════════════════════════════════════════ */

  /* ── Top Grid (First Partial) ── */
  .news-menu-tile-board-section {
    margin-top: 0;
    position: relative;
    box-sizing: border-box;
  }

  .news-menu-content {
    margin-top: 0;
  }

  .news-menu-items.active {
    display: block;
  }

  .news-grid-container {
    display: flex;
    flex-direction: column;
    max-width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .news-top-row {
    display: flex;
    flex-direction: column;
    gap: var(--ft-21-16);
    overflow-x: auto;
  }

  .news-grid-row {
    display: grid;
    gap: var(--ft-16-12);
    box-sizing: border-box;
  }

  .news-row1 {
    grid-template-columns: repeat(2, 1fr);
  }

  .news-row2 {
    grid-template-columns: repeat(2, 1fr);
  }

  /* Each grid item in top rows */
  .news-grid-item {
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--section-dark-background-color);
    overflow: hidden;
    border-radius: 6px;
    text-decoration: none;
    color: var(--white-color-1);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease;
  }

  .news-grid-item:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .news-row1-image,
  .news-row2-image {
    width: 100%;
    height: clamp(150px, 21.9101px + 33.7079vw, 300px);
    object-fit: cover;
  }

  .news-row1-content,
  .news-row2-content {
    flex: 1;
    padding: 1.35rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .news-row1-title,
  .news-row2-title {
    font-size: var(--ft-24-17);
    font-weight: var(--font-weight7);
    margin: 0 0 0.5rem 0;
    line-height: 1.35;
    letter-spacing: -0.5px;
    color: var(--white-color-1);
    font-family: var(--identity-font);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .news-row1-date,
  .news-row2-date {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
  }

  .news-grid-item .news-content-top {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Hover effect for top partial titles */
  .news-grid-item:hover .news-row1-title,
  .news-grid-item:hover .news-row2-title {
    text-decoration: underline;
    text-decoration-color: var(--white-black-color-1);
    text-decoration-thickness: clamp(1.25px, 1.1167px + 0.0333vw, 1.5px);
    text-underline-offset: 1.25px;
  }

  /* ── Bottom Feed (News Cont.) ── */
  .news-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ft-16-12);
    box-sizing: border-box;
  }

  .news-item {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    background: var(--section-dark-background-color);
    overflow: hidden;
    position: relative;
    border-radius: 6px;
    text-decoration: none;
    color: var(--white-color-1);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease;
  }

  .news-item:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .news-item-image {
    width: 40%;
    height: var(--font-size-250px);
    object-fit: cover;
    order: 1;
  }

  .news-content-top {
    display: flex;
    flex-direction: column;
  }

  .news-item-content {
    order: 2;
    width: 60%;
    height: auto;
    padding: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .news-item-title {
    font-size: var(--font-size-21px);
    font-weight: var(--font-weight7);
    letter-spacing: -0.5px;
    margin: 1rem 0 1.15rem 0;
    line-height: 1.5;
    color: var(--white-color-1);
    font-family: var(--identity-font);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .news-item-description {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0;
    line-height: 1.4;
    font-size: var(--font-size-16px);
    color: var(--grey-color-4);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
  }

  .news-item-date {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--grey-color-3);
  }

  .news-row .item-tag {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Hover effect for bottom feed titles */
  .news-item:hover .news-item-title {
    text-decoration: underline;
    text-decoration-color: var(--white-color-1);
    text-decoration-thickness: 1.25px;
    text-underline-offset: 1.25px;
  }

  /* ── Inline ad in bottom feed ── */
  .news-inline-ad {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ── EditorsBadge positioning — top grid rows ── */
  .news-row1 .editors-choice-badge,
  .news-row2 .editors-choice-badge {
    font-size: var(--ft-20-15);
    display: flex;
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
  }

  /* ── EditorsBadge positioning — bottom feed ── */
  .news-row .editors-choice-badge {
    font-size: var(--ft-17-14);
    display: flex;
    position: absolute;
    top: 0.75rem;
    right: calc(60% + 0.75rem);
    z-index: 10;
  }

  /* ══════════════════════════════════════════════════════════════════════════
     RESPONSIVE — Port of scroller_4x4.css breakpoints
     ══════════════════════════════════════════════════════════════════════════ */

  @media (max-width: 1150px) {
    .news-item {
      border-radius: 5px;
    }

    .news-item-title {
      font-size: var(--ft-21-16);
      line-height: 1.4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .news-item-description {
      font-size: var(--font-size-15px);
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .news-row {
      grid-template-columns: 1fr;
    }

    .news-item-image {
      width: 40%;
      height: var(--font-size-215px);
      object-fit: cover;
      order: 1;
    }

    .news-item-content {
      order: 2;
      width: 60%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .news-item-date {
      display: block;
    }
  }

  @media (max-width: 825px) {
    .news-item-image {
      height: var(--font-size-175px);
    }

    .news-item-title {
      margin: 0.45rem 0 0.7rem 0;
    }

    .news-item-content {
      padding: clamp(12px, 9.1765px + 0.7059vw, 15px) 15px;
    }

    .news-row1-title,
    .news-row2-title {
      line-height: 1.3;
    }

    .news-item-description {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-bottom: 0.25rem;
    }
  }

  @media (max-width: 600px) {
    .news-item-image {
      height: clamp(var(--font-size-125px), 75px + 12.5vw, var(--font-size-150px));
    }

    .news-row1-title,
    .news-row2-title {
      font-size: var(--fm-17-15);
    }

    .news-item-title {
      font-size: var(--fm-16-14);
      margin: 0.45rem 0 0 0;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .news-item-description {
      display: none;
    }

    .news-item-date {
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 1;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* EditorsBadge responsive — top grid */
    .news-row1 .editors-choice-badge,
    .news-row2 .editors-choice-badge {
      font-size: var(--fm-15-12);
    }

    /* EditorsBadge responsive — bottom feed */
    .news-row .editors-choice-badge {
      font-size: var(--fm-14-11);
    }
  }

  @media (max-width: 380px) {
    .news-item-image {
      height: var(--font-size-120px);
    }
  }
</style>
