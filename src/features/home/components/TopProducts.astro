---
/**
 * TopProducts.astro — Top products section with slideshow,
 * category dropdown, and tools sidebar shell.
 * Port of HBS .home-page-intro (lines 300–386).
 */
import SectionDivider from '@shared/ui/SectionDivider.astro';
import HomeSlideshow from './HomeSlideshow.astro';
import CategoryDropdown from './CategoryDropdown';
import { CONFIG, categoryColor, label } from '@core/config';
import { getCategoryColors } from '@core/categories';
import { getMobileTools } from '@core/hub-tools';

const categoryOptions = CONFIG.categories.map(id => ({
  id,
  color: categoryColor(id),
  hover: getCategoryColors(id).hover,
}));

const toolGroups = getMobileTools();
/** Desktop: ≤3 categories → top 2 open, 4-5 → top 1 open, 6+ → all closed. */
const n = toolGroups.length;
const desktopExpandCount = n <= 3 ? 2 : n <= 5 ? 1 : 0;
---

<div class="home-page-intro">

  {/* ── Section Divider with Dropdown ── */}
  <SectionDivider
    title="Top Deals"
    titleHref="/guides/hardware/highlighted-products"
    subtitle="Fresh Drops: Today's Top Gear"
    class="top-products"
  >
    <div slot="actions">
      <CategoryDropdown client:load categories={categoryOptions} />
    </div>
  </SectionDivider>

  {/* ── Content Row: Slideshow + Tools ── */}
  <div class="home-page-intro-wrapper">

    {/* Slideshow (Embla carousel) */}
    <HomeSlideshow />

    {/* Tools sidebar */}
    <div class="home-intro-right">
      <a href="/hubs/" class="home-intro-right-title">Hubs</a>

      {/* Accordion: Hub prominent per category, secondary tools expand */}
      <div class="tools-accordion">
        {toolGroups.map((group, i) => {
          const hubTool = group.tools.find(t => t.tool === 'hub');
          const secondaryTools = group.tools.filter(t => t.tool !== 'hub');
          const catLabel = label(group.category);
          const panelClasses = ['accordion-panel-outer', 'auto-expand',
            ...(i < desktopExpandCount ? ['auto-expand-desktop'] : [])
          ].join(' ');
          return (
            <div class="accordion-category" data-category={group.category}>
              <div class="accordion-header">
                <a href={hubTool?.url ?? `/hubs/${group.category}`} class="accordion-hub-link">
                  <div class="accordion-icon" style={`color: ${group.tools[0]?.categoryColor}`} set:html={hubTool?.svg ?? ''} />
                  <span class="accordion-label">{catLabel} Hub</span>
                  <span class="accordion-hub-arrow">&#10095;</span>
                </a>
                {secondaryTools.length > 0 && (
                  <button class="accordion-toggle" aria-expanded="false" aria-label={`Show ${catLabel} tools`}>
                    <span class="accordion-chevron">&#10095;</span>
                  </button>
                )}
              </div>
              {secondaryTools.length > 0 && (
                <div class={panelClasses}>
                  <div class="accordion-panel">
                    {secondaryTools.map(tool => (
                      <a href={tool.url} class="accordion-sub-row">
                        <div class="accordion-sub-icon" set:html={tool.svg} />
                        <span class="accordion-sub-title">{tool.title}</span>
                        <span class="accordion-sub-arrow">&#10095;</span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>

  </div>
</div>

<style>
  /* ── Top Products Section ── */
  .home-page-intro {
    display: flex;
    flex-direction: column;
    width: calc(100% - 3rem);
    max-width: var(--home-width);
    margin: 0 auto;
    order: 1;
  }

  .home-page-intro-wrapper {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: stretch;
  }

  /* ── Slideshow Wrapper ── */
  /* WHY no flex ratio: HBS .home-top-slides-wrapper has NO flex property.
     The inner .home-top-slides uses clamp() for responsive sizing.
     Sidebar gets flex:1 and fills remaining space. */
  .home-top-slides-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ── Tools Sidebar ── */
  /* WHY contain:size — locks sidebar to slideshow height via align-items:stretch,
     so inner .tools-accordion scrolls instead of growing unbounded. Matches HBS.
     WHY grid — grid-template-rows: auto 1fr gives the accordion a definite track
     height (unlike flex:1), so overflow-y:auto actually scrolls. */
  .home-intro-right {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 0;
    contain: size;
    flex: 1;
  }

  .home-intro-right-title {
    position: relative;
    text-align: center;
    font-weight: var(--font-weight8);
    font-family: var(--identity-font);
    color: var(--white-color-1);
    letter-spacing: -0.25px;
    line-height: 1;
    font-size: var(--font-size-20px);
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 1.25rem;
    background: none;
    border-bottom: 1px solid var(--section-medium-background-color);
    border-top: 1px solid var(--section-medium-background-color);
  }

  .home-intro-right:hover .home-intro-right-title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Downward arrow pseudo-element */
  .home-intro-right-title::after {
    content: '';
    position: absolute;
    bottom: -0.7rem;
    left: 78%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 0.7rem solid transparent;
    border-right: 0.7rem solid transparent;
    border-top: 0.7rem solid var(--section-medium-background-color);
  }

  /* ── Tools Accordion ── */
  .tools-accordion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
    padding: 0.25rem;
    min-height: 0;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .accordion-category {
    border-radius: 6px;
    background-color: var(--section-dark-background-color);
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: var(--card-shadow);
  }

  .accordion-header {
    display: flex;
    align-items: stretch;
  }

  .accordion-hub-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    padding: 0.85rem 1rem;
    text-decoration: none;
    color: var(--white-color-1);
    min-width: 0;
  }

  .accordion-icon {
    flex-shrink: 0;
    width: 1.6em;
    height: 1.6em;
    font-size: var(--font-size-20px);
  }

  .accordion-icon :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .accordion-label {
    font-family: var(--identity-font);
    font-weight: var(--font-weight7);
    font-size: var(--font-size-17px);
    text-transform: uppercase;
    letter-spacing: -0.25px;
    white-space: nowrap;
  }

  .accordion-hub-arrow {
    color: var(--grey-color-3);
    font-size: var(--font-size-13px);
    margin-left: auto;
    transition: transform 0.15s ease;
  }

  /* WHY 4rem: minimum 44px touch target (4 × 11px base) per Apple HIG */
  .accordion-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    flex-shrink: 0;
    background-color: var(--section-darkest-background-color);
    border: none;
    border-left: 1px solid var(--section-medium-background-color);
    cursor: pointer;
    padding: 0;
    color: var(--grey-color-3);
    transition: background-color 0.15s ease;
  }

  .accordion-chevron {
    display: inline-block;
    font-size: var(--font-size-12px);
    transition: transform 0.25s ease;
    transform: rotate(90deg);
  }

  .accordion-toggle[aria-expanded="true"] .accordion-chevron {
    transform: rotate(-90deg);
  }

  /* ── Grid animation wrapper (0fr → 1fr for smooth height) ── */
  .accordion-panel-outer {
    display: grid;
    grid-template-rows: 0fr;
  }

  .accordion-panel-outer[data-open] {
    grid-template-rows: 1fr;
  }

  /* Desktop: server marks first N panels with .auto-expand-desktop — zero flicker */
  @media (min-width: 901px) {
    .accordion-panel-outer.auto-expand-desktop {
      grid-template-rows: 1fr;
    }
  }

  /* Mobile: panels start collapsed, user toggles open (matches original) */

  /* Transitions enabled by JS after first paint — prevents load animation */
  .accordion-panel-outer.animate {
    transition: grid-template-rows 0.3s ease;
  }

  .accordion-panel {
    overflow: hidden;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  /* ── Desktop sub-rows (SVG icon + title + arrow) ── */
  .accordion-sub-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 1rem 0.5rem 1.25rem;
    text-decoration: none;
    color: var(--grey-color-2);
    font-family: var(--identity-font);
    font-weight: var(--font-weight6);
    font-size: var(--font-size-14px);
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .accordion-sub-row:first-child {
    padding-top: 0.65rem;
    border-top: 1px solid var(--section-medium-background-color);
  }

  .accordion-sub-row:last-child {
    padding-bottom: 0.65rem;
  }

  .accordion-sub-icon {
    flex-shrink: 0;
    width: 1.2em;
    height: 1.2em;
    color: var(--grey-color-4);
  }

  .accordion-sub-icon :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .accordion-sub-title {
    flex: 1;
  }

  .accordion-sub-arrow {
    color: var(--grey-color-4);
    font-size: var(--font-size-11px);
    transition: transform 0.15s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .accordion-hub-link:hover .accordion-label {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .accordion-hub-link:hover .accordion-hub-arrow {
      transform: translateX(3px);
    }

    .accordion-toggle:hover {
      background-color: var(--section-medium-background-color);
    }

    .accordion-sub-row:hover {
      background-color: var(--section-medium-background-color);
      color: var(--white-color-1);
    }

    .accordion-sub-row:hover .accordion-sub-icon {
      color: var(--grey-color-2);
    }

    .accordion-sub-row:hover .accordion-sub-arrow {
      transform: translateX(3px);
    }
  }

  /* ── Dropdown Styles (global — targets React island DOM) ── */
  :global(.custom-dropdown) {
    position: relative;
    display: inline-block;
  }

  :global(.custom-dropdown-button) {
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--section-medium-background-color);
    border-radius: 8px;
    background-color: transparent;
    color: var(--white-color-1);
    font-size: var(--font-size-14px);
    font-family: var(--identity-font);
    font-weight: var(--font-weight6);
    cursor: pointer;
    text-decoration: none;
    position: relative;
    text-transform: uppercase;
  }

  :global(.custom-dropdown-button)::after {
    content: '\25BC';
    display: inline-block;
    margin-left: 0.5rem;
    color: var(--white-color-1);
    transform-origin: center;
    transition: transform 0.3s ease;
  }

  :global(.custom-dropdown-menu) {
    position: absolute;
    top: calc(100% + 1px);
    z-index: 1000;
    background-color: var(--section-dark-background-color);
    border: 1px solid var(--section-dark-background-color);
    margin-top: 0;
    padding: 0.5rem 0;
    list-style: none;
    min-width: 180px;
    display: none;
  }

  :global(.custom-dropdown-menu li) {
    background-color: transparent;
    border: none;
    padding: 0.75rem 1.25rem;
    color: var(--white-color-2);
    font-size: var(--font-size-14px);
    cursor: pointer;
    text-transform: uppercase;
    font-family: var(--identity-font);
    font-weight: var(--font-weight6);
    letter-spacing: 0.05rem;
    outline: none;
  }

  :global(.custom-dropdown-menu li[aria-selected="true"]),
  :global(.custom-dropdown-menu li.selected) {
    border-left: 4px solid var(--card-hover, var(--site-start-color));
    color: var(--card-hover, var(--site-start-color));
    background-color: var(--section-darkest-background-color);
  }

  :global(.custom-dropdown-menu li:focus-visible) {
    outline: 2px solid var(--site-start-color);
    outline-offset: -2px;
  }

  /* Locked/open state */
  :global(.custom-dropdown.locked .custom-dropdown-button) {
    box-shadow: 0 0 0 2px currentColor;
  }

  :global(.custom-dropdown.locked .custom-dropdown-button)::after {
    content: '\25B2';
  }

  :global(.custom-dropdown.locked .custom-dropdown-menu) {
    display: block;
  }

  /* Locked button — "All Products" */
  :global(.custom-dropdown.locked .custom-dropdown-button[data-category="all"]) {
    border-color: var(--site-start-color);
    color: var(--site-start-color);
  }

  :global(.custom-dropdown.locked .custom-dropdown-button[data-category="all"])::after {
    color: var(--site-start-color);
  }

  /* Locked button — specific category */
  :global(.custom-dropdown.locked .custom-dropdown-button:not([data-category="all"])) {
    border-color: var(--card-color);
    color: var(--card-color);
  }

  :global(.custom-dropdown.locked .custom-dropdown-button:not([data-category="all"]))::after {
    color: var(--card-color);
  }

  /* Desktop hover interactions */
  @media (hover: hover) and (pointer: fine) {
    :global(.custom-dropdown:hover .custom-dropdown-menu) {
      display: block;
    }

    :global(.custom-dropdown-button[data-category="all"]:hover) {
      border-color: var(--site-start-color);
      color: var(--site-start-color);
    }

    :global(.custom-dropdown-button[data-category="all"]:hover)::after {
      color: var(--site-start-color);
    }

    :global(.custom-dropdown-button:not([data-category="all"]):hover) {
      border-color: var(--card-color);
      color: var(--card-color);
    }

    :global(.custom-dropdown-button:not([data-category="all"]):hover)::after {
      color: var(--card-color);
    }

    :global(.custom-dropdown-menu li:hover) {
      border-left: 4px solid var(--card-hover, var(--site-start-color));
      color: var(--card-hover, var(--site-start-color));
      background-color: var(--section-darkest-background-color);
    }
  }

  /* ── SectionDivider overrides for .top-products ── */
  :global(.section-divider.top-products) {
    margin: 4rem auto 1.75rem auto;
  }

  :global(.section-divider.top-products .section-divider-actions) {
    padding-bottom: 0;
    margin-bottom: 0;
    margin-top: 0;
    overflow: visible !important;
  }

  /* ── Responsive: ≤900px ── */
  @media (max-width: 900px) {
    .home-page-intro {
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 0 0 0;
      background-color: var(--section-darkestdark-background-color);
      order: 3;
    }

    :global(.section-divider.top-products) {
      margin: 0 auto 1.75rem auto;
      width: calc(100% - 3rem);
    }

    .home-page-intro-wrapper {
      display: flex;
      flex-direction: column;
      min-height: auto;
    }

    .home-intro-right {
      margin: 0 auto;
      flex-shrink: 0;
      background-color: var(--section-darkestdarker-background-color);
      contain: unset;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .home-intro-right-title::after {
      display: none;
    }

    .home-intro-right-title {
      padding: 0;
      text-transform: capitalize;
      margin: 1.5rem 0;
      text-align: left;
      background: none;
      border-bottom: none;
      border-top: none;
      font-family: var(--identity-font);
      font-size: var(--ft-30-24);
      letter-spacing: -0.5px;
      color: var(--white-black-color-1);
      font-weight: var(--font-weight8);
      line-height: 1.15;
      width: calc(100% - 3rem);
    }

    .tools-accordion {
      width: calc(100% - 3rem);
      margin: 0.5rem auto 1.5rem auto;
      gap: 0.65rem;
      padding: 0;
    }

    /* Mobile: hide/show instead of 0fr animation (avoids padding leak) */
    .accordion-panel-outer {
      display: none;
    }

    .accordion-panel-outer[data-open] {
      display: block;
    }

    /* Sub-rows become pills on mobile */
    .accordion-panel {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
      padding: 0.5rem 1rem 0.75rem;
    }

    .accordion-sub-row {
      padding: 0.35rem 0.85rem;
      border-radius: 4px;
      background-color: var(--section-medium-background-color);
      font-size: var(--font-size-12px);
      text-transform: uppercase;
      letter-spacing: 0.02em;
      gap: 0;
    }

    .accordion-sub-row:first-child {
      padding-top: 0.35rem;
      border-top: none;
    }

    .accordion-sub-row:last-child {
      padding-bottom: 0.35rem;
    }

    .accordion-sub-icon,
    .accordion-sub-arrow {
      display: none;
    }
  }


  @media (max-width: 600px) {
    :global(.custom-dropdown-button) {
      font-size: var(--fm-14-13);
    }

    :global(.custom-dropdown-menu li) {
      font-size: var(--fm-14-13);
    }

    .accordion-label {
      font-size: var(--fm-15-14);
    }

    .accordion-sub-row {
      font-size: var(--fm-11-10);
    }
  }
</style>

<script>
  const isDesktop = window.matchMedia('(min-width: 901px)').matches;

  // Phase 1: Convert CSS auto-expand classes to data-open state, sync aria
  // Desktop: .auto-expand-desktop panels open. Mobile: all start collapsed.
  document.querySelectorAll('.accordion-panel-outer').forEach(el => {
    if (isDesktop && el.classList.contains('auto-expand-desktop')) {
      el.setAttribute('data-open', '');
      const btn = el.closest('.accordion-category')?.querySelector('.accordion-toggle');
      if (btn) btn.setAttribute('aria-expanded', 'true');
    }
    el.classList.remove('auto-expand', 'auto-expand-desktop');
  });

  // Phase 2: Enable transitions after first paint — prevents load flicker
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      document.querySelectorAll('.accordion-panel-outer').forEach(el => {
        el.classList.add('animate');
      });
    });
  });

  // Phase 3: Toggle handler — scroll opened category into view after animation
  document.querySelectorAll('.accordion-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.closest('.accordion-category');
      const outer = category?.querySelector('.accordion-panel-outer');
      if (!outer) return;

      const isOpen = outer.hasAttribute('data-open');
      if (isOpen) {
        outer.removeAttribute('data-open');
      } else {
        outer.setAttribute('data-open', '');
        // After expand animation, scroll so the full category is visible
        outer.addEventListener('transitionend', () => {
          category?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, { once: true });
      }
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>

