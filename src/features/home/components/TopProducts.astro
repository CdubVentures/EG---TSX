---
/**
 * TopProducts.astro — Top products section with slideshow,
 * category dropdown, and tools sidebar shell.
 * Port of HBS .home-page-intro (lines 300–386).
 */
import SectionDivider from '@shared/ui/SectionDivider.astro';
import HomeSlideshow from './HomeSlideshow.astro';
import CategoryDropdown from './CategoryDropdown';
import { CONFIG, categoryColor } from '@core/config';
import { getCategoryColors } from '@core/categories';
import { getDesktopTools, getMobileTools } from '@core/hub-tools';

const categoryOptions = CONFIG.categories.map(id => ({
  id,
  color: categoryColor(id),
  hover: getCategoryColors(id).hover,
}));

const desktopTools = getDesktopTools();
const mobileToolGroups = getMobileTools();
---

<div class="home-page-intro">

  {/* ── Section Divider with Dropdown ── */}
  <SectionDivider
    title="Top Deals"
    titleHref="/guides/hardware/highlighted-products"
    subtitle="Fresh Drops: Today's Top Gear"
    class="top-products"
  >
    <div slot="actions">
      <CategoryDropdown client:load categories={categoryOptions} />
    </div>
  </SectionDivider>

  {/* ── Content Row: Slideshow + Tools ── */}
  <div class="home-page-intro-wrapper">

    {/* Slideshow (Embla carousel) */}
    <HomeSlideshow />

    {/* Tools sidebar */}
    <div class="home-intro-right">
      <a href="/hubs/" class="home-intro-right-title">Hubs</a>

      {/* Desktop: vertical list sorted by tool type → category */}
      <div class="home-tools-wrapper desktop-tools">
        {desktopTools.map(tool => (
          <a href={tool.url} class="home-tools-item" data-category={tool.category}>
            <div class="home-tools-text-content">
              <div class="home-tools-right-wrapper">
                <span class="home-tools-tag" style={`color: ${tool.categoryColor}`}>
                  {tool.category}
                </span>
                <h3 class="home-tools-title">{tool.title}</h3>
                <p class="home-tools-description">{tool.description}</p>
              </div>
              <span class="home-tools-arrow">&#10095;</span>
            </div>
            <div class="home-tools-image" set:html={tool.svg} />
          </a>
        ))}
      </div>

      {/* Mobile: one row per category */}
      <div class="home-tools-wrapper mobile-tools">
        {mobileToolGroups.map(group => (
          <div class="home-tools-row" data-category={group.category}>
            {group.tools.map(tool => (
              <a href={tool.url} class="home-tools-item" data-category={tool.category}>
                <div class="home-tools-text-content">
                  <div class="home-tools-right-wrapper">
                    <span class="home-tools-tag" style={`color: ${tool.categoryColor}`}>
                      {tool.category}
                    </span>
                    <h3 class="home-tools-title">{tool.title}</h3>
                    <p class="home-tools-description">{tool.description}</p>
                  </div>
                  <span class="home-tools-arrow">&#10095;</span>
                </div>
                <div class="home-tools-image" set:html={tool.svg} />
              </a>
            ))}
          </div>
        ))}
      </div>
    </div>

  </div>
</div>

<style>
  /* ── Top Products Section ── */
  .home-page-intro {
    display: flex;
    flex-direction: column;
    width: calc(100% - 3rem);
    max-width: var(--home-width);
    margin: 0 auto;
    order: 1;
  }

  .home-page-intro-wrapper {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    align-items: stretch;
  }

  /* ── Slideshow Wrapper ── */
  /* WHY no flex ratio: HBS .home-top-slides-wrapper has NO flex property.
     The inner .home-top-slides uses clamp() for responsive sizing.
     Sidebar gets flex:1 and fills remaining space. */
  .home-top-slides-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ── Tools Sidebar ── */
  .home-intro-right {
    display: flex;
    flex-direction: column;
    min-height: 0;
    contain: size;
    flex: 1;
  }

  .home-intro-right-title {
    position: relative;
    text-align: center;
    font-weight: var(--font-weight8);
    font-family: var(--identity-font);
    color: var(--white-color-1);
    letter-spacing: -0.25px;
    line-height: 1;
    font-size: var(--font-size-20px);
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 1.25rem;
    background: none;
    border-bottom: 1px solid var(--section-medium-background-color);
    border-top: 1px solid var(--section-medium-background-color);
  }

  .home-intro-right:hover .home-intro-right-title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Downward arrow pseudo-element */
  .home-intro-right-title::after {
    content: '';
    position: absolute;
    bottom: -0.7rem;
    left: 78%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 0.7rem solid transparent;
    border-right: 0.7rem solid transparent;
    border-top: 0.7rem solid var(--section-medium-background-color);
  }

  .home-tools-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: auto;
    margin-top: 1rem;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .home-tools-wrapper.mobile-tools {
    display: none;
  }

  /* ── Tool Items ── */
  .home-tools-item {
    position: relative;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    text-decoration: none;
    color: var(--white-color-1);
    padding: 1rem 1.25rem;
    margin-right: 0.5rem;
    border-radius: 6px;
    box-sizing: border-box;
    transition: filter 0.2s ease-in-out;
    background-color: var(--section-dark-background-color);
  }

  .home-tools-text-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    margin-right: 1.5rem;
    text-overflow: ellipsis;
    justify-content: space-between;
  }

  .home-tools-right-wrapper {
    display: flex;
    flex-direction: column;
  }

  .home-tools-tag {
    font-size: var(--font-size-14px);
    font-weight: var(--font-weight7);
    text-transform: uppercase;
    font-family: var(--identity-font);
    line-height: 1.2;
  }

  .home-tools-title {
    font-size: var(--font-size-20px);
    font-family: var(--identity-font);
    font-weight: var(--font-weight7);
    line-height: 1.3;
    color: var(--white-black-color-1);
    margin: 0 0 0.25rem 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .home-tools-description {
    font-size: var(--font-size-13px);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    line-height: 1.3;
    color: var(--grey-color-4);
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .home-tools-arrow {
    display: none;
    font-size: var(--ft-18-15);
    color: var(--grey-color-1);
    margin-left: 3rem;
  }

  .home-tools-image {
    font-size: var(--font-size-55px);
    max-width: 1em;
    overflow: hidden;
    color: var(--grey-color-4);
  }

  .home-tools-image :global(svg) {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 11;
    object-fit: contain;
    fill: var(--grey-color-4) !important;
  }

  /* Desktop hover */
  @media (hover: hover) and (pointer: fine) {
    .home-tools-item:hover {
      background-color: var(--section-medium-background-color);
    }

    .home-tools-item:hover .home-tools-title {
      text-decoration: underline;
      text-decoration-color: var(--white-color-1);
      text-decoration-thickness: 1px;
      text-underline-offset: 1px;
    }
  }

  /* Mobile tool rows */
  .home-tools-row {
    display: flex;
    flex-direction: row;
    gap: 0.75rem;
    overflow-x: auto;
    scrollbar-width: thin;
    width: 100%;
  }

  /* ── Dropdown Styles (global — targets React island DOM) ── */
  :global(.custom-dropdown) {
    position: relative;
    display: inline-block;
  }

  :global(.custom-dropdown-button) {
    padding: 0.75rem 1.75rem;
    border: 1px solid var(--section-medium-background-color);
    border-radius: 8px;
    background-color: transparent;
    color: var(--white-color-1);
    font-size: var(--font-size-14px);
    font-family: var(--identity-font);
    font-weight: var(--font-weight6);
    cursor: pointer;
    text-decoration: none;
    position: relative;
    text-transform: uppercase;
  }

  :global(.custom-dropdown-button)::after {
    content: '\25BC';
    display: inline-block;
    margin-left: 0.5rem;
    color: var(--white-color-1);
    transform-origin: center;
    transition: transform 0.3s ease;
  }

  :global(.custom-dropdown-menu) {
    position: absolute;
    top: calc(100% + 1px);
    z-index: 1000;
    background-color: var(--section-dark-background-color);
    border: 1px solid var(--section-dark-background-color);
    margin-top: 0;
    padding: 0.5rem 0;
    list-style: none;
    min-width: 180px;
    display: none;
  }

  :global(.custom-dropdown-menu li) {
    background-color: transparent;
    border: none;
    padding: 0.75rem 1.25rem;
    color: var(--white-color-2);
    font-size: var(--font-size-14px);
    cursor: pointer;
    text-transform: uppercase;
    font-family: var(--identity-font);
    font-weight: var(--font-weight6);
    letter-spacing: 0.05rem;
    outline: none;
  }

  :global(.custom-dropdown-menu li[aria-selected="true"]),
  :global(.custom-dropdown-menu li.selected) {
    border-left: 4px solid var(--card-hover, var(--site-start-color));
    color: var(--card-hover, var(--site-start-color));
    background-color: var(--section-darkest-background-color);
  }

  :global(.custom-dropdown-menu li:focus-visible) {
    outline: 2px solid var(--site-start-color);
    outline-offset: -2px;
  }

  /* Locked/open state */
  :global(.custom-dropdown.locked .custom-dropdown-button) {
    box-shadow: 0 0 0 2px currentColor;
  }

  :global(.custom-dropdown.locked .custom-dropdown-button)::after {
    content: '\25B2';
  }

  :global(.custom-dropdown.locked .custom-dropdown-menu) {
    display: block;
  }

  /* Locked button — "All Products" */
  :global(.custom-dropdown.locked .custom-dropdown-button[data-category="all"]) {
    border-color: var(--site-start-color);
    color: var(--site-start-color);
  }

  :global(.custom-dropdown.locked .custom-dropdown-button[data-category="all"])::after {
    color: var(--site-start-color);
  }

  /* Locked button — specific category */
  :global(.custom-dropdown.locked .custom-dropdown-button:not([data-category="all"])) {
    border-color: var(--card-color);
    color: var(--card-color);
  }

  :global(.custom-dropdown.locked .custom-dropdown-button:not([data-category="all"]))::after {
    color: var(--card-color);
  }

  /* Desktop hover interactions */
  @media (hover: hover) and (pointer: fine) {
    :global(.custom-dropdown:hover .custom-dropdown-menu) {
      display: block;
    }

    :global(.custom-dropdown-button[data-category="all"]:hover) {
      border-color: var(--site-start-color);
      color: var(--site-start-color);
    }

    :global(.custom-dropdown-button[data-category="all"]:hover)::after {
      color: var(--site-start-color);
    }

    :global(.custom-dropdown-button:not([data-category="all"]):hover) {
      border-color: var(--card-color);
      color: var(--card-color);
    }

    :global(.custom-dropdown-button:not([data-category="all"]):hover)::after {
      color: var(--card-color);
    }

    :global(.custom-dropdown-menu li:hover) {
      border-left: 4px solid var(--card-hover, var(--site-start-color));
      color: var(--card-hover, var(--site-start-color));
      background-color: var(--section-darkest-background-color);
    }
  }

  /* ── SectionDivider overrides for .top-products ── */
  :global(.section-divider.top-products) {
    margin: 4rem auto 1.75rem auto;
  }

  :global(.section-divider.top-products .section-divider-actions) {
    padding-bottom: 0;
    margin-bottom: 0;
    margin-top: 0;
    overflow: visible !important;
  }

  /* ── Responsive: ≤900px ── */
  @media (max-width: 900px) {
    .home-page-intro {
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 0 0 0;
      background-color: var(--section-darkestdark-background-color);
      order: 3;
    }

    :global(.section-divider.top-products) {
      margin: 0 auto 1.75rem auto;
      width: calc(100% - 3rem);
    }

    .home-page-intro-wrapper {
      display: flex;
      flex-direction: column;
    }

    .home-intro-right {
      margin: 0 auto;
      flex-shrink: 0;
      background-color: var(--section-darkestdarker-background-color);
      contain: unset;
      width: 100%;
      display: flex;
      align-items: center;
    }

    .home-intro-right-title::after {
      display: none;
    }

    .home-intro-right-title {
      padding: 0;
      text-transform: capitalize;
      margin: 1.5rem 0;
      text-align: left;
      background: none;
      border-bottom: none;
      border-top: none;
      font-family: var(--identity-font);
      font-size: var(--ft-30-24);
      letter-spacing: -0.5px;
      color: var(--white-black-color-1);
      font-weight: var(--font-weight8);
      line-height: 1.15;
      width: calc(100% - 3rem);
    }

    .home-tools-wrapper.desktop-tools {
      display: none;
    }

    .home-tools-wrapper.mobile-tools {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem;
      width: calc(100% - 3rem);
      max-width: calc(100% - 3rem);
      margin: 0;
      overflow: hidden;
    }

    /* WHY row-reverse: on mobile, image sits LEFT, text sits RIGHT */
    .home-tools-item {
      flex-direction: row-reverse;
      justify-content: flex-start;
      gap: 0.75rem;
      flex: 1 1 calc(33.333% - 0.75rem);
      min-width: max-content;
      margin-right: 0;
    }

    .home-tools-text-content {
      display: flex;
      flex-direction: row;
      text-overflow: ellipsis;
      margin: 0;
    }

    .home-tools-right-wrapper {
      justify-content: center;
      min-width: 6rem;
    }

    .home-tools-title {
      font-size: var(--ft-18-15);
      color: var(--grey-color-1);
      font-weight: var(--font-weight8);
      margin: 0;
      display: block;
      -webkit-line-clamp: unset;
    }

    .home-tools-description {
      display: none;
    }

    .home-tools-tag {
      font-size: var(--ft-12-11);
    }

    .home-tools-arrow {
      display: flex;
      align-items: center;
    }

    .home-tools-image {
      font-size: var(--ftm-38-35);
      width: 1em;
      color: var(--grey-color-1);
      flex-shrink: 0;
    }

    .home-tools-image :global(svg) {
      fill: var(--grey-color-1);
    }

    .home-tools-row {
      gap: 0.75rem;
    }
  }


  @media (max-width: 600px) {
    :global(.custom-dropdown-button) {
      font-size: var(--fm-14-13);
    }

    :global(.custom-dropdown-menu li) {
      font-size: var(--fm-14-13);
    }

    .home-tools-item {
      flex: 1 1 calc(33.333% - 0.65rem);
      padding: 1rem 4rem 1rem 1.25rem;
    }

    .home-tools-row {
      gap: 0.65rem;
    }

    .home-tools-tag {
      font-size: var(--fm-11-10);
    }

    .home-tools-title {
      font-size: var(--fm-15-14);
    }

    .home-tools-arrow {
      display: none;
    }

    .home-tools-image {
      font-size: var(--fm-35-32);
    }
  }
</style>

