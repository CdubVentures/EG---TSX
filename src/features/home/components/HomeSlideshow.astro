---
/**
 * HomeSlideshow.astro — Full-featured product carousel for the home page.
 * Port of HBS scrollerSlideShow.handlebars + scrollerSlideShow.js + scroller_slideShow.css
 *
 * Renders all slides server-side. Embla Carousel initializes client-side
 * for drag, autoplay, arrows, pause/play, category filtering, lazy loading.
 */
import { getProducts } from '@core/products';
import { getImageWithFallback } from '@core/media';
import { categoryColor, imageDefaults } from '@core/config';
import { contentImage, collectionImagePath } from '@core/images';
import { productUrl } from '@core/product-helpers';
import type { ProductMedia } from '@core/media';
import { resolveSlideshowDeal } from '../slideshow-deal';
import DexaBadge from '@shared/ui/DexaBadge.astro';

// ─── Resolve hero image for a product ────────────────────────────────────────
// WHY: HBS uses hubCards.getImagesArrayXXL + sortImagesForCarousel to pick the
// best hero shot. We replicate this with the structured media object: pick the
// first carousel image by view priority from config.

function pickHero(media: ProductMedia, category: string): { stem: string; objectFit: string } | null {
  const coverChain = imageDefaults(category).coverImageView;
  const hero = getImageWithFallback(media, coverChain);
  if (!hero) return null;
  // WHY: coverImageView targets views best suited for cover display (feature-image, sangle, etc.)
  // viewMeta objectFit is informational — slideshow CSS forces object-fit: cover on .slide-image
  return { stem: hero.stem, objectFit: 'cover' };
}

// ─── Rating bar width calculation (port of HBS calcRatingWidth) ──────────────
function calcRatingWidth(overall: number | string): string {
  const score = parseFloat(String(overall));
  if (isNaN(score)) return '0';
  return (((score + 0.2) / 10) * 100).toFixed(2);
}

// ─── Darken hex color (port of HBS darkenCSSHexHelper) ───────────────────────
function darkenHex(hex: string, factor: number = 0.15): string {
  const h = hex.replace('#', '');
  const r = Math.max(0, Math.round(parseInt(h.substring(0, 2), 16) * (1 - factor)));
  const g = Math.max(0, Math.round(parseInt(h.substring(2, 4), 16) * (1 - factor)));
  const b = Math.max(0, Math.round(parseInt(h.substring(4, 6), 16) * (1 - factor)));
  return `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${b.toString(16).padStart(2, '0')}`;
}

// ─── Build slide data from product collection ────────────────────────────────
interface SlideData {
  slug: string;
  brand: string;
  model: string;
  category: string;
  imagePath: string;
  heroStem: string;
  heroObjectFit: string;
  overall: number;
  snapSubtitle: string;
  brandSlug: string;
  thumbnailStem: string;
  deal: {
    href: string;
    label: 'View Deal' | 'Search Amazon';
    retailer: string;
    slug: string;
    variant?: string;
  } | null;
}

// WHY: Zod schema uses .passthrough() so TS doesn't know about overall/snap_subtitle.
// Narrow once here instead of scattering `as any` everywhere.
interface SlideshowProduct {
  slug: string;
  brand: string;
  model: string;
  category: string;
  imagePath: string;
  media: ProductMedia;
  affiliateLinks?: Array<{
    url?: string;
    retailer?: string;
    slug?: string;
    variant?: string;
    isPrimary?: boolean;
  }>;
  overall?: number | string;
  snap_subtitle?: string;
}

// ─── Load slideshow config ────────────────────────────────────────────────────
// WHY: config/data/slideshow.json is the SSOT for slide order when populated.
// If config is empty or missing, fall back to algorithmic selection (original).
import slideshowConfig from '../../../../config/data/slideshow.json';

const allProducts = await getProducts();
// WHY: filterByActiveCategories (.mjs) strips Astro's CollectionEntry type.
// Cast through unknown to restore .id access for the lookup map.
const productMap = new Map(
  (allProducts as unknown as Array<{ id: string; data: Record<string, unknown> }>)
    .map(p => [p.id, p])
);

// ─── Helper: resolve a product entry → SlideData ─────────────────────────────
function toSlide(p: { id: string; data: Record<string, unknown> }): SlideData | null {
  const d = p.data as unknown as SlideshowProduct;
  if (!d.media?.images?.length) return null;
  const hero = pickHero(d.media, d.category);
  if (!hero) return null;
  const pathParts = d.imagePath.split('/');
  // Resolve thumbnail via data-level fallback chain (Photoshop script guarantees all sizes)
  const viewChain = imageDefaults(d.category).defaultImageView;
  const thumb = getImageWithFallback(d.media, viewChain);
  if (!thumb) return null;

  return {
    slug: d.slug,
    brand: d.brand,
    model: d.model,
    category: d.category,
    imagePath: d.imagePath,
    heroStem: hero.stem,
    heroObjectFit: hero.objectFit,
    overall: parseFloat(String(d.overall || 0)),
    snapSubtitle: d.snap_subtitle || '',
    brandSlug: pathParts[3] || '',
    thumbnailStem: thumb.stem,
    deal: resolveSlideshowDeal(d),
  };
}

// ─── Config-driven selection ─────────────────────────────────────────────────
const configuredSlides: SlideData[] = [];
const configMax = slideshowConfig.maxSlides ?? 10;

for (const entryId of slideshowConfig.slides ?? []) {
  if (configuredSlides.length >= configMax) break;
  const p = productMap.get(entryId);
  if (!p) continue;
  const slide = toSlide(p);
  if (slide) configuredSlides.push(slide);
}

// ─── Algorithmic fallback (original logic) ───────────────────────────────────
function algorithmicSlides(): SlideData[] {
  const typed = allProducts as unknown as Array<{ id: string; data: Record<string, unknown> }>;
  const candidates = typed
    .filter(p => {
      const d = p.data as unknown as SlideshowProduct;
      return d.overall && d.overall !== '' && d.media?.images?.length > 0;
    })
    .map(p => {
      const d = p.data as unknown as SlideshowProduct;
      return { entry: p, overall: parseFloat(String(d.overall)) };
    })
    .filter(c => !isNaN(c.overall))
    .sort((a, b) => b.overall - a.overall);

  const result: SlideData[] = [];
  const catCounts: Record<string, number> = {};
  const MAX_PER_CAT = 5;
  const MAX = 10;

  for (const c of candidates) {
    if (result.length >= MAX) break;
    const d = c.entry.data as unknown as SlideshowProduct;
    const cat = d.category;
    if ((catCounts[cat] || 0) >= MAX_PER_CAT) continue;
    const slide = toSlide(c.entry);
    if (!slide) continue;
    result.push(slide);
    catCounts[cat] = (catCounts[cat] || 0) + 1;
  }
  return result;
}

// WHY: use config slides when available, fall back to algorithmic when empty
const slides = configuredSlides.length > 0 ? configuredSlides : algorithmicSlides();
const slideCount = slides.length;

// Build srcset helper — all sizes for a product image stem, routed through CDN
function srcSet(imagePath: string, stem: string): string {
  const sizes: Array<{ suffix: 'xxs' | 'xs' | 's' | 'm' | 'l' | 'xl' | 'xxl'; w: number }> = [
    { suffix: 'xxs', w: 100 },
    { suffix: 'xs', w: 200 },
    { suffix: 's', w: 400 },
    { suffix: 'm', w: 600 },
    { suffix: 'l', w: 800 },
    { suffix: 'xl', w: 1000 },
    { suffix: 'xxl', w: 2000 },
  ];
  return sizes.map(s => `${contentImage(imagePath, stem, s.suffix)} ${s.w}w`).join(', ');
}
---

<section class="home-top-slides-wrapper">
  <div class="home-top-slides" data-slideshow>

    {/* ── Embla track: first child = Embla container ── */}
    <div class="slideshow-track">
      {slides.map((slide, idx) => {
      const catHex = categoryColor(slide.category);
      const catDark = darkenHex(catHex, 0.15);
      const ratingWidth = calcRatingWidth(slide.overall);
      const isFirst = idx === 0;
      const heroSrc = contentImage(slide.imagePath, slide.heroStem, 'l');
      const heroSrcSet = srcSet(slide.imagePath, slide.heroStem);
      const brandLogoPath = contentImage(collectionImagePath('brands', slide.brandSlug), 'brand-logo-horizontal-mono-black', 'xs', 'png');

      const productHref = productUrl(slide);
      const dealAriaLabel = slide.deal?.label === 'Search Amazon'
        ? `Search Amazon for ${slide.brand} ${slide.model}`
        : `View deal on ${slide.deal?.retailer ?? 'retailer'}${slide.deal?.variant ? ` (${slide.deal.variant})` : ''}`;

      return (
        <div
          class={`slide-anchor ${slide.category}-color ${isFirst ? 'is-active' : ''}`}
          data-category={slide.category}
          data-slide-index={idx}
          data-id={slide.slug}
          draggable="false"
        >
          {/* Main image area */}
          <div class="image-stretch-container">

            {/* Scoring badges (top-left) */}
            <div class="scoring-wrapper-top">
              <div class="scoring-wrapper">
                {slide.overall ? (
                  <DexaBadge score={slide.overall} />
                ) : null}
              </div>

              {/* Compare toggle (top-right) — hydrated by initCarousel via hydrateVaultToggles.
                   WHY no client:load: Embla cloneNode(true) destroys Astro hydration targets.
                   Static HTML here is the initial paint; React mounts on the clones. */}
              <div
                class="vault-toggle-slot"
                data-vault-product={JSON.stringify({
                  id: slide.slug,
                  slug: slide.slug,
                  brand: slide.brand,
                  model: slide.model,
                  category: slide.category,
                  imagePath: slide.imagePath,
                  thumbnailStem: slide.thumbnailStem,
                })}
              >
                <div
                  class={`compare-toggle ${slide.category}-color`}
                  data-id={slide.slug}
                  data-category={slide.category}
                  data-vault-mount
                >
                  <input
                    type="checkbox"
                    class="compare-checkbox"
                    id={`compare-${slide.category}-${slide.slug}`}
                    aria-label={`Add ${slide.model} to vault`}
                  />
                  <label for={`compare-${slide.category}-${slide.slug}`} class="compare-label">
                    <span class="compare-text">COMPARE</span>
                    <span class="compare-symbol">
                      <span class="compare-sym-slot">
                        <svg class="compare-icon compare-icon-plus" viewBox="0 0 16 16" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                          <line x1="8" y1="4.5" x2="8" y2="11.5" />
                          <line x1="4.5" y1="8" x2="11.5" y2="8" />
                        </svg>
                      </span>
                    </span>
                  </label>
                </div>
              </div>
            </div>

            {/* Hero image — first slide eager, rest lazy via data-src */}
            <a
              class="slide-image-link"
              href={productHref}
              aria-label={`Learn more about ${slide.brand} ${slide.model}`}
            >
              {isFirst ? (
                <img
                  fetchpriority="high"
                  loading="eager"
                  src={heroSrc}
                  srcset={heroSrcSet}
                  sizes="(min-width: 825px) 625px, 100vw"
                  alt={`${slide.brand} ${slide.model} Hero Shot`}
                  class="slide-image"
                  style={`object-fit: ${slide.heroObjectFit};`}
                  draggable="false"
                />
              ) : (
                <img
                  data-src={heroSrc}
                  data-srcset={heroSrcSet}
                  data-sizes="(min-width: 825px) 625px, 100vw"
                  alt={`${slide.brand} ${slide.model} Hero Shot`}
                  class="slide-image"
                  style={`object-fit: ${slide.heroObjectFit};`}
                  draggable="false"
                />
              )}
            </a>

            {/* Deal CTA (overlaid bottom of image) */}
            {slide.deal ? (
              <div class={`wrapper-cta-details ${slide.category}-color`}>
                <button
                  class="slide-deal-cta"
                  type="button"
                  data-deal-href={slide.deal.href}
                  aria-label={dealAriaLabel}
                  title={dealAriaLabel}
                >
                  <span class="slide-deal-label">{slide.deal.label}</span>
                </button>
              </div>
            ) : null}
          </div>

          {/* Slide details bar */}
          <a class="wrapper-details" href={productHref}>
            <div
              class="detail-container"
              style={`background: ${catHex};`}
            >
              <div class="detail-title-wrapper">
                <div class="detail-title">
                  <h3 class="brand-text">{slide.brand} {slide.model}</h3>
                  {isFirst ? (
                    <img
                      loading="eager"
                      src={brandLogoPath}
                      alt={`${slide.brand} Logo`}
                      class="slideShow-brand-logo"
                      onerror="this.style.display='none'"
                    />
                  ) : (
                    <img
                      data-src={brandLogoPath}
                      alt={`${slide.brand} Logo`}
                      class="slideShow-brand-logo"
                      onerror="this.style.display='none'"
                    />
                  )}
                </div>
              </div>
              <div class="detail-title slide-bottom-text">
                <h4 class="slide-sub-text">
                  {slide.snapSubtitle || `${slide.brand} ${slide.model} gaming ${slide.category}`}
                </h4>
                <div class="learn-more-link">Learn More</div>
              </div>
              {/* Rating bar */}
              <div class="rating-bar">
                <span class="rating-value">{slide.overall}</span>
                <div
                  class="rating-fill"
                  style={`width: ${ratingWidth}%; background: linear-gradient(180deg, ${catHex}, ${catDark});`}
                ></div>
                <div class="rating-separators">
                  {Array.from({ length: 12 }).map(() => <div class="separator"></div>)}
                </div>
              </div>
            </div>
          </a>
        </div>
      );
    })}
    </div>{/* close .slideshow-track */}

    {/* ── Overlay: arrows + counter + pause (absolute, over the track) ── */}
    <div class="overlay-wrapper-main">
      <div class="overlay-wrapper-btns">
        <div class="slide-arrow-container-wrapper">
          {/* Left arrow */}
          <button type="button" class="slide-card-carousel-arrow-container left-arrow" aria-label="Previous slide">
            <div class="slide-card-carousel-circle-left">
              <div class="slide-card-carousel-arrow">
                <svg aria-hidden="true" focusable="false" height="16" class="svg-base" viewBox="0 0 16 16" width="16" xmlns="http://www.w3.org/2000/svg">
                  <path fill="currentColor" d="M2.38 7.784 8.796 1.37l1.414 1.414-5 5 5 5-1.414 1.414z"></path>
                </svg>
              </div>
            </div>
          </button>
          {/* Right arrow */}
          <button type="button" class="slide-card-carousel-arrow-container right-arrow" aria-label="Next slide">
            <div class="slide-card-carousel-circle-right">
              <div class="slide-card-carousel-arrow">
                <svg aria-hidden="true" focusable="false" height="16" class="svg-base" viewBox="0 0 16 16" width="16" xmlns="http://www.w3.org/2000/svg">
                  <path fill="currentColor" d="m13.21 7.784-6.415 6.414-1.414-1.414 5-5-5-5L6.795 1.37z"></path>
                </svg>
              </div>
            </div>
          </button>
        </div>

        {/* Slide counter + pause button */}
        <div class="slide-info-overlay">
          <div class="slide-count-container" aria-live="polite">
            <span class="current-slide-number">1</span>
            <span class="count-separator">of</span>
            <span class="total-slides">{slideCount}</span>
          </div>
          <button type="button" class="pause-button" aria-label="Pause slideshow">
            <span class="pause-icon">
              <span class="bars">
                <svg viewBox="-45 0 327 327" xmlns="http://www.w3.org/2000/svg" fill="white" width="100%" height="100%" class="svg-base">
                  <path d="m158 0h71c4.417969 0 8 3.582031 8 8v311c0 4.417969-3.582031 8-8 8h-71c-4.417969 0-8-3.582031-8-8v-311c0-4.417969 3.582031-8 8-8zm0 0"></path>
                  <path d="m8 0h71c4.417969 0 8 3.582031 8 8v311c0 4.417969-3.582031 8-8 8h-71c-4.417969 0-8-3.582031-8-8v-311c0-4.417969 3.582031-8 8-8zm0 0"></path>
                </svg>
              </span>
              <span class="arrow">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="white" width="100%" height="100%" class="svg-base">
                  <path d="M4 2v20l16-10z"></path>
                </svg>
              </span>
            </span>
          </button>
        </div>
      </div>

      {/* Transparent detail placeholder (reserves layout space before Embla mounts) */}
      <div class="wrapper-details wrapper-details-transparent">
        <div class="detail-container">
          <div class="detail-title-wrapper">
            <div class="detail-title">
              <h3 class="brand-text">&nbsp;</h3>
            </div>
          </div>
          <div class="detail-title slide-bottom-text">
            <h4 class="slide-sub-text">&nbsp;</h4>
          </div>
          <div class="rating-bar">
            <span class="rating-value">&mdash;</span>
            <div class="rating-fill" style="width:50%;background:transparent;"></div>
            <div class="rating-separators">
              {Array.from({ length: 12 }).map(() => <div class="separator"></div>)}
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  import { initSlideshow } from '../slideshow-carousel';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initSlideshow());
  } else {
    initSlideshow();
  }
</script>

<style is:global>
  /* ══════════════════════════════════════════════════════════════════════════════
     HOME SLIDESHOW — Port of scroller_slideShow.css
     ══════════════════════════════════════════════════════════════════════════════ */

  /* ── Container ── */
  .home-top-slides {
    position: relative;
    width: clamp(500px, 363.6364px + 22.7273vw, 625px);
    height: clamp(380px, 276.3636px + 17.2727vw, 475px);
    margin: 0 auto;
    overflow: hidden;
    box-sizing: border-box;
    z-index: 1;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    border-radius: 0;
  }

  /* ── Slideshow track: Embla uses this as the container (flex row of slides) ── */
  .slideshow-track {
    display: flex;
    width: 100%;
    height: 100%;
  }

  /* ── Slide anchor ── */
  .slide-anchor {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 0 0 100%;
    min-width: 0;
    width: 100%;
    height: 100%;
    margin-right: clamp(8px, 3.7333px + 1.0667vw, 16px);
    background-color: #1d2021 /* always-dark: slideshow overlays photos */;
    cursor: pointer;
    user-select: none;
    -webkit-user-drag: none;
    text-decoration: none;
  }

  .slide-anchor.dragging { transition: none; }

  .blurred-image {
    pointer-events: none;
  }

  /* ── Image stretch container ── */
  .image-stretch-container {
    flex: 1 1 auto;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-items: center;
    margin: 0;
    padding: 0;
    width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  .slide-image-link {
    position: absolute;
    inset: 0;
    display: block;
    text-decoration: none;
  }

  /* ── Slide image ── */
  .home-top-slides .slide-image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Wrapper details (bottom bar) ── */
  .wrapper-details {
    flex: 0 0 auto;
    width: 100%;
    height: auto;
    overflow: hidden;
    z-index: 1000;
    text-decoration: none;
    color: inherit;
  }

  .detail-container {
    position: relative;
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    box-sizing: border-box;
    z-index: 3000;
    padding: .65rem 1.65rem 1.35rem 1.65rem;
    font-family: var(--identity-font);
    letter-spacing: 0px;
    text-align: left;
    cursor: pointer;
    width: 100%;
    max-width: 100%;
    box-shadow: none;
    pointer-events: auto;
  }

  .detail-title-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    box-sizing: border-box;
    flex-wrap: wrap;
    width: 100%;
    column-gap: 1rem;
    justify-content: space-between;
  }

  .detail-title {
    display: flex;
    width: 100%;
    min-width: 0;
    overflow: hidden;
    justify-content: space-between;
    align-items: center;
    font-size: clamp(var(--font-size-24px), 1.325rem + 1.143vw, var(--font-size-26px));
  }

  /* Brand logo in slide detail bar */
  .slideShow-brand-logo {
    position: relative !important;
    z-index: 9999;
    height: calc(1em * 1.1);
    filter: brightness(0) invert(1);
  }

  .detail-container .brand-text {
    font-weight: var(--font-weight7);
    letter-spacing: -.5px !important;
    font-family: var(--identity-font);
    color: var(--color-text-on-accent);
    line-height: 1.4;
    display: inline-block;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    box-sizing: border-box;
    text-overflow: ellipsis;
    text-transform: capitalize;
  }

  .slide-bottom-text { margin-bottom: .55rem; }

  .detail-container .slide-sub-text {
    font-size: clamp(var(--font-size-18px), 0.779rem + 1.143vw, var(--font-size-20px));
    font-weight: var(--font-weight4);
    letter-spacing: -.5px !important;
    font-family: var(--identity-font);
    color: var(--color-text-on-accent);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis !important;
    margin-right: 1rem;
  }

  .learn-more-link {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    width: auto;
    margin: 0;
    margin-right: .5rem;
    padding: 0;
    font-size: clamp(var(--font-size-17px), 1.117rem + 0.571vw, var(--font-size-18px));
    color: var(--color-text-on-accent);
    text-decoration: none;
    text-align: left;
    font-weight: 400;
    letter-spacing: -.5px;
    position: relative;
  }

  .learn-more-link::after {
    content: '\276F';
    position: relative;
    font-family: var(--identity-font);
    font-weight: 400;
    color: var(--color-text-on-accent);
    margin-left: .5rem;
    line-height: .9;
    font-size: clamp(var(--font-size-17px), 1.117rem + 0.571vw, var(--font-size-18px));
  }

  /* Hover underline on slide text */
  .slide-anchor:hover .detail-container .brand-text,
  .slide-anchor:hover .detail-container .slide-sub-text,
  .slide-anchor:hover .detail-container .learn-more-link {
    text-decoration-line: underline;
    text-decoration-thickness: 1.25px;
    text-decoration-color: var(--color-text-on-accent);
    text-underline-offset: 2px;
  }

  /* ── Rating bar ── */
  .rating-bar {
    position: relative;
    width: calc(100% - .1rem) !important;
    height: clamp(var(--font-size-23px), 18.2857px + 0.5714vw, var(--font-size-24px)) !important;
    background-color: #646464;
    border-radius: 2px;
    overflow: hidden;
    margin-left: 0rem !important;
    margin-bottom: .1rem;
    box-shadow: inset 0 0 2px rgba(0, 0, 0, 0.6), 0 1px 2px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(0, 0, 0, 0.5);
  }

  .rating-fill {
