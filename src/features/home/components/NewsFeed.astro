---
/**
 * NewsFeed.astro — Right sidebar: "News Feed" title + 3 news items with thumbnails.
 * Faithful port of HBS scroller_dashboard.css .newsfeed-right section (lines 916–1149).
 */
import { articleUrl, resolveHero, articleSrcSet, formatArticleDate } from '@core/article-helpers';
import type { DashboardEntry } from '@core/article-helpers';

interface Props {
  items: DashboardEntry[];
}

const { items } = Astro.props;
---

<div class="newsfeed-right">
  <a href="/news/" class="newsfeed-right-title">News Feed</a>
  <div class="newsfeed-wrapper">
    {items.map((item) => {
      const url = articleUrl(item._collection, item.id);
      const heroPath = item.data.hero
        ? resolveHero(item._collection, item.id, item.data.hero)
        : null;
      return (
        <a href={url} class="newsfeed-item">
          <div class="newsfeed-text-content">
            <h3 class="newsfeed-title">{item.data.title}</h3>
            <p class="newsfeed-date item-date">
              {formatArticleDate(item.data.datePublished, item.data.dateUpdated)}
            </p>
          </div>
          {heroPath && (
            <div class="newsfeed-image">
              <img
                loading="eager"
                src={`${heroPath}_xs.webp`}
                srcset={articleSrcSet(heroPath)}
                sizes="(min-width: 825px) 140px, 200px"
                alt={item.data.title}
                class="latestnews-image"
              />
            </div>
          )}
        </a>
      );
    })}
  </div>
</div>

<style>
  /* ── News Feed sidebar ── */
  .newsfeed-right {
    display: flex;
    flex-direction: column;
    contain: size;
    min-height: 0;
    width: calc(42.5% - 1rem);
    flex: 1;
    box-sizing: border-box;
  }

  .newsfeed-right-title {
    position: relative;
    text-align: center;
    font-weight: var(--font-weight8);
    font-family: var(--identity-font);
    color: var(--white-color-1);
    letter-spacing: -0.5px;
    line-height: 1;
    font-size: var(--font-size-20px);
    text-transform: uppercase;
    padding: 1rem 1.25rem;
    background: none;
    border-bottom: 1px solid var(--section-medium-background-color);
    border-top: 1px solid var(--section-medium-background-color);
    text-decoration: none;
  }

  .newsfeed-right:hover .newsfeed-right-title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Down-arrow triangle */
  .newsfeed-right-title::after {
    content: '';
    position: absolute;
    bottom: -0.7rem;
    left: 80%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 0.7rem solid transparent;
    border-right: 0.7rem solid transparent;
    border-top: 0.7rem solid var(--section-medium-background-color);
  }

  /* ── News items list ── */
  .newsfeed-wrapper {
    display: flex;
    flex-direction: column;
    width: auto;
    margin-top: 1.25rem;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .newsfeed-item {
    position: relative;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    text-decoration: none;
    color: var(--white-color-1);
    border-bottom: 1px solid var(--section-light-background-color);
    margin: 0 1rem;
    padding: 1rem 0 1.25rem 0;
    box-sizing: border-box;
  }

  .newsfeed-item:last-child {
    border-bottom: none;
  }

  .newsfeed-item:hover .newsfeed-title {
    text-decoration: underline;
    text-decoration-color: var(--white-black-color-1);
    text-decoration-thickness: 1.25px;
    text-underline-offset: 1.25px;
  }

  /* ── Text content (left) ── */
  .newsfeed-text-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    margin-right: 1.15rem;
    text-overflow: ellipsis;
    justify-content: center;
  }

  .newsfeed-title {
    font-size: var(--font-size-17px);
    font-family: var(--identity-font);
    font-weight: var(--font-weight7);
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
    letter-spacing: -0.5px;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--white-black-color-1);
  }

  .newsfeed-date {
    color: var(--grey-color-3);
    margin: 0;
  }

  /* ── Thumbnail (right) ── */
  .newsfeed-image {
    max-width: 135px;
    overflow: hidden;
    padding: 2px;
  }

  .newsfeed-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 16/10;
    object-fit: cover;
    border-radius: 4px;
    flex-grow: 1;
    overflow: hidden;
  }

  /* ── ≤825px: stacks below hero, horizontal card list ── */
  @media (max-width: 825px) {
    .newsfeed-right {
      contain: unset;
      width: 100%;
      order: 3;
      margin: 0 auto;
      max-height: 100%;
      flex-shrink: 0;
    }

    .newsfeed-wrapper {
      background-color: var(--section-dark-background-color);
      border-radius: 6px;
      margin-top: 1rem;
      gap: 0;
      padding: 0.25rem;
      box-shadow: var(--card-shadow);
    }

    /* Show only first 3 items */
    .newsfeed-wrapper > :nth-child(n+4) {
      display: none;
    }

    .newsfeed-wrapper > :nth-child(n+3) {
      border-bottom: none;
    }

    .newsfeed-text-content {
      justify-content: center;
      min-width: 15rem;
    }

    .newsfeed-right-title::after {
      display: none;
    }

    .newsfeed-item {
      padding: 1rem 0;
      margin: 0 1.5rem;
    }

    .newsfeed-right-title {
      margin-top: 3rem;
      font-size: var(--ft-30-24);
      padding: 0 0 1rem 0;
      text-align: left;
      border-bottom: none;
      border-top: none;
      text-transform: capitalize;
    }

    .newsfeed-title {
      font-size: var(--ftm-17-16);
      line-height: 1.3;
    }

    .newsfeed-image {
      max-width: clamp(125px, 54.4118px + 17.6471vw, 200px);
      min-width: clamp(125px, 54.4118px + 17.6471vw, 200px);
    }
  }

  /* ── ≤600px: smaller text ── */
  @media (max-width: 600px) {
    .newsfeed-title {
      font-size: var(--fm-16-15);
      line-height: 1.3;
    }
  }
</style>
