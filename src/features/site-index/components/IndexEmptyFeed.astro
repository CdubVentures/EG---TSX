---
/**
 * IndexEmptyFeed — placeholder shown when all articles are consumed by the dashboard hero.
 * Displays a professional SVG illustration with "More Coming Soon" messaging.
 * WHY: When a category has 1–2 articles, all go to the dashboard hero section,
 * leaving the feed empty. This placeholder fills that space gracefully.
 */

interface Props {
  typeLabel: string;
  dashboardCount: number;
}

const { typeLabel, dashboardCount } = Astro.props;
const selectionWord = dashboardCount === 1 ? 'selection' : 'selections';
---

<div class="empty-feed">
  <div class="empty-feed__inner">
    {/* WHY: Inline SVG uses currentColor + CSS vars so it themes automatically */}
    <svg
      class="empty-feed__icon"
      viewBox="0 0 120 120"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      {/* Outer ring */}
      <circle cx="60" cy="60" r="54" stroke="currentColor" stroke-width="1.5" opacity="0.15" />
      <circle cx="60" cy="60" r="42" stroke="currentColor" stroke-width="1" opacity="0.1" />

      {/* Document stack — three stacked rectangles */}
      <rect x="38" y="44" width="44" height="36" rx="3" stroke="currentColor" stroke-width="1.5" opacity="0.25" />
      <rect x="34" y="40" width="44" height="36" rx="3" stroke="currentColor" stroke-width="1.5" opacity="0.35" fill="var(--section-dusk-background-color)" />
      <rect x="30" y="36" width="44" height="36" rx="3" stroke="currentColor" stroke-width="2" opacity="0.6" fill="var(--section-dusk-background-color)" />

      {/* Content lines on front document */}
      <line x1="38" y1="48" x2="62" y2="48" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.4" />
      <line x1="38" y1="54" x2="56" y2="54" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.25" />
      <line x1="38" y1="59" x2="60" y2="59" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.25" />

      {/* Plus badge — bottom-right */}
      <circle cx="82" cy="78" r="14" fill="var(--site-start-color, #4a9ced)" opacity="0.85" />
      <line x1="82" y1="72" x2="82" y2="84" stroke="var(--color-text-on-accent)" stroke-width="2.5" stroke-linecap="round" />
      <line x1="76" y1="78" x2="88" y2="78" stroke="var(--color-text-on-accent)" stroke-width="2.5" stroke-linecap="round" />
    </svg>

    <h3 class="empty-feed__heading">More {typeLabel} Coming Soon</h3>
    <p class="empty-feed__sub">
      For now, you have {dashboardCount} great {selectionWord} above.
    </p>
  </div>
</div>

<style>
  .empty-feed {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 260px;
    padding: 48px 24px;
  }

  .empty-feed__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 400px;
  }

  .empty-feed__icon {
    width: 120px;
    height: 120px;
    color: var(--grey-color-1);
    margin-bottom: 8px;
  }

  .empty-feed__heading {
    margin: 0;
    font-family: var(--identity-font, inherit);
    font-weight: var(--font-weight8, 800);
    font-size: var(--ft-22-18);
    line-height: 1.2;
    color: var(--color-text-primary, var(--white-color-1));
    letter-spacing: -0.3px;
  }

  .empty-feed__sub {
    margin: 0;
    font-size: var(--ft-15-13);
    line-height: 1.4;
    color: var(--grey-color-1);
    opacity: 0.75;
  }
</style>
