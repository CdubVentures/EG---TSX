---
/**
 * IndexDashboard — 1/2/3-slot hero layout for site-index pages (reviews, news, guides).
 * Port of HBS site-top-dashboard.handlebars + feed_moreof.css .moreof-hf grid.
 *
 * Layouts by item count:
 *   3: [ HERO (65%) | RIGHT COLUMN (35%) with 2 stacked side cards ] + ad rail
 *   2: [ HERO (65%) | RIGHT COLUMN (35%) with 1 full-height card ] + ad rail
 *   1: [ HERO (100%) ] + ad rail
 */
import type { FeaturedItem } from '@features/home/featured-scroller-utils';
import IndexHeroCard from './IndexHeroCard.astro';
import IndexSideCard from './IndexSideCard.astro';
import AdSlot from '@features/ads/components/AdSlot.astro';

interface Props {
  items: FeaturedItem[];
  type: 'reviews' | 'news' | 'guides';
}

const { items, type } = Astro.props;

const heroItem = items[0];
const sideItems = items.slice(1, 3);
const itemCount = items.length;
---

{items.length > 0 && (
  <section class="moreof-hf" data-feed-kind="type-dashboard" data-layout="horizontal">
    <div class="moreof-hf__grid">
      <div class="moreof-hf__stageFlex" data-count={itemCount}>
        {heroItem && <IndexHeroCard item={heroItem} />}

        {sideItems.length > 0 && (
          <div class="moreof-hf__rightCol">
            {sideItems.map(item => (
              <IndexSideCard item={item} />
            ))}
          </div>
        )}
      </div>

      <aside class="moreof-rail-ad" aria-label="Advertisement">
        <AdSlot position="sidebar" />
      </aside>
    </div>
  </section>
)}

<style>
  /* Port of feed_moreof.css — grid + stage layout */
  .moreof-hf {
    margin-bottom: 0;
  }

  .moreof-hf__grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 30px;                       /* HBS: [data-ad-rail="right"] gap is 30px */
    align-items: start;
  }

  .moreof-hf__stageFlex {
    display: flex;
    align-items: stretch;
    gap: clamp(10px, -0.9091px + 1.8182vw, 20px);
    min-width: 0;
    height: clamp(380px, 271.1111px + 15.5556vw, 450px);
  }

  /* Right column: two stacked side cards (default 3-item layout) */
  .moreof-hf__rightCol {
    flex: 0 1 35%;
    max-width: 420px;
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: clamp(10px, -0.9091px + 1.8182vw, 20px);
    align-items: stretch;
    height: 100%;
  }

  /* WHY: 1 article — hero fills full width, no right column */
  .moreof-hf__stageFlex[data-count="1"] :global(.moreof-hero__wrap) {
    flex: 1 1 100%;
  }

  /* WHY: 2 articles — single side card fills full right column height */
  .moreof-hf__stageFlex[data-count="2"] .moreof-hf__rightCol {
    grid-template-rows: 1fr;
  }

  /* Ad rail — HBS: feed_moreof_side.css .moreof-rail-ad
     WHY sidebar (not sidebar_sticky) — this slot is height-constrained to the hero;
     the sticky rail goes in the body grid below (future phase).
     WHY max-height + overflow:clip — ad must never exceed the hero/stageFlex height.
     WHY min-height: CLS reservation — prevents layout shift when ad loads. */
  .moreof-rail-ad {
    width: 300px;
    max-width: 300px;
    min-width: 0;
    min-height: 250px;
    max-height: clamp(380px, 271.1111px + 15.5556vw, 450px);
    overflow: clip;
  }

  /* ── Responsive: hide rail ≤1150px ── */
  @media (max-width: 1150px) {
    .moreof-hf__grid {
      grid-template-columns: 1fr;
    }

    .moreof-rail-ad {
      display: none;
    }

    .moreof-hf__rightCol {
      max-width: 380px;
    }
  }

  /* ── Responsive: phone stack ≤700px ── */
  @media (max-width: 700px) {
    .moreof-hf__stageFlex {
      flex-direction: column;
      gap: clamp(12px, 2.5vw, 16px);
      max-height: none;
      height: unset;
    }

    .moreof-hf__rightCol {
      display: flex;
      flex-direction: column;
      gap: clamp(12px, 2.5vw, 16px);
      flex: 1 1 auto;
      min-width: 0;
      max-width: none;
      width: 100%;
    }
  }

  /* ── Responsive: phone tile sizing ≤600px ── */
  @media (max-width: 600px) {
    .moreof-hf__rightCol {
      min-width: 0;
      max-width: none;
      width: 100%;
      grid-template-rows: auto auto;
    }
  }
</style>
