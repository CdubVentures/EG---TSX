---
/**
 * DexaBadge.astro — Reusable hexagon score badge.
 *
 * Port of HBS renderDexa(): SVG hex frame with category-gradient fill,
 * score number centered at 45% from top, and a "core" section below
 * (two white bars flanking the EG logo).
 *
 * Sizing: Container sets `--dexa-size` CSS variable. The badge reads
 * `font-size: var(--dexa-size, 1.875rem)` and all internal dimensions
 * are em-based, so the whole badge scales from one font-size value.
 */
import { formatScore, scoreLetterSpacing, makeGradientId } from './dexa-badge-logic.mjs';

interface Props {
  score: number | string;
  class?: string;
}

const { score, class: className } = Astro.props;
const { text, render } = formatScore(score);
if (!render) return;

const spaceFix = scoreLetterSpacing(score);
const gradId = makeGradientId();
---

<div class:list={['dexa', className]}>
  <svg class="dexa-frame" viewBox="0 0 14 16" width="16" height="16" aria-hidden="true">
    <defs>
      <linearGradient id={gradId} x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" style="stop-color: var(--card-score-start, var(--site-start-color));" />
        <stop offset="100%" style="stop-color: var(--card-score-end, var(--site-end-color));" />
      </linearGradient>
    </defs>
    {/* Outer hex (white frame) */}
    <path d="M7,0l7,4v8l-7,4L0,12V4Z" fill="#ffffff" />
    {/* Inner hex (category gradient fill) */}
    <path d="M7,0.8l6.2,3.5v7.4l-6.2,3.5L0.8,11.7V4.3Z" fill={`url(#${gradId})`} />
  </svg>

  <span class="dexa-score" style={spaceFix}>{text}</span>

  <div class="dexa-core">
    {/* White bar (left) */}
    <svg class="dexa-bar" viewBox="0 0 140 30" preserveAspectRatio="none" aria-hidden="true">
      <rect width="140" height="30" fill="#fff" />
    </svg>

    {/* EG logo (inline, self-contained) */}
    <svg class="dexa-logo" viewBox="0 0 343 340" aria-hidden="true">
      <path d="M.31,152V0h342.69v156c-.56-.07-1.83.2-1.97,0-.35-.49-1.15-10.12-2.02-11.99h-161.85v52l159.37-.99c3.28-.64,4-9.22,4.52-12.53.29-1.86-1.26-4.05,1.97-3.49v161h-157.86l30.19-6.28c40.15-11.09,78.1-39.69,99.5-75.41,4.45-7.43,10.36-16.56,10.18-25.31h-86.42c-.95,0-11.05,10.6-14.17,12.81-13.87,9.82-31.61,15.38-48.23,18.23l.95,75.96H.31v-154c3.59,18.55,7.38,36.01,15.13,53.36,25.75,57.62,81.1,97.09,144.73,99.64v-76c-64.32-7.01-99.9-72.77-74.4-131.97,13-30.18,41.9-50.33,74.4-54.03V1Z" fill="none" />
      <path fill="#ffffff" d="M.31,152c2.07-23.08,13.32-52.35,25.56-71.92C53.48,35.97,107.35,1.3,160.17,1v76c-32.5,3.7-61.4,23.85-74.4,54.03-25.5,59.19,10.08,124.96,74.4,131.97v76c-63.63-2.55-118.98-42.02-144.73-99.64-7.75-17.35-11.54-34.81-15.13-53.36.72-11-.97-23.15,0-34Z" />
      <path fill="#ffffff" d="M177.15,340l-.95-75.96c16.62-2.85,34.36-8.41,48.23-18.23,3.12-2.21,13.22-12.81,14.17-12.81h86.42c.17,8.75-5.73,17.88-10.18,25.31-21.4,35.72-59.35,64.32-99.5,75.41l-30.19,6.28h-7.99Z" />
      <path d="M343,179c-3.23-.57-1.67,1.63-1.97,3.49-.52,3.31-1.24,11.88-4.52,12.53l-159.37.99v-52h161.85c.87,1.87,1.67,11.5,2.02,11.99.15.2,1.41-.06,1.97,0v23Z" fill="#e6e7e9" />
      <path fill="#ffffff" d="M326.02,107h-87.42c-16.59-16.63-37.89-27.6-61.44-30V1c64.96,1.49,126.51,44.97,148.87,106Z" />
    </svg>

    {/* White bar (right) */}
    <svg class="dexa-bar" viewBox="0 0 140 30" preserveAspectRatio="none" aria-hidden="true">
      <rect width="140" height="30" fill="#fff" />
    </svg>
  </div>
</div>

<style>
  /* ── DexaBadge scoped styles (ported from HBS site_shared.css) ── */
  .dexa {
    position: relative;
    width: 2.55em;
    line-height: 0;
    z-index: 2;
    font-size: var(--dexa-size, 1.875rem);
  }

  .dexa-frame {
    width: 100%;
    height: auto;
    display: block;
  }

  .dexa-score {
    position: absolute;
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 1em;
    color: #fff;
    text-shadow: 0 0 8px rgba(0, 0, 0, 0.43);
    font-family: var(--identity-font);
    font-weight: var(--font-weight8);
    line-height: 1;
    letter-spacing: -0.5px;
    z-index: 2;
  }

  .dexa-core {
    position: absolute;
    top: calc(52.5% + 0.5em);
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex: 1 0 auto;
    align-items: center;
    gap: 0;
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.43));
    z-index: 2;
    overflow: hidden;
  }

  .dexa-logo {
    width: 0.35em !important;
    height: auto !important;
    fill: #ffffff;
  }

  .dexa-bar {
    width: 0.2em !important;
    height: 0.05em !important;
    min-height: 1px !important;
    display: block !important;
    flex: 0 0 auto;
    aspect-ratio: unset;
  }

  .dexa-bar:first-child {
    margin-right: 0.075em;
  }

  .dexa-bar:last-child {
    margin-left: 0.075em;
  }
</style>
