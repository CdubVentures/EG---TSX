---
/**
 * SectionDivider.astro — Section heading with title, subtitle, and actions slot.
 * Faithful port of HBS site_shared.css .section-divider (lines 418–622).
 */
interface Props {
  title: string;
  titleHref?: string;
  subtitle?: string;
  seeMoreHref?: string;
  class?: string;
}

const { title, titleHref, subtitle, seeMoreHref, class: className } = Astro.props;
---

<div class:list={['section-divider', className]}>
  <div class="section-divider-heading">
    <h2 class="section-divider-title">
      {titleHref ? (
        <a href={titleHref} class="section-divider-link" aria-label={title}>{title}</a>
      ) : (
        title
      )}
    </h2>
    {subtitle && <span class="section-divider-subtitle">{subtitle}</span>}
  </div>
  <div class="section-divider-actions">
    {seeMoreHref && (
      <a href={seeMoreHref} class="section-divider-link" aria-label={`See more ${title}`}>See More</a>
    )}
    <slot name="actions" />
  </div>
</div>

<style is:global>
  /* ── Base layout ── */
  /* WHY is:global: section-divider classes are shared UI used inline by
     FeaturedScroller (filter tabs) and potentially other components.
     Scoped styles only apply to elements rendered inside this component,
     but these classes need to work in any context. */
  .section-divider {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin: var(--section-gap) auto 2.25rem auto;
    max-width: var(--home-width);
    row-gap: 0.5rem;
  }

  .section-divider-heading {
    flex: 1 1 auto;
    min-width: 0;
    margin: 0 1rem 0 0;
  }

  .section-divider-title {
    font-family: var(--identity-font);
    font-size: var(--ft-34-28);
    letter-spacing: -0.75px;
    color: var(--white-black-color-1);
    font-weight: 900;
    margin: 0;
    line-height: 1.3;
  }

  .section-divider-subtitle {
    font-size: var(--ftm-15-13);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    color: var(--grey-color-3);
    margin: 0;
    line-height: 1.4;
    letter-spacing: -0.25px;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
    display: block;
  }

  /* ── Actions area ── */
  .section-divider-actions {
    flex: 0 1 auto;
    display: flex;
    gap: 4px;
    white-space: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    margin-top: 1rem;
    margin-bottom: -6px;
    padding-bottom: 6px;
    scrollbar-width: thin;
    scrollbar-color: var(--scrollbar-thumb) transparent;
  }

  .section-divider-actions::-webkit-scrollbar {
    height: 6px;
  }

  .section-divider-actions::-webkit-scrollbar-track {
    background: transparent;
  }

  .section-divider-actions::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 4px;
  }

  /* ── Title link with caret (inside .section-divider-title) ── */
  .section-divider-title .section-divider-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font: inherit;
    color: var(--white-color-1);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.18s ease, transform 0.12s ease, background 0.18s ease;
    will-change: color, transform, background;
  }

  .section-divider-title .section-divider-link::after {
    content: "›";
    display: inline-block;
    line-height: 1;
    font-weight: 500;
    font-size: 1.6em;
    margin-left: 0.1rem;
    transform: translateY(-0.04em);
    color: var(--site-color);
    transition: transform 0.14s ease, color 0.18s ease;
  }

  .section-divider-title .section-divider-link:hover {
    color: var(--site-color);
  }

  .section-divider-title .section-divider-link:hover::after {
    transform: translateX(6px) translateY(-0.04em);
  }

  @supports ((-webkit-background-clip: text) or (background-clip: text)) {
    .section-divider-title .section-divider-link:hover {
      background: var(--site-gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .section-divider-title .section-divider-link:hover::after {
      background: var(--site-gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      transform: translateX(6px) translateY(-0.04em);
    }
  }

  .section-divider-title .section-divider-link:focus-visible {
    outline: 2px solid var(--site-color);
    outline-offset: 3px;
    border-radius: 6px;
  }

  /* ── Action button (pill-shaped, inside .section-divider-actions) ── */
  /* Port of HBS site_shared.css lines 489–550 */
  .section-divider-actions .section-divider-link {
    appearance: none;
    display: inline-block;
    padding: 0.75rem 1.75rem;
    margin-top: 0.25em;
    border: 1px solid var(--section-medium-background-color);
    font-size: var(--ft-14-13);
    background-color: transparent;
    color: var(--white-color-2);
    font-family: var(--identity-font, sans-serif);
    font-weight: var(--font-weight6, 600);
    cursor: pointer;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, border 0.18s ease;
  }

  .section-divider-actions .section-divider-link:first-child {
    border-top-left-radius: 80px;
    border-bottom-left-radius: 80px;
  }

  .section-divider-actions .section-divider-link:last-child {
    border-top-right-radius: 80px;
    border-bottom-right-radius: 80px;
  }

  /* WHY: single button = both first and last child → fully rounded */

  @media (hover: hover) and (pointer: fine) {
    .section-divider-actions .section-divider-link[data-product-color="true"]:hover {
      background-color: transparent;
      border: 1px solid transparent;
      border-image: linear-gradient(to right,
          var(--card-hover),
          var(--card-hover)) 1;
      border-image-slice: 1;
      color: var(--card-hover);
    }

    .section-divider-actions .section-divider-link:not([data-product-color="true"]):hover {
      background: var(--site-gradient-text);
      border-image: var(--site-background-gradient) 1;
      border-image-slice: 1;
      -webkit-background-clip: text;
      -moz-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    }
  }

  .section-divider-actions .section-divider-link[data-product-color="true"].active {
    background-color: var(--card-color, var(--site-color));
    border: 1px solid var(--card-color, var(--site-color));
    color: #fff;
  }

  .section-divider-actions .section-divider-link:not([data-product-color="true"]).active {
    background: var(--site-background-gradient);
    border: 1px solid var(--site-start-color);
    border-image: none;
    color: #fff;
  }

  .section-divider-actions .section-divider-link:focus-visible {
    outline: 2px solid var(--site-color);
    outline-offset: 3px;
  }
</style>
