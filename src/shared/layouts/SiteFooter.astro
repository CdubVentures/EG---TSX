---
/**
 * SiteFooter.astro — Global site footer.
 *
 * 1:1 port of HBS `views/partials/footer.handlebars` + `site_shared.css:1510–1679`.
 * 4-column responsive grid: Brand | Socials | Contact | Legal + bottom bar.
 */

import NavLogo from './NavLogo.astro';
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo" aria-label="EG Gear site footer">
  <div class="site-footer__inner">

    <!-- Brand / Logo + About -->
    <section class="site-footer__col site-footer__brand-col" aria-label="About EG Gear">
      <NavLogo />
      <p class="site-footer__about">
        EG GEAR: independent reviews, clear guides, and tools for faster PC-gear picks. Verified specs, transparent
        criteria, and updates as products change.
      </p>
    </section>

    <!-- Socials -->
    <nav class="site-footer__col" aria-label="Follow Us">
      <h3 class="site-footer__heading">Socials / Follow Us</h3>
      <ul class="site-footer__list">
        <li>
          <a class="site-footer__link" href="https://twitter.com" target="_blank" rel="noopener noreferrer">
            <svg class="site-footer__icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="18"
              height="18" style="width:18px;height:18px;max-width:18px;max-height:18px;flex:0 0 18px;">
              <path d="M18.244 2H21.5l-7.5 8.58L22.5 22h-6.34l-5-6.2L5 22H1.744l8.21-9.4L1 2h6.42l4.57 5.7L18.244 2Z" />
            </svg>
            <span>Twitter</span>
          </a>
        </li>
        <li>
          <a class="site-footer__link" href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer">
            <svg class="site-footer__icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="18"
              height="18" style="width:18px;height:18px;max-width:18px;max-height:18px;flex:0 0 18px;">
              <path
                d="M23 7.2a4 4 0 0 0-2.8-2.8C18 4 12 4 12 4s-6 0-8.2.4A4 4 0 0 0 1 7.2 41.6 41.6 0 0 0 .6 12 41.6 41.6 0 0 0 1 16.8a4 4 0 0 0 2.8 2.8C6 20 12 20 12 20s6 0 8.2-.4a4 4 0 0 0 2.8-2.8 41.6 41.6 0 0 0 .4-4.8 41.6 41.6 0 0 0-.4-4.8ZM9.75 15.5v-7l6 3.5-6 3.5Z" />
            </svg>
            <span>YouTube</span>
          </a>
        </li>
        <li>
          <a class="site-footer__link" href="https://discord.com/invite/" target="_blank" rel="noopener noreferrer">
            <svg class="site-footer__icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="18"
              height="18" style="width:18px;height:18px;max-width:18px;max-height:18px;flex:0 0 18px;">
              <path
                d="M20.3 4.4A15.7 15.7 0 0 0 15.9 3l-.4.7a14 14 0 0 1 3.4 1.7c-1.4-.6-2.8-1-4.3-1s-3 .4-4.3 1c1-.7 2.2-1.3 3.4-1.7l-.5-.7A15.7 15.7 0 0 0 3.7 4.4C1.5 7.9.8 11.3 1 14.7 3.2 16.6 5.2 17.7 7 18l.9-1.5c-.5-.2-1.1-.5-1.8-.9l.4-.3c1.7.8 3.4 1.2 5.5 1.2s3.8-.4 5.5-1.2l.4.3c-.7.4-1.3.7-1.8.9l.9 1.5c1.8-.3 3.8-1.4 6-3.3.3-3.4-.5-6.8-2.7-10.3ZM9.4 14c-.9 0-1.6-.8-1.6-1.8s.7-1.8 1.6-1.8 1.6.8 1.6 1.8S10.3 14 9.4 14Zm5.2 0c-.9 0-1.6-.8-1.6-1.8s.7-1.8 1.6-1.8 1.6.8 1.6 1.8-.7 1.8-1.6 1.8Z" />
            </svg>
            <span>Discord</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Contact / Company -->
    <nav class="site-footer__col" aria-label="Company">
      <h3 class="site-footer__heading">Contact</h3>
      <ul class="site-footer__list">
        <li>
          <a class="site-footer__link" href="/about">
            <span class="site-link-text">About</span>
          </a>
        </li>
        <li>
          <a class="site-footer__link" href="/contact">
            <span class="site-link-text">Contact</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Legal -->
    <nav class="site-footer__col" aria-label="Legal">
      <h3 class="site-footer__heading">Legal</h3>
      <ul class="site-footer__list">
        <li>
          <a class="site-footer__link" href="/privacy">
            <span class="site-link-text">Privacy</span>
          </a>
        </li>
        <li>
          <a class="site-footer__link" href="/policies">
            <span class="site-link-text">Policies</span>
          </a>
        </li>
        <li>
          <a class="site-footer__link" href="/terms">
            <span class="site-link-text">Terms</span>
          </a>
        </li>
        <li>
          <a class="site-footer__link" href="/affiliate-disclaimer">
            <span class="site-link-text">Affiliate and Ad Disclaimer</span>
          </a>
        </li>
      </ul>
    </nav>

  </div>

  <div class="site-footer__bar">
    <p>&copy; {currentYear} Nalster LLC. All rights reserved.</p>
  </div>
</footer>

<style>
  /* WHY scoped: footer CSS is self-contained, no other component shares these selectors. */

  .site-footer {
    background: var(--eg-footer-background);
    color: var(--white-black-color-1);
    margin-top: 0rem;
    padding: 1rem 0 0;
  }

  .site-footer__inner {
    width: calc(100% - 3rem);
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 2rem 0 2rem;
    display: grid;
    grid-template-columns: minmax(0, 2.2fr) repeat(3, minmax(0, 1fr));
    column-gap: 2.75rem;
    row-gap: 2.75rem;
  }

  /* 2 cols (tablet) */
  @media (max-width: 900px) {
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* 1 col (mobile) */
  @media (max-width: 500px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      row-gap: 2.75rem;
      padding: 2rem 0 1.25rem;
    }
  }

  /* Brand column */
  .site-footer__brand-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: .5rem;
  }

  /* WHY :global(): .site-name and .logo-container are rendered by NavLogo child component.
     NavLogo has navbar-specific responsive rules (≤1150px: width:100%/center,
     ≤825px: order:2/max-width:none) that would break footer layout.
     These overrides keep the footer logo left-aligned at all sizes. */
  .site-footer :global(.logo-container) {
    width: auto;
    max-width: fit-content;
    justify-self: start;
    order: 0;
  }

  .site-footer :global(.site-name) {
    font-size: var(--font-size-32px);
    justify-content: flex-start;
  }

  .site-footer__about {
    margin: 1.25rem 0 0 .15rem;
    color: var(--white-color-2);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    font-size: clamp(var(--ft-14-13), 0.9rem + 0.15vw, var(--ft-15-13));
    line-height: 1.55;
    max-width: 56ch;
    text-wrap: pretty;
  }

  @media (max-width: 600px) {
    .site-footer__about {
      max-width: 100%;
    }
  }

  /* Columns / headings / lists */
  .site-footer__col {
    min-width: 0;
  }

  .site-footer__heading {
    margin: 0 0 .75rem 0;
    font-family: var(--identity-font);
    font-weight: 700;
    font-size: var(--font-size-15px);
    line-height: 1.2;
    letter-spacing: -.1px;
    text-transform: uppercase;
    color: var(--white-black-color-1);
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: .55rem;
  }

  /* Links — never underline */
  .site-footer__link {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-family: var(--identity-font);
    font-size: var(--font-size-14px);
    color: var(--white-color-2);
    text-decoration: none;
  }

  /* Hover/focus: solid-color fallback */
  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--site-start-color);
    text-decoration: none;
    outline: none;
  }

  /* Gradient text hover (feature-gated) */
  @supports (-webkit-background-clip: text) or (background-clip: text) {
    .site-footer__link:hover :global(.site-link-text),
    .site-footer__link:focus-visible :global(.site-link-text),
    .site-footer__link:hover > span,
    .site-footer__link:focus-visible > span {
      background-image: var(--site-gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
      text-decoration: none;
    }
  }

  /* Icon sizing */
  .site-footer__icon {
    width: 1.15em;
    height: 1.15em;
    display: inline-block;
    fill: currentColor;
  }

  /* Bottom bar */
  .site-footer__bar {
    width: calc(100% - 3rem);
    max-width: var(--site-width);
    margin: 0 auto;
    border-top: 1px solid var(--section-medium-background-color);
    padding: .95rem 0 1.35rem;
    text-align: center;
  }

  .site-footer__bar p {
    margin: 1rem 0;
    color: var(--white-color-2);
    font-family: var(--identity-font);
    font-size: var(--ft-14-13);
  }
</style>
