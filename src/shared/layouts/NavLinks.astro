---
/**
 * NavLinks.astro — Desktop primary navigation links + mega menu dropdowns.
 *
 * Matches HBS `<nav class="main-nav"><div class="wrapper"><ul class="nav-links">`
 * with full mega menus for Games, Guides, Brands, and Hubs.
 *
 * WHY inline script: Dropdown open/close logic and category switching requires
 * DOM manipulation that matches HBS partial_navbar.js behavior exactly:
 * - Fine pointer: hover to open, click to lock/unlock
 * - Coarse pointer: click to toggle open/close
 * - Category tabs switch content panels in Guides/Brands
 */

import { contentImage, collectionImagePath } from '@core/images';
import { plural } from '@core/config';
import VaultCount from '@features/vault/components/VaultCount';
import VaultDropdown from '@features/vault/components/VaultDropdown';

interface Props {
  games: Array<{ title: string; slug: string; url: string }>;
  guides: Array<{
    category: string;
    sections: Array<{
      title: string;
      items: Array<{ guide: string; url: string }>;
    }>;
  }>;
  brands: Array<{
    category: string;
    columns: Array<Array<{ brand: string; slug: string; url: string }>>;
  }>;
  hubs: Array<{ category: string }>;
}

const { games, guides, brands, hubs } = Astro.props;
const pathname = Astro.url.pathname;

/* WHY: the mega menu must stay the same width regardless of which category
   tab is selected. Using the max section count across all categories prevents
   layout shift when switching between e.g. Mouse (4 sections) and Keyboard (1). */
const maxGuideSections = Math.max(...guides.map((g) => g.sections.length), 1);

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}

function titleCase(s: string): string {
  return s.charAt(0).toUpperCase() + s.slice(1);
}
---

<nav class="main-nav">
  <div class="wrapper">
    <ul class="nav-links">
      {/* Home icon link — hidden at ≤1600px */}
      <li class="home-link">
        <a href="/" class="nav-link icon-inline" aria-label="Home">
          <svg viewBox="0 0 384 384" xmlns="http://www.w3.org/2000/svg" class="nav-home-svg" aria-hidden="true">
            <defs>
              <linearGradient id="navbarThemeGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color: var(--site-gradient-start);" />
                <stop offset="100%" style="stop-color: var(--site-gradient-end);" />
              </linearGradient>
            </defs>
            <path
              d="M319.63,199.86v121.64c0,6.56-7.48,13.74-13.91,14.53-21.69-1.34-45.95,2-67.33.1-6.34-.57-13.51-5.98-14.52-12.43-2.35-15.01,1.52-35.81-.05-51.6-.85-8.59-6.71-15.01-15.42-16.02-7.87-.91-23.3-.7-31.39-.11-10.5.76-16.68,6.28-17.59,16.85-1.34,15.64,2.02,34.99-.04,50.11-.96,7.06-7.53,12.57-14.5,13.19-21.38,1.91-45.65-1.44-67.33-.1-6.44-.8-13.91-7.97-13.91-14.53v-121.64c-14.92,18.87-41.54,2.5-27.69-18.34L178.14,55.01c8.44-8.49,18.52-8.5,26.97,0l141.46,125.77c15.56,20.65-11.47,38.46-26.94,19.08Z"
              fill="currentColor"
            />
          </svg>
          <span>Home</span>
        </a>
      </li>

      <li><a href="/news" class="nav-link" aria-current={isActive('/news') ? 'page' : undefined}>News</a></li>
      <li><a href="/reviews" class="nav-link" aria-current={isActive('/reviews') ? 'page' : undefined}>Reviews</a></li>

      {/* ─── Games mega menu ─── */}
      {games.length > 0 && (
        <li class="sub-menu">
          <a href="#" class="nav-link">Games</a>
          <div class="mega-menu games-menu" style="opacity: 0; visibility: hidden; pointer-events: none;">
            <div class="nav-game-grid">
              {/* Explore All card */}
              <div class="nav-game-grid-item">
                <a href="/games" class="nav-game-item-link explore-all-link">
                  <div class="nav-game-image-container">
                    <img
                      src="/images/games/exploreall.webp"
                      alt="Explore All Games"
                      class="nav-game-item-image"
                      draggable="false"
                      loading="lazy"
                    />
                  </div>
                  <h4 class="nav-game-title">Explore All</h4>
                </a>
              </div>
              {games.map((g) => (
                <div class="nav-game-grid-item">
                  <a href={g.url} class="nav-game-item-link">
                    <div class="nav-game-image-container">
                      <img
                        src={contentImage(collectionImagePath('games', g.slug), 'box-art-cover', 's')}
                        alt={g.title}
                        class="nav-game-item-image"
                        draggable="false"
                        loading="lazy"
                      />
                    </div>
                    <h4 class="nav-game-title">{g.title}</h4>
                  </a>
                </div>
              ))}
            </div>
          </div>
        </li>
      )}

      {/* ─── Guides mega menu ─── */}
      {guides.length > 0 && (
        <li class="sub-menu">
          <a href="#" class="nav-link">Guides</a>
          <div class="mega-menu mega-menu-guides" id="mega-menu-guides" style="opacity: 0; visibility: hidden; pointer-events: none;">
            <div class="mega-menu-inner">
              {/* Left column: category tabs */}
              <div class="mega-menu-left-column">
                <div class="mega-left-stack">
                  <ul class="mega-menu-left-nav">
                    {guides.map((cat, i) => (
                      <li>
                        <a
                          href="#"
                          data-category={cat.category}
                          class={`${cat.category}-color${i === 0 ? ' active' : ''}`}
                        >
                          <span class={`category-icon icon-${cat.category}`} />
                          {plural(cat.category)}
                        </a>
                      </li>
                    ))}
                  </ul>
                  <div class="mega-left-spacer" />
                  <a href="/guides" class="mega-menu-bottom-link left-explore-all-cta all-guides-link">
                    <span class="nav-underline">Explore All</span>
                  </a>
                </div>
              </div>

              {/* Right content: guide sections per category (HBS: titled columns) */}
              <div class="mega-menu-content">
                {guides.map((cat, i) => (
                  <div
                    class="guides-set"
                    data-category={cat.category}
                    style={i === 0 ? undefined : 'display:none;'}
                  >
                    <div class="guides-set-inner" style={`grid-template-columns: repeat(${maxGuideSections}, var(--grid-width));`}>
                      {cat.sections.map((section) => (
                        <div class="dropdown-column1">
                          <div class="category-header">
                            <h4><span class="genre-focused">{section.title}</span></h4>
                          </div>
                          <ul>
                            {section.items.map((item) => (
                              <li>
                                <a href={item.url}>
                                  <span class="nav-underline">{item.guide}</span>
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                    <a href={`/guides/${cat.category}`} class="mega-menu-bottom-link all-guides-link">
                      <span class="nav-underline">Explore All {plural(cat.category)}</span>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </li>
      )}

      {/* ─── Brands mega menu ─── */}
      {brands.length > 0 && (
        <li class="sub-menu">
          <a href="#" class="nav-link">Brands</a>
          <div class="mega-menu mega-menu-brands" id="mega-menu-brands" style="opacity: 0; visibility: hidden; pointer-events: none;">
            <div class="mega-menu-inner">
              {/* Left column: category tabs */}
              <div class="mega-menu-left-column">
                <div class="mega-left-stack">
                  <ul class="mega-menu-left-nav">
                    {brands.map((cat, i) => (
                      <li>
                        <a
                          href="#"
                          data-category={cat.category}
                          class={`${cat.category}-color${i === 0 ? ' active' : ''}`}
                        >
                          <span class={`category-icon icon-${cat.category}`} />
                          {plural(cat.category)}
                        </a>
                      </li>
                    ))}
                  </ul>
                  <div class="mega-left-spacer" />
                  <a href="/brands" class="mega-menu-bottom-link left-explore-all-cta all-guides-link">
                    <span class="nav-underline">Explore All</span>
                  </a>
                </div>
              </div>

              {/* Right content: brand items per category */}
              <div class="mega-menu-content">
                {brands.map((cat, i) => (
                  <div
                    class={`brand-set ${cat.category}-color`}
                    data-category={cat.category}
                    style={i === 0 ? undefined : 'display:none;'}
                  >
                    <div class="brand-set-inner">
                      {cat.columns.map((col) => (
                        <div class="dropdown-column1">
                          <ul>
                            {col.map((item) => (
                              <li>
                                <a href={item.url} class="brand-item">
                                  <div class="brand-logo-container">
                                    <img
                                      src={contentImage(collectionImagePath('brands', item.slug), 'brand-logo-horizontal-mono-black', 'xs', 'png')}
                                      alt={`${item.brand} logo`}
                                      class="brand-logo"
                                      loading="lazy"
                                    />
                                  </div>
                                  <span class="nav-underline">{item.brand}</span>
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                    <a href={`/brands/${cat.category}`} class="mega-menu-bottom-link all-guides-link">
                      <span class="nav-underline">Explore All {plural(cat.category)}</span>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </li>
      )}

      {/* ─── Hubs mega menu ─── */}
      {hubs.length > 0 && (
        <li class="sub-menu hubs-dropdown">
          <a href="#" class="nav-link">
            Hubs <span class="nav-dropdown-arrow"></span>
            <span class="navbar-new-badge" data-neutral="true">&nbsp;New!</span>
          </a>
          <div class="mega-menu hubs-menu" style="opacity: 0; visibility: hidden; pointer-events: none;">
            <ul>
              {hubs.map((h) => (
                <li>
                  <a href={`/hubs/${h.category}`} data-category={h.category}>
                    <span class={`category-icon icon-${h.category} ${h.category}-color`} />
                    <span class={`nav-underline ${h.category}-color`}>{titleCase(h.category)}</span>
                  </a>
                </li>
              ))}
              <li>
                <a href="/hubs" class="see-all-link" aria-label="See all hubs">
                  <span class="see-all-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="880 880 2240 2240" focusable="false">
                      <path fill="currentColor"
                        d="M1888 2448v336c0 184.789-151.211 336-336 336h-336c-184.789 0-336-151.211-336-336v-336c0-184.789 151.211-336 336-336h336c184.789 0 336 151.211 336 336zM1888 1216v336c0 184.789-151.211 336-336 336h-336c-184.789 0-336-151.211-336-336v-336c0-184.789 151.211-336 336-336h336c184.789 0 336 151.211 336 336zM3120 2448v336c0 184.789-151.211 336-336 336h-336c-184.789 0-336-151.211-336-336v-336c0-184.789 151.211-336 336-336h336c184.789 0 336 151.211 336 336zM3120 1216v336c0 184.789-151.211 336-336 336h-336c-184.789 0-336-151.211-336-336v-336c0-184.789 151.211-336 336-336h336c184.789 0 336 151.211 336 336z" />
                    </svg>
                  </span>
                  <span class="nav-underline">See All</span>
                </a>
              </li>
            </ul>
          </div>
        </li>
      )}

      {/* ─── Vault mega menu (LAST item in nav — matches HBS navbar.handlebars line 400) ─── */}
      <li class="sub-menu vault-bin-menu">
        <a href="#" class="vault-bin-button nav-link">
          <span class="vault-bin-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" class="svg-base" fill="none">
              <defs>
                <linearGradient id="neutralGradient-1" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" style="stop-color: var(--site-start-color);" />
                  <stop offset="100%" style="stop-color: var(--site-end-color);" />
                </linearGradient>
              </defs>
              <g fill="url(#neutralGradient-1)">
                <path d="M8.088 12.098l3.185-1.81a.178.178 0 01.176 0l2.843 1.615a.172.172 0 010 .3l-6.204 3.524a.178.178 0 01-.176 0L1.088 11.85A.173.173 0 011 11.7V3.947c0-.061.033-.118.088-.15L7.292.274a.176.176 0 01.264.15v3.23a.172.172 0 01-.088.15l-3.186 1.81a.173.173 0 00-.088.149v4.124c0 .062.034.119.088.15l3.63 2.062c.054.03.122.03.176 0z" />
                <path d="M8.532 3.803l3.186 1.81a.173.173 0 01.088.149v3.62c0 .06.033.118.088.149l2.842 1.615a.176.176 0 00.264-.15V3.947a.173.173 0 00-.088-.15L8.708.274a.176.176 0 00-.264.15v3.23c0 .062.034.119.088.150z" />
                <path d="M4 2h8a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V4a2 2 0 012-2z" fill="#000000" opacity="0.1" />
                <path d="M5.9 6.2l2.1 4.2h0l2.1-4.2H8l-2.1 0z" fill="#FFFFFF" />
              </g>
            </svg>
          </span>
          <div class="nav-vault-item-count-wrapper">
            <VaultCount client:only="react" />
          </div>
          Comparison Vault
        </a>
        <div class="mega-menu mega-menu-vault" id="mega-menu-vault" style="opacity: 0; visibility: hidden; pointer-events: none;">
          <VaultDropdown client:only="react" />
        </div>
      </li>
    </ul>
  </div>
</nav>

{/* ─── Dropdown logic (matches HBS partial_navbar.js) ─── */}
{/* WHY no DOMContentLoaded: Astro module scripts are deferred — DOM is
    already parsed when they execute. Wrapping in DOMContentLoaded would
    cause the listener to never fire (event already dispatched). */}
<script>
  let activeDropdown: HTMLElement | null = null;

  function closeAllDropdowns() {
    document.querySelectorAll<HTMLElement>('.nav-links > li.sub-menu, .nav-links > li').forEach((item) => {
      const dropdown = item.querySelector<HTMLElement>('.mega-menu');
      if (dropdown) {
        dropdown.style.opacity = '0';
        dropdown.style.visibility = 'hidden';
        dropdown.style.pointerEvents = 'none';
      }
      item.classList.remove('active', 'locked');
    });
    activeDropdown = null;
  }

  function isMenuLocked(): boolean {
    if (!activeDropdown) return false;
    const parentLi = activeDropdown.closest('li');
    return parentLi?.classList.contains('locked') ?? false;
  }

  function openMegaMenu(item: HTMLElement, dropdown: HTMLElement) {
    dropdown.style.opacity = '1';
    dropdown.style.visibility = 'visible';
    dropdown.style.pointerEvents = 'auto';
    item.classList.add('active');
    activeDropdown = dropdown;
  }

  function openMegaMenuLocked(item: HTMLElement, dropdown: HTMLElement) {
    dropdown.style.opacity = '1';
    dropdown.style.visibility = 'visible';
    dropdown.style.pointerEvents = 'auto';
    item.classList.add('active', 'locked');
    activeDropdown = dropdown;
  }

  function closeMegaMenu(item: HTMLElement, dropdown: HTMLElement) {
    dropdown.style.opacity = '0';
    dropdown.style.visibility = 'hidden';
    dropdown.style.pointerEvents = 'none';
    item.classList.remove('active', 'locked');
    if (activeDropdown === dropdown) activeDropdown = null;
  }

  const isFinePointer = () => window.matchMedia('(pointer: fine)').matches;

  /* WHY: links that should always navigate (skip dropdown toggling) */
  const BYPASS = '.all-guides-link, .all-hubs-link, .see-all-link, .explore-all-link, .mega-menu-vault-inner';

  /* Close open menus when hovering plain items (no dropdown) */
  document.querySelectorAll<HTMLElement>('.nav-links > li:not(.sub-menu)').forEach((li) => {
    li.addEventListener('mouseenter', () => {
      if (!isMenuLocked()) closeAllDropdowns();
    });
  });

  document.querySelectorAll<HTMLElement>('.nav-links > li').forEach((item) => {
    const dropdown = item.querySelector<HTMLElement>('.mega-menu');
    if (!dropdown) {
      item.addEventListener('click', () => closeAllDropdowns());
      return;
    }

    /* Hover open (fine pointer only) */
    item.addEventListener('mouseenter', () => {
      if (!isFinePointer()) return;
      if (activeDropdown && !isMenuLocked()) {
        const currentLi = activeDropdown.closest('li');
        if (currentLi !== item) closeAllDropdowns();
      }
      if (!activeDropdown) openMegaMenu(item, dropdown);
    });

    /* Close when leaving the trigger, unless entering its dropdown */
    item.addEventListener('mouseleave', (e) => {
      if (!isFinePointer()) return;
      const to = (e as MouseEvent).relatedTarget as Node | null;
      if (!isMenuLocked() && !dropdown.contains(to) && !item.contains(to)) {
        closeMegaMenu(item, dropdown);
      }
    });

    /* Close when leaving the dropdown, unless returning to trigger */
    dropdown.addEventListener('mouseleave', (e) => {
      if (!isFinePointer()) return;
      const to = (e as MouseEvent).relatedTarget as Node | null;
      if (!isMenuLocked() && !item.contains(to)) {
        closeMegaMenu(item, dropdown);
      }
    });

    /* Click: toggle (coarse) or lock/unlock (fine) */
    item.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest(BYPASS)) return;

      const a = (e.target as HTMLElement).closest('a');
      if (a) {
        const href = a.getAttribute('href');
        if (href && href !== '#') return;
      }

      e.preventDefault();
      e.stopPropagation();

      const isCoarse = window.matchMedia('(pointer: coarse)').matches;
      if (isCoarse) {
        if (activeDropdown === dropdown) {
          closeMegaMenu(item, dropdown);
          return;
        }
        if (activeDropdown && activeDropdown !== dropdown) closeAllDropdowns();
        openMegaMenuLocked(item, dropdown);
      } else {
        if (activeDropdown === dropdown) {
          item.classList.toggle('locked');
          dropdown.style.opacity = '1';
          dropdown.style.visibility = 'visible';
          dropdown.style.pointerEvents = 'auto';
          item.classList.add('active');
          activeDropdown = dropdown;
        } else {
          if (activeDropdown && activeDropdown !== dropdown) closeAllDropdowns();
          openMegaMenuLocked(item, dropdown);
        }
      }
    });

    /* Prevent clicks inside dropdown from closing it */
    dropdown.addEventListener('click', (e) => e.stopPropagation());
  });

  /* ─── Mobile vault icon → toggles the vault mega-menu ─── */
  const mobileVaultIcon = document.querySelector<HTMLElement>('.vault-mobile-icon');
  const vaultLi = document.querySelector<HTMLElement>('.vault-bin-menu');
  const vaultMenu = vaultLi?.querySelector<HTMLElement>('.mega-menu-vault');

  if (mobileVaultIcon && vaultLi && vaultMenu) {
    /* WHY move to body: the navbar (mainNav) creates a stacking context with
       z-index 95000. Any child — even position:fixed — paints within that
       context, so it can never appear BEHIND the navbar. Moving the vault menu
       to <body> lets it sit at z-index 94000 (below 95000), so the navbar
       covers the menu as it slides down, creating the "from under" effect.
       WHY lazy: the move happens on first click, not page load. If the page
       loads at desktop width (e.g. DevTools responsive toggle), the matchMedia
       check at load time would fail and the menu would stay trapped. */
    let _vaultMovedToBody = false;
    function ensureVaultInBody() {
      if (_vaultMovedToBody) return;
      _vaultMovedToBody = true;
      document.body.appendChild(vaultMenu!);
      // WHY: force the browser to compute the initial layout (translateY(-100%))
      // before we add vault-menu-open. Without this, the browser batches the
      // append + class add into one paint and skips the transition.
      vaultMenu!.getBoundingClientRect();
    }

    function closeSideMenuIfOpen() {
      const sideMenu = document.querySelector<HTMLElement>('.side-menu.active');
      if (!sideMenu) return false;
      document.querySelector<HTMLElement>('.mobile-hamburger-menu-icon')?.click();
      return true;
    }

    function openVaultMobile() {
      vaultMenu!.style.opacity = '1';
      vaultMenu!.style.visibility = 'visible';
      vaultMenu!.style.pointerEvents = 'auto';
      vaultMenu!.classList.add('vault-menu-open');
      vaultLi!.classList.add('active', 'locked');
      activeDropdown = vaultMenu!;
    }

    function closeVaultMobile() {
      vaultMenu!.classList.remove('vault-menu-open');
      vaultLi!.classList.remove('active', 'locked');
      // Let the slide-up transition finish before hiding
      setTimeout(() => {
        if (!vaultMenu!.classList.contains('vault-menu-open')) {
          vaultMenu!.style.opacity = '0';
          vaultMenu!.style.visibility = 'hidden';
          vaultMenu!.style.pointerEvents = 'none';
        }
      }, 350);
      if (activeDropdown === vaultMenu) activeDropdown = null;
    }

    mobileVaultIcon.addEventListener('click', (e) => {
      e.stopPropagation();
      ensureVaultInBody();

      if (vaultLi!.classList.contains('locked')) {
        closeVaultMobile();
        return;
      }

      closeAllDropdowns();

      if (closeSideMenuIfOpen()) {
        setTimeout(() => openVaultMobile(), 300);
      } else {
        openVaultMobile();
      }
    });

    // Prevent clicks inside vault dropdown from closing it
    vaultMenu.addEventListener('click', (e) => e.stopPropagation());
  }

  /* Close on top-bar-right hover/click (skip if mobile vault icon was clicked) */
  const topBarRight = document.querySelector<HTMLElement>('.top-bar-right');
  if (topBarRight) {
    topBarRight.addEventListener('mouseenter', () => {
      if (!isMenuLocked()) closeAllDropdowns();
    });
    topBarRight.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.vault-mobile-icon')) return;
      closeAllDropdowns();
    });
  }

  /* Close on logo hover */
  const logo = document.querySelector<HTMLElement>('.logo-container');
  if (logo) {
    logo.addEventListener('mouseenter', () => {
      if (!isMenuLocked()) closeAllDropdowns();
    });
  }

  /* Global away-click */
  function globalClickClose(e: Event) {
    const target = e.target as HTMLElement;
    if (activeDropdown && !target.closest('.nav-links') && !target.closest('.vault-mobile-icon') && !target.closest('.mega-menu-vault')) {
      closeAllDropdowns();
      // Also close mobile vault (it's outside .nav-links since it's in body)
      if (vaultMenu?.classList.contains('vault-menu-open')) {
        vaultMenu.classList.remove('vault-menu-open');
        vaultLi?.classList.remove('active', 'locked');
        setTimeout(() => {
          if (!vaultMenu!.classList.contains('vault-menu-open')) {
            vaultMenu!.style.opacity = '0';
            vaultMenu!.style.visibility = 'hidden';
            vaultMenu!.style.pointerEvents = 'none';
          }
        }, 350);
      }
    }
  }
  document.addEventListener('click', globalClickClose);
  document.addEventListener('touchstart', globalClickClose);

  /* ─── Guides category switching ─── */
  document.querySelectorAll<HTMLElement>('.mega-menu-guides .mega-menu-left-nav a[data-category]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const category = link.getAttribute('data-category');
      if (!category) return;

      document.querySelectorAll<HTMLElement>('.mega-menu-guides .mega-menu-left-nav a[data-category]')
        .forEach((el) => el.classList.remove('active'));
      link.classList.add('active');

      document.querySelectorAll<HTMLElement>('.guides-set').forEach((set) => {
        set.style.display = 'none';
      });
      const target = document.querySelector<HTMLElement>(`.guides-set[data-category="${category}"]`);
