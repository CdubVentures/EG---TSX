  /* Set default guides category color */
  const defaultGuidesLink = document.querySelector<HTMLElement>('.mega-menu-guides .mega-menu-left-nav a[data-category]');
  if (defaultGuidesLink) {
    const cat = defaultGuidesLink.getAttribute('data-category');
    const menu = document.querySelector<HTMLElement>('.mega-menu-guides');
    if (menu && cat) menu.style.setProperty('--navbar-guides-color', `var(--cat-${cat})`);
  }

  /* ─── Brands category switching ─── */
  document.querySelectorAll<HTMLElement>('.mega-menu-brands .mega-menu-left-nav a[data-category]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const category = link.getAttribute('data-category');
      if (!category) return;

      document.querySelectorAll<HTMLElement>('.mega-menu-brands .mega-menu-left-nav a[data-category]')
        .forEach((el) => el.classList.remove('active'));
      link.classList.add('active');

      document.querySelectorAll<HTMLElement>('.brand-set').forEach((set) => {
        set.style.display = 'none';
      });
      const target = document.querySelector<HTMLElement>(`.brand-set[data-category="${category}"]`);
      if (target) target.style.display = 'flex';

      const menu = document.querySelector<HTMLElement>('.mega-menu-brands');
      if (menu) menu.style.setProperty('--navbar-brands-color', `var(--cat-${category})`);
    });
  });

  /* Set default brands category color */
  const defaultBrandsLink = document.querySelector<HTMLElement>('.mega-menu-brands .mega-menu-left-nav a[data-category]');
  if (defaultBrandsLink) {
    const cat = defaultBrandsLink.getAttribute('data-category');
    const menu = document.querySelector<HTMLElement>('.mega-menu-brands');
    if (menu && cat) menu.style.setProperty('--navbar-brands-color', `var(--cat-${cat})`);
  }

  /* ─── Hubs menu pinning (fixed position under top bar) ─── */
  const hubsLi = document.querySelector<HTMLElement>('.sub-menu.hubs-dropdown');
  const hubsLink = hubsLi?.querySelector<HTMLElement>('.nav-link');
  const hubsMenu = hubsLi?.querySelector<HTMLElement>('.mega-menu.hubs-menu');
  const topBar = document.querySelector<HTMLElement>('.top-bar');

  if (hubsLi && hubsLink && hubsMenu && topBar) {
    Object.assign(hubsMenu.style, { position: 'fixed', transform: 'none' });

    function placeHubs() {
      const bar = topBar!.getBoundingClientRect();
      const a = hubsLink!.getBoundingClientRect();
      hubsMenu!.style.left = `${a.left}px`;
      hubsMenu!.style.top = `${bar.bottom}px`;
      hubsMenu!.style.minWidth = `${a.width}px`;
    }

    function onHubs() {
      placeHubs();
      window.addEventListener('resize', placeHubs);
      window.addEventListener('scroll', placeHubs, { passive: true });
    }
    function offHubs() {
      window.removeEventListener('resize', placeHubs);
      window.removeEventListener('scroll', placeHubs);
    }

    const observer = new MutationObserver((muts) => {
      for (const m of muts) {
        if (m.attributeName !== 'class') continue;
        hubsLi!.classList.contains('active') ? onHubs() : offHubs();
      }
    });
    observer.observe(hubsLi, { attributes: true });
