  /* ─── VanillaTilt on game cards (matches HBS lazyNavGames.js) ─── */
  /* WHY lazy: HBS only initializes tilt on first games menu hover.
     We load the library dynamically and init once to avoid blocking. */
  {
    const gamesSubMenu = document.querySelector<HTMLElement>('li.sub-menu:has(.games-menu)');
    const gamesMenu = gamesSubMenu?.querySelector<HTMLElement>('.games-menu');

    if (gamesSubMenu && gamesMenu) {
      let tiltInit = false;

      function initGamesTilt() {
        if (tiltInit) return;
        tiltInit = true;

        const tiles = gamesMenu!.querySelectorAll<HTMLElement>('.nav-game-image-container');
        if (!tiles.length) return;

        /* WHY: load script dynamically — matches HBS pattern where
           widget_tile_tilt.js is a global script and navbar uses window.VanillaTilt */
        if ((window as any).VanillaTilt) {
          (window as any).VanillaTilt.init(Array.from(tiles), {
            max: 15,
            speed: 400,
            scale: 1.025,
            perspective: 800,
            glare: true,
            'max-glare': 0.35,
          });
          return;
        }

        const script = document.createElement('script');
        script.src = '/js/widget_tile_tilt.js';
        script.onload = () => {
          if ((window as any).VanillaTilt) {
            (window as any).VanillaTilt.init(Array.from(tiles), {
              max: 15,
              speed: 400,
              scale: 1.025,
              perspective: 800,
              glare: true,
              'max-glare': 0.35,
            });
          }
        };
        document.head.appendChild(script);
      }

      gamesSubMenu.addEventListener('pointerenter', initGamesTilt, { once: true });
      gamesSubMenu.addEventListener('focusin', initGamesTilt, { once: true });
      gamesSubMenu.addEventListener('touchstart', initGamesTilt, { once: true });
    }
  }

  /* ─── Index link bypass (ensure CTAs always navigate) ─── */
  const bypassLinks = document.querySelectorAll<HTMLAnchorElement>(
    '.mega-menu .all-guides-link, .mega-menu .all-hubs-link, .mega-menu .see-all-link'
  );
  bypassLinks.forEach((a) => {
    ['click', 'pointerup', 'touchend'].forEach((type) => {
      a.addEventListener(type, (ev) => {
        const href = a.getAttribute('href');
        if (!href || href === '#') return;
        ev.preventDefault();
        ev.stopPropagation();
        ev.stopImmediatePropagation?.();
        window.location.assign(href);
      }, { capture: true });
    });
  });
