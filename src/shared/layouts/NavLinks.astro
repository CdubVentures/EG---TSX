    display: inline-block;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* Guides hover: category color */
  .mega-menu-guides .dropdown-column1 ul li a:hover .nav-underline {
    color: var(--navbar-guides-color, var(--cat-mouse));
  }
  .mega-menu-guides .dropdown-column1 ul li a:hover .nav-underline::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--navbar-guides-color, var(--cat-mouse));
  }

  /* Brands hover: category color */
  .mega-menu-brands .dropdown-column1 ul li a:hover .nav-underline {
    color: var(--navbar-brands-color, var(--cat-mouse));
  }
  .mega-menu-brands .dropdown-column1 ul li a:hover .nav-underline::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--navbar-brands-color, var(--cat-mouse));
  }

  /* ─── Bottom CTA buttons ─── */
  .mega-menu-bottom-link {
    width: 100%;
    cursor: pointer;
    text-align: center;
    background-color: var(--nav-surface-medium, #2e343b);
    box-sizing: border-box;
    border-radius: 4px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .all-guides-link {
    color: var(--white-color-1);
    text-decoration: none;
    font-family: var(--identity-font);
    font-weight: var(--font-weight7);
    font-size: var(--font-size-14px);
    display: inline-block;
    padding: 0.65rem 1rem;
    transition: background-color 0.3s ease, color 0.3s ease;
    cursor: pointer;
    position: relative;
  }

  .mega-menu-guides .mega-menu-bottom-link:hover {
    background-color: var(--navbar-guides-color, var(--cat-mouse)) !important;
  }
  .mega-menu-brands .mega-menu-bottom-link:hover {
    background-color: var(--navbar-brands-color, var(--cat-mouse)) !important;
  }

  /* Chevron arrow on bottom CTA */
  .all-guides-link::after {
    content: '\276F';
    display: inline-block;
    position: static;
    bottom: auto;
    left: auto;
    transform: none;
    width: auto;
    height: auto;
    background: none;
    margin-left: 1rem;
    transition: transform 0.3s ease, color 0.3s ease;
    color: var(--nav-text);
  }

  .mega-menu-guides .mega-menu-bottom-link:hover .all-guides-link::after,
  .mega-menu-brands .mega-menu-bottom-link:hover .all-guides-link::after {
    transform: translateX(5px);
  }

  /* Left column explore-all CTA — no extra padding vs the right button.
     WHY: HBS selector was .mega-menu-left-nav .left-explore-all-cta but the
     CTA is a sibling, not a child, so the padding-top never applied in HBS. */
  .left-explore-all-cta {
    display: block;
    text-align: center;
  }
  .left-explore-all-cta::after {
    display: none;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     BRANDS — logo circles
     ═══════════════════════════════════════════════════════════════════════════ */
  .brand-logo-container {
    flex: 0 0 2.5em;
    width: 2.5em;
    height: 2.5em;
    margin-right: 0.5rem;
    border-radius: 50%;
    background-color: #121212; /* HBS --section-darkestdark-background-color */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-logo {
    width: 1.85em;
    height: 1.85em;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .brand-item {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .brand-item:hover .brand-logo-container {
    background-color: var(--card-color, var(--site-gradient-end)) !important;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     HUBS MEGA MENU
     ═══════════════════════════════════════════════════════════════════════════ */
  .hubs-menu {
    padding: 1rem 2rem;
    min-width: max-content;
  }

  .hubs-menu > ul {
    display: block;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .hubs-menu ul li a {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 1.25rem 0;
    color: var(--white-color-1);
    text-decoration: none;
    font-size: var(--font-size-14px);
    letter-spacing: -0.5px;
    font-family: var(--identity-font);
    font-weight: var(--font-weight5);
    width: 100%;
    gap: 1rem;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* Hubs hover: per-row category color using --card-color */
  .hubs-menu ul li a:not(.active):hover .nav-underline {
    color: var(--card-color, var(--site-gradient-end));
  }
  .hubs-menu ul li a:not(.active):hover .category-icon {
    background-color: var(--card-color, var(--site-gradient-end));
  }
  .hubs-menu ul li a:not(.active):hover .nav-underline::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background-color: var(--card-color, var(--site-gradient-end));
  }

  /* Category color classes — SSOT: generated from categories.json in MainLayout.astro.
     .{cat}-color sets --card-color, --card-accent, --card-rgb, --card-glow, etc. */

  /* See All link */
  .see-all-link {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }
  .see-all-icon {
    flex: 0 0 1.5em;
    width: 1.5em;
    height: 1.5em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-text);
  }
  .see-all-icon svg {
    width: 70%;
    height: 70%;
    display: block;
    fill: currentColor;
  }

  .hubs-menu ul li a.see-all-link:hover .nav-underline {
    color: var(--site-gradient-end);
  }
  .hubs-menu ul li a.see-all-link:hover .see-all-icon {
    color: var(--site-gradient-end);
  }
  .hubs-menu ul li a.see-all-link:hover .nav-underline::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--site-gradient-end);
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     HUBS DROPDOWN HOVER (CSS-only open for fine pointer)
     ═══════════════════════════════════════════════════════════════════════════ */
  .sub-menu.hubs-dropdown {
    position: relative;
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     VAULT MEGA MENU — matches HBS partial_navbar.css vault section exactly
     ═══════════════════════════════════════════════════════════════════════════ */

  /* Vault trigger button — bordered box */
  .vault-bin-button {
    position: relative;
    display: inline-flex !important;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    border: 3px solid var(--white-color-1);
    border-radius: 0;
    transition: border 0.3s ease-out;
  }

  .vault-bin-menu {
    padding: 0.35rem;
  }

  .vault-bin-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vault-bin-icon svg {
    display: block;
    width: 1.3em;
    height: 1.3em;
    fill: currentColor;
    transition: transform 0.3s ease;
  }

  /* No underline on vault button */
  .nav-links > li.sub-menu.vault-bin-menu.locked > a.vault-bin-button::after {
    content: none !important;
  }

  /* Rotate icon on hover / locked */
  .sub-menu.vault-bin-menu:hover .vault-bin-icon svg {
    transform: rotate(180deg);
  }
  .nav-links > li.sub-menu.vault-bin-menu.locked .vault-bin-icon svg {
    transform: rotate(180deg);
  }

  /* Gradient text when locked + hover */
  .nav-links li.sub-menu.vault-bin-menu.locked > a.vault-bin-button:hover {
    background: linear-gradient(to right, var(--site-start-color), var(--site-end-color));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nav-links > li.sub-menu.vault-bin-menu.locked > a.vault-bin-button {
    border-color: transparent;
  }

  /* Gradient border via @supports mask (HBS uses this exact pattern) */
  @supports ((mask-composite: exclude) or (-webkit-mask-composite: xor)) {
    .vault-bin-button::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, var(--site-start-color), var(--site-end-color));
      top: -3px;
      left: -3px;
      right: -3px;
      bottom: -3px;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease-out;
      box-sizing: border-box;
      padding: 3px;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0) border-box;
      mask-composite: exclude;
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0) border-box;
      -webkit-mask-composite: xor;
    }
  }

  .nav-links > li.sub-menu.vault-bin-menu.locked > a.vault-bin-button::before {
    opacity: 1;
  }

  /* Badge: item count circle */
  .nav-vault-item-count-wrapper {
    position: absolute;
    top: 0;
    right: 0;
    transform: translate(50%, -50%);
    background: linear-gradient(to right, var(--site-start-color), var(--site-end-color));
    color: var(--white-color-1);
    width: 1.55em;
    aspect-ratio: 1;
    font-family: var(--identity-font);
    border-radius: 50%;
    font-size: var(--font-size-12px);
    font-weight: 700;
    display: none;
    align-items: center;
    justify-content: center;
    min-inline-size: max-content;
    pointer-events: none;
    flex-shrink: 0;
  }

  /* Show badge when React island renders content */
  .nav-vault-item-count-wrapper:has(.nav-vault-item-count) {
    display: flex;
  }

  .nav-vault-item-count {
    line-height: 1;
  }

  @media (max-width: 1150px) {
    .vault-bin-button {
      display: none !important;
    }
    .vault-bin-menu {
      padding: 0;
    }
    .nav-vault-item-count-wrapper {
      width: 1.35em;
    }
  }

  /* ─── Mega menu vault panel ─── */
  .mega-menu-vault {
    border-bottom: 1px solid var(--navbar-vault-color, var(--cat-mouse));
    padding: 2rem 2.5rem 0 2.5rem;
  }

  /* ─── Vault inner grid (same 20rem + 1fr as Guides/Brands) ─── */
  .mega-menu-vault-inner {
    display: grid;
    grid-template-columns: 20rem 1fr;
    align-items: stretch;
  }

  /* ─── Vault left column (shared styling with Guides/Brands left-column) ─── */
  /* WHY: vault reuses .mega-menu-left-column + .vault-left-column double class
     from HBS. The base styles are already on .mega-menu-left-column above. */

  /* ─── Vault-specific left-nav overrides ─── */
  .vault-link-count {
    color: var(--white-color-1);
    font-family: var(--identity-font);
    font-weight: var(--font-weight4);
    margin-left: 4px;
    margin-bottom: 2px;
  }

  /* Vault chevron (shared with guides/brands — already defined above) */
  .mega-menu-vault .mega-menu-left-nav li a::after {
    content: '\276F' !important;
    position: absolute !important;
    bottom: auto !important;
    left: auto !important;
    top: 50% !important;
    right: 1.25rem !important;
    transform: translateY(-50%) !important;
    color: var(--white-color-1);
    width: auto !important;
    height: auto !important;
    background: none !important;
    margin-left: 2rem;
  }

  /* Vault empty-cat (categories with 0 items) */
  .mega-menu-vault .mega-menu-left-nav .empty-cat::after {
    color: var(--overall-zero-score, #555) !important;
  }
  .mega-menu-vault .mega-menu-left-nav .empty-cat:hover {
    color: var(--overall-zero-score, #555);
  }
  .mega-menu-vault .mega-menu-left-nav .empty-cat:hover::after {
    filter: brightness(130%);
  }
  .mega-menu-vault .empty-cat .category-icon {
    background-color: var(--overall-zero-score, #555) !important;
  }
  .mega-menu-vault .mega-menu-left-column .mega-menu-left-nav .empty-cat:hover:not(.active) .category-icon {
    filter: brightness(130%);
  }
  .mega-menu-vault .mega-menu-left-column .mega-menu-left-nav .empty-cat.active .category-icon {
    background-color: var(--overall-zero-score, #555) !important;
  }
  .mega-menu-vault .mega-menu-left-column .mega-menu-left-nav .empty-cat:not(.active):hover .vault-link-count {
    color: var(--card-color);
  }
  .vault-left-nav li a.empty-cat {
    color: var(--overall-zero-score, #555) !important;
  }
  .vault-left-nav li a.empty-cat:hover {
    filter: brightness(130%);
  }

  /* Vault active state overrides */
  .mega-menu-vault .mega-menu-left-column .mega-menu-left-nav li a.active::after {
    color: var(--navbar-vault-color, var(--cat-mouse));
  }
  .mega-menu-vault .mega-menu-left-column .mega-menu-left-nav li a.active {
    background-color: var(--section-darkest-background-color, #0d0e0f);
    border-left: 3px solid var(--navbar-vault-color, var(--cat-mouse));
  }

  /* ─── Vault clear section ─── */
  .vault-clear-section {
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid #444;
  }

  .vault-clear-all-link {
    display: block;
    text-decoration: none;
    font-family: var(--identity-font);
    font-weight: var(--font-weight7);
    font-size: var(--font-size-15px);
    color: var(--white-color-1);
    padding: 1rem;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .vault-clear-category-link {
    font-family: var(--identity-font);
    font-size: var(--font-size-15px) !important;
    display: block;
    padding: 1rem;
    font-weight: 500;
    text-decoration: none;
    text-transform: capitalize;
    color: var(--white-color-2, #ccc) !important;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media (hover: hover) and (pointer: fine) {
    .vault-clear-all-link:hover {
      color: var(--navbar-vault-color, var(--cat-mouse)) !important;
    }
    .vault-clear-category-link:hover {
      color: var(--navbar-vault-color, var(--cat-mouse)) !important;
    }
  }

  /* Confirm timer bar (2-click confirmation pattern) */
  .confirm-timer-bar {
    height: 2px;
    background-color: var(--navbar-vault-color, var(--cat-mouse));
    width: 100%;
    transition: width 10s linear;
  }

  /* ─── Vault right content area ─── */
  .vault-right-content {
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    box-sizing: border-box;
    padding-bottom: 2rem;
    height: unset;
    padding-left: 3rem;
  }

  .vault-set {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    justify-content: space-between;
  }

  .vault-set-inner {
    display: grid;
    grid-template-columns: repeat(3, calc((var(--grid-width) * 4 + 6rem - 2rem) / 3));
    grid-auto-rows: minmax(90px, 1fr);
    gap: 1rem;
    align-items: stretch;
    justify-items: center;
  }

  .vault-set-empty {
    justify-content: center;
    align-items: center;
    width: calc(var(--grid-width) * 4 + 6rem);
  }

  .vault-set-empty .vault-set-inner {
    display: none;
  }

  /* ─── Empty state (dashed border box) ─── */
  .vault-nav-empty {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    flex: 1 1 100%;
    max-width: 100%;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    width: 100%;
    margin: auto;
    text-align: center;
    color: var(--grey-color-2, #8a8f98);
    font-family: var(--identity-font);
    font-size: var(--font-size-14px);
    border: 1px dashed var(--accent-color-1, #555);
    border-radius: 4px;
    opacity: 0.8;
    padding: 2rem 1rem;
    box-sizing: border-box;
  }

  /* ─── Vault item cards ─── */
  .navbar-vault-item {
    position: relative;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    background-color: var(--section-darkest-background-color, #0d0e0f);
    border: 1px solid var(--navbar-vault-color, var(--cat-mouse));
    border-radius: 4px;
    padding: 0.75rem;
    display: flex;
    align-items: center;
  }

  .navbar-vault-img {
    font-size: var(--font-size-15px);
    width: 4.25em;
    height: 4.25em;
    flex-shrink: 0;
  }

  .navbar-vault-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .navbar-vault-info {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
    margin-left: 0.5rem;
    flex: 1;
    min-width: 0;
    max-width: 100%;
    white-space: normal;
    cursor: pointer;
  }

  .navbar-vault-info a {
    width: 100%;
    text-decoration: none;
  }

  .navbar-vault-info .navbar-vault-brand,
  .navbar-vault-info .navbar-vault-model {
    text-decoration: none;
    text-decoration-color: transparent;
  }

  .navbar-vault-info:hover .navbar-vault-brand,
  .navbar-vault-info:hover .navbar-vault-model {
    text-decoration: underline;
    text-decoration-color: var(--navbar-vault-color, var(--cat-mouse));
    text-underline-offset: 3px !important;
    text-decoration-thickness: 2px !important;
  }

  .navbar-vault-brand,
  .navbar-vault-model {
    overflow: hidden;
    text-align: left;
    text-transform: capitalize;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    white-space: normal;
    max-width: 100%;
    word-wrap: break-word;
  }

  .navbar-vault-brand {
    font-family: var(--identity-font);
    font-size: var(--font-size-13px);
    font-weight: 400;
    color: var(--white-color-2, #ccc);
    opacity: 0.8;
    margin-bottom: 2px;
  }

  .navbar-vault-model {
    font-family: var(--identity-font);
    font-size: var(--font-size-15px);
    font-weight: 700;
    color: var(--white-color-1);
  }

  /* Remove button (trash icon) */
  .navbar-vault-remove {
    position: absolute;
    top: 6px;
    right: 4px;
    font-size: var(--font-size-15px);
    width: 1.35em;
    height: 1.35em;
    cursor: pointer;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .navbar-vault-remove svg {
    width: 100%;
    height: 100%;
    stroke: var(--white-color-1);
  }

  .navbar-vault-remove:hover {
    transform: scale(1.1);
    color: var(--navbar-vault-color, var(--cat-mouse));
  }

  .navbar-vault-remove:hover svg {
    stroke: var(--navbar-vault-color, var(--cat-mouse));
  }

  /* ─── Comparison buttons row ─── */
  .vault-comparison-row {
    display: flex;
    gap: 1rem;
    box-sizing: border-box;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .vault-comparison-row .vault-compare-link {
    flex: 1 1 calc(50% - 0.5rem);
    text-align: center;
  }

  .vault-compare-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: normal;
    text-align: center;
    flex-wrap: wrap;
    max-width: 100%;
    background-color: var(--nav-surface-medium, #2e343b);
    border-radius: 4px;
    color: var(--white-color-1);
    padding: 0.65rem 1rem;
    font-family: var(--identity-font);
    font-size: var(--font-size-15px);
    font-weight: var(--font-weight7);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    box-sizing: border-box;
    line-height: 1.25;
  }

  @media (hover: hover) and (pointer: fine) {
    .vault-compare-link:hover {
      background-color: var(--navbar-vault-color, var(--cat-mouse));
    }
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     RESPONSIVE — ≤1600px
     ═══════════════════════════════════════════════════════════════════════════ */
  @media (max-width: 1600px) {
    .nav-links > li:first-child { display: none; } /* hide Home icon */

    .mega-menu.games-menu,
    .mega-menu-guides,
    .mega-menu-brands,
    .mega-menu-vault {
      display: flex;
      flex-direction: row;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 2rem;
      width: 100% !important;
    }

    .mega-menu-inner,
    .mega-menu-vault-inner {
      margin: 0 auto;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     RESPONSIVE — ≤1150px (mobile breakpoint — hide desktop nav)
     ═══════════════════════════════════════════════════════════════════════════ */
  @media (max-width: 1150px) {
    .main-nav {
      display: none;
    }

    /* WHY position:fixed + z-index below navbar (95000): the vault menu
       is moved to <body> via JS on mobile so it escapes the navbar's
       stacking context. At z-index 94000 (below 95000), the navbar covers
       the menu as it slides down — creating the "from under" effect. */
    .mega-menu-vault {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      width: 100vw;
      max-height: calc(100dvh - var(--nav-height));
      transform: translateY(-100%);
      transition: transform 0.3s ease;
      z-index: 94000;
      min-width: unset;
    }

    .mega-menu-vault.vault-menu-open {
      transform: translateY(0);
    }

    .mega-menu-vault-inner {
      overflow-x: auto;
      overflow-y: hidden;
      margin: 0;
      display: flex;
      flex-direction: row;
      column-gap: 0;
      width: 100%;
    }

