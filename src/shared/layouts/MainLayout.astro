---
/**
 * MainLayout.astro — Global document shell.
 *
 * 4.1: document wrapper, head meta, theme, fonts, favicons, OG tags.
 * Features are added as the sub-phases that need them are built.
 */

import { CONFIG } from '@core/config';
import categoriesData from '../../../config/categories.json';
import GlobalNav from './GlobalNav.astro';
import AuthDialog from '@features/auth/components/AuthDialog';
import SettingsDialog from '@features/settings/components/SettingsDialog';

// ─── Category color derivation engine ──────────────────────────────────────
// WHY: categories.json stores ONE base hex per category. All variants (accent,
// hover, dark, glow, shadows, etc.) are derived mathematically at build time.
// Change a color in the GUI → save JSON → next build produces all variants.

function hexToRgb(hex: string): [number, number, number] {
  const h = hex.replace('#', '');
  return [parseInt(h.slice(0, 2), 16), parseInt(h.slice(2, 4), 16), parseInt(h.slice(4, 6), 16)];
}

function rgbToHsl(r: number, g: number, b: number): [number, number, number] {
  r /= 255; g /= 255; b /= 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  const l = (max + min) / 2;
  if (max === min) return [0, 0, l * 100];
  const d = max - min;
  const s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
  let h = 0;
  if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
  else if (max === g) h = ((b - r) / d + 2) / 6;
  else h = ((r - g) / d + 4) / 6;
  return [h * 360, s * 100, l * 100];
}

function hslToHex(h: number, s: number, l: number): string {
  h = ((h % 360) + 360) % 360;
  s = Math.max(0, Math.min(100, s)) / 100;
  l = Math.max(0, Math.min(100, l)) / 100;
  const c = (1 - Math.abs(2 * l - 1)) * s;
  const x = c * (1 - Math.abs((h / 60) % 2 - 1));
  const m = l - c / 2;
  let r = 0, g = 0, b = 0;
  if (h < 60) { r = c; g = x; }
  else if (h < 120) { r = x; g = c; }
  else if (h < 180) { g = c; b = x; }
  else if (h < 240) { g = x; b = c; }
  else if (h < 300) { r = x; b = c; }
  else { r = c; b = x; }
  const toHex = (v: number) => Math.round((v + m) * 255).toString(16).padStart(2, '0');
  return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
}

function deriveCategoryVars(id: string, hex: string): string {
  const [r, g, b] = hexToRgb(hex);
  const [h, s, l] = rgbToHsl(r, g, b);
  const accent = hslToHex(h, s, l * 0.9);
  const dark = hslToHex(h, s * 0.4, l * 0.35);
  const hover = hslToHex(h, s, l * 0.7);
  const gradStart = hslToHex(h, s * 0.85, l * 0.5);
  const scoreEnd = hslToHex(h, s, l * 0.75);

  // WHY "soft": HBS glow/shadow colors use a desaturated + lightened version of
  // the base color (e.g. mouse glow is rgb(115,168,225) not rgb(0,174,255)).
  // This produces softer glows that don't blow out on dark backgrounds.
  // Formula: reduce saturation 40%, increase lightness 15% (clamped to 85%).
  const softHex = hslToHex(h, s * 0.6, Math.min(l * 1.15, 85));
  const [sr, sg, sb] = hexToRgb(softHex);

  return [
    `--cat-${id}: ${hex}`,
    `--cat-${id}-accent: ${accent}`,
    `--cat-${id}-dark: ${dark}`,
    `--cat-${id}-hover: ${hover}`,
    `--cat-${id}-gradient-start: ${gradStart}`,
    `--cat-${id}-highlight: rgba(${r}, ${g}, ${b}, 0.1)`,
    `--cat-${id}-glow: rgba(${sr}, ${sg}, ${sb}, 0.8)`,
    `--cat-${id}-rgb: ${r}, ${g}, ${b}`,
    `--cat-${id}-soft-rgb: ${sr}, ${sg}, ${sb}`,
    `--cat-${id}-shadow-light: 0 4px 8px rgba(${sr}, ${sg}, ${sb}, 0.2)`,
    `--cat-${id}-shadow-xl: 0 2px 5px rgba(${sr}, ${sg}, ${sb}, 0.1)`,
    `--cat-${id}-shadow-strong: 0 6px 12px rgba(${r}, ${g}, ${b}, 0.4)`,
    `--cat-${id}-score-start: ${hex}`,
    `--cat-${id}-score-end: ${scoreEnd}`,
    `--cat-${id}-score-rgba: rgba(${r}, ${g}, ${b}, 1)`,
  ].join('; ');
}

// Generate --card-* class mappings so components use the HBS-compatible indirection layer.
// .mouse-color { --card-color: var(--cat-mouse); --card-accent: var(--cat-mouse-accent); ... }
function categoryColorClass(id: string): string {
  return `.${id}-color { ` + [
    `--card-color: var(--cat-${id})`,
    `--card-accent: var(--cat-${id}-accent)`,
    `--card-dark-accent: var(--cat-${id}-dark)`,
    `--card-rgb: var(--cat-${id}-rgb)`,
    `--card-soft-rgb: var(--cat-${id}-soft-rgb)`,
    `--card-glow: var(--cat-${id}-glow)`,
    `--card-hover: var(--cat-${id}-hover)`,
    `--card-gradientStart: var(--cat-${id}-gradient-start)`,
    `--card-highlight: var(--cat-${id}-highlight)`,
    `--card-shadow-light: var(--cat-${id}-shadow-light)`,
    `--card-shadow-extra-light: var(--cat-${id}-shadow-xl)`,
    `--card-shadow-strong: var(--cat-${id}-shadow-strong)`,
    `--card-score-start: var(--cat-${id}-score-start)`,
    `--card-score-end: var(--cat-${id}-score-end)`,
    `--card-score-rgba: var(--cat-${id}-score-rgba)`,
  ].join('; ') + '; }';
}

// ─── Site color derivation ─────────────────────────────────────────────────
// WHY: siteColors.primary and .secondary in categories.json are the SSOT for
// the site-wide gradient. All --site-* vars are derived from primary; --brand-color
// is secondary. Change them in the GUI → seasonal themes (Easter, Christmas, etc.).
function deriveSiteVars(primary: string, secondary: string): string {
  const [r, g, b] = hexToRgb(primary);
  const [h, s, l] = rgbToHsl(r, g, b);
  const accent = hslToHex(h, s, l * 0.9);
  const dark = hslToHex(h, s * 0.4, l * 0.35);
  const hover = hslToHex(h, s, l * 0.7);
  const gradStart = hslToHex(h, s * 0.85, l * 0.5);
  const softHex = hslToHex(h, s * 0.6, Math.min(l * 1.15, 85));
  const [sr, sg, sb] = hexToRgb(softHex);

  return [
    `--site-color: ${primary}`,
    `--brand-color: ${secondary}`,
    `--site-accent: ${accent}`,
    `--site-dark-accent: ${dark}`,
    `--site-hover: ${hover}`,
    `--site-gradientStart: ${gradStart}`,
    `--site-highlight: rgba(${r}, ${g}, ${b}, 0.1)`,
    `--site-glow: rgba(${sr}, ${sg}, ${sb}, 0.8)`,
    `--site-rgb: ${r}, ${g}, ${b}`,
    `--site-shadow-light: 0 4px 8px rgba(${sr}, ${sg}, ${sb}, 0.2)`,
    `--site-shadow-extra-light: 0 2px 5px rgba(${sr}, ${sg}, ${sb}, 0.1)`,
    `--site-shadow-strong: 0 6px 12px rgba(${r}, ${g}, ${b}, 0.4)`,
    `--site-score-start: ${primary}`,
    `--site-start-color: ${primary}`,
    `--site-score-end: ${secondary}`,
    `--site-end-color: ${secondary}`,
    `--site-score-rgba: rgba(${r}, ${g}, ${b}, 1)`,
    `--site-gradient-start: ${primary}`,
    `--site-gradient-end: ${secondary}`,
    `--site-gradient-text: linear-gradient(to right, ${primary}, ${secondary})`,
    `--site-background-gradient: linear-gradient(to right, ${primary}, ${secondary})`,
  ].join('; ');
}

type CatEntry = { id: string; color: string };
const cats = categoriesData.categories as CatEntry[];
const siteColors = (categoriesData as any).siteColors ?? { primary: '#394cc8', secondary: '#00aeff' };
const siteVars = deriveSiteVars(siteColors.primary, siteColors.secondary);
const rootVars = cats.map(c => deriveCategoryVars(c.id, c.color)).join('; ');
const cardClasses = cats.map(c => categoryColorClass(c.id)).join('\n');
const categoryVars = `:root { ${siteVars}; ${rootVars} }\n${cardClasses}`;

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  theme?: 'default' | 'gaming' | 'workstation' | 'review';
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage,
  ogType = 'website',
  theme = 'default',
  noIndex = false,
} = Astro.props;

const siteName = CONFIG.site.name;
const resolvedOgImage = ogImage ?? `${Astro.site ?? ''}images/favicons/icon-512.png`;

/* WHY: theme-color map used by the inline script to set <meta name="theme-color">
   before first paint. Values match --color-bg-base per theme. */
const themeColors: Record<string, string> = {
  default: '#ffffff',
  gaming: '#0a0a0f',
  workstation: '#fafafa',
  review: '#fffef7',
};

import '@/styles/global.css';
---

<!doctype html>
<html lang="en" data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta name="darkreader-lock" />
  <meta name="theme-color" content={themeColors[theme] ?? themeColors.default} />

  {/* Theme flash prevention — must run before CSS paints */}
  <script is:inline define:vars={{ themeColors }}>
    (function () {
      var saved = localStorage.getItem('eg-theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
        var tc = themeColors[saved];
        if (tc) {
          var el = document.querySelector('meta[name="theme-color"]');
          if (el) el.setAttribute('content', tc);
        }
      }
    })();
  </script>

  {/* Font preloads — critical weights only to prevent FOUT */}
  <link rel="preload" as="font" href="/fonts/open-sans-v40-latin-regular.woff2" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" as="font" href="/fonts/open-sans-v40-latin-700.woff2" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" as="font" href="/fonts/FuturaCyrillicBold.ttf" type="font/ttf" crossorigin="anonymous" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  {/* Open Graph */}
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={resolvedOgImage} />

  {/* Twitter */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  {/* Favicons */}
  <link rel="icon" type="image/x-icon" href="/images/favicons/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/images/favicons/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicons/icon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/images/favicons/icon-192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/images/favicons/icon-512.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicons/apple-touch-icon.png" />

  <meta name="generator" content={Astro.generator} />

  {/* Category accent colours — SSOT from categories.json */}
  <style set:html={categoryVars}></style>

  {/* AUTH HINT — eg_hint cookie drives .logged-hide/.logged-show CSS toggle.
      No JWT decoding, no localStorage, no globals. Runs before paint. */}
  <script is:inline>
  (function () {
    var hasHint = document.cookie.indexOf('eg_hint=1') !== -1;
    document.documentElement.classList.toggle('logged', hasHint);
  })();
  </script>
</head>

<body class="min-h-dvh bg-bg-base text-text-primary" style="padding-top: var(--nav-height);">
  <GlobalNav />

  {/* Auth dialog — React island replaces old popup divs + overlay + controller */}
  <AuthDialog client:load />

  {/* Settings dialog — React island for user preferences popup */}
  <SettingsDialog client:load />

  {/* AUTH HYDRATION — Vite-bundled module. Fetches /api/auth/me to hydrate
      $auth store with server-verified user data. Settings prefs loaded after auth. */}
  <script>
    import { hydrateAuth } from '@features/auth/store';
    import { initVaultSync } from '@features/vault/sync';
    import { loadPrefs, loadTheme } from '@features/settings/store';
    hydrateAuth();
    initVaultSync();
    loadPrefs();
    loadTheme();
  </script>

  <main>
    <slot />
  </main>
</body>
</html>
