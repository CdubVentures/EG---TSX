# Copy to .env.deploy and adjust for the target Astro app.
# Paths may be absolute or relative to this file.

DEPLOY_PROJECT_ROOT=../..
DEPLOY_SRC_DIR=src
DEPLOY_PUBLIC_DIR=public
DEPLOY_STATIC_OUTPUT_DIR=dist/client
DEPLOY_ASTRO_CACHE_DIR=.astro
DEPLOY_VITE_CACHE_DIR=node_modules/.vite
DEPLOY_SCRIPT_PATH=scripts/deploy-aws.mjs
DEPLOY_STACK_NAME=my-astro-prod

DEPLOY_S3_BUCKET=my-static-site-bucket
AWS_REGION=us-east-2
DEPLOY_CLOUDFRONT_ID=E1234567890
DEPLOY_DASHBOARD_PORT=8420
